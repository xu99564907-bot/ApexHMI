<Application x:Class="ApexHMI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ApexHMI.Converters">
    <Application.Resources>
        <!-- 通用转换器 -->
        <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <converters:NormalizedHeightConverter x:Key="NormalizedHeightConverter"/>
        <Style x:Key="SparklinePathStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="2.5"/>
            <Setter Property="Stretch" Value="Fill"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="ModeToggleButtonStyle">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow" x:Key="HighlightRowStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow" x:Key="ParameterRowStyle">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReadOnly}" Value="False">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </DataTrigger>
                <!-- P6: 与配方对比差异行高亮（蓝） -->
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </DataTrigger>
                <!-- P3: 未保存修改行高亮（黄） -->
                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                    <Setter Property="Background" Value="#FEF3C7"/>
                </DataTrigger>
                <!-- P8: 校验失败行高亮（红） -->
                <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DataGridEditTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <!-- 机械手相关转换器 -->
        <converters:BoolToIndicatorBrushConverter x:Key="BoolToIndicatorBrushConverter"/>
        <converters:BoolToIndicatorBorderConverter x:Key="BoolToIndicatorBorderConverter"/>
        <converters:BoolToIndicatorTextConverter x:Key="BoolToIndicatorTextConverter"/>
        <converters:BoolToBlueBrushConverter x:Key="BoolToBlueBrushConverter"/>
        <converters:BoolToBlueBorderConverter x:Key="BoolToBlueBorderConverter"/>
        <converters:BoolToBlueTextConverter x:Key="BoolToBlueTextConverter"/>
        <converters:BoolToYellowBrushConverter x:Key="BoolToYellowBrushConverter"/>
        <converters:BoolToYellowBorderConverter x:Key="BoolToYellowBorderConverter"/>
        <converters:BoolToYellowTextConverter x:Key="BoolToYellowTextConverter"/>
        <converters:BoolToErrorBrushConverter x:Key="BoolToErrorBrushConverter"/>
        <converters:BoolToErrorBorderConverter x:Key="BoolToErrorBorderConverter"/>
        <converters:BoolToErrorTextConverter x:Key="BoolToErrorTextConverter"/>
        <converters:BoolToErrorBackgroundConverter x:Key="BoolToErrorBackgroundConverter"/>
        <converters:BoolToErrorValueConverter x:Key="BoolToErrorValueConverter"/>
        <converters:BoolToStatusTitleConverter x:Key="BoolToStatusTitleConverter"/>
        <converters:BoolToStatusTitleColorConverter x:Key="BoolToStatusTitleColorConverter"/>
        <converters:BoolToStatusMessageConverter x:Key="BoolToStatusMessageConverter"/>
        <converters:BoolToStatusMessageColorConverter x:Key="BoolToStatusMessageColorConverter"/>
        <converters:BoolToErrorBorderBrushConverter x:Key="BoolToErrorBorderBrushConverter"/>
        <converters:ErrorToTextColorConverter x:Key="ErrorToTextColorConverter"/>
    </Application.Resources>
</Application>
