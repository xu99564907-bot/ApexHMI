<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 共用按钮基类 -->
    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,8,8"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Primary：主操作（蓝） -->
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.PrimaryHover}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.PrimaryHover}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary：次级操作（深灰） -->
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#374151"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#374151"/>
    </Style>

    <!-- Success：保存类 / 应用类（绿） -->
    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.Success}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Success}"/>
    </Style>

    <!-- Danger：删除 / 危险操作（红） -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.Danger}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.DangerHover}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.DangerHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Warning：警告类（橙） -->
    <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.Warning}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning}"/>
    </Style>

    <!-- Ghost：低权重按钮 (浅灰底框) -->
    <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#E2E8F0"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
    </Style>

    <!-- Icon：表内行内按钮（透明底，小） -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

</ResourceDictionary>
