<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 默认 DataGrid 视觉（隐式应用 — 通过 BasedOn 自定义可继续覆盖） -->
    <Style TargetType="DataGrid" x:Key="StandardDataGrid">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="{StaticResource Brush.Surface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.SurfaceAlt}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.BorderSoft}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader" x:Key="StandardDataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Brush.HeaderBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.HeaderText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,8"/>
    </Style>

    <Style TargetType="DataGridCell" x:Key="StandardDataGridCell">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

</ResourceDictionary>
