<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 深色主题：覆盖 Theme.xaml 中的 Brush.* 与 Color.* 别名 -->
    <Color x:Key="Color.Primary">#3B82F6</Color>
    <Color x:Key="Color.PrimaryHover">#60A5FA</Color>
    <Color x:Key="Color.PrimaryLight">#1E3A8A</Color>
    <Color x:Key="Color.Success">#10B981</Color>
    <Color x:Key="Color.SuccessLight">#064E3B</Color>
    <Color x:Key="Color.Warning">#FBBF24</Color>
    <Color x:Key="Color.WarningLight">#78350F</Color>
    <Color x:Key="Color.Danger">#EF4444</Color>
    <Color x:Key="Color.DangerHover">#F87171</Color>
    <Color x:Key="Color.DangerLight">#7F1D1D</Color>
    <Color x:Key="Color.Info">#A78BFA</Color>
    <Color x:Key="Color.InfoLight">#4C1D95</Color>

    <Color x:Key="Color.Text">#F1F5F9</Color>
    <Color x:Key="Color.TextSecondary">#CBD5E1</Color>
    <Color x:Key="Color.TextMuted">#94A3B8</Color>
    <Color x:Key="Color.TextPlaceholder">#64748B</Color>
    <Color x:Key="Color.Border">#334155</Color>
    <Color x:Key="Color.BorderSoft">#1E293B</Color>
    <Color x:Key="Color.Surface">#1E293B</Color>
    <Color x:Key="Color.SurfaceAlt">#0F172A</Color>
    <Color x:Key="Color.SurfaceMuted">#0B1220</Color>
    <Color x:Key="Color.Background">#020617</Color>
    <Color x:Key="Color.HeaderBackground">#0F172A</Color>
    <Color x:Key="Color.HeaderText">#E2E8F0</Color>

    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="Brush.PrimaryHover" Color="{StaticResource Color.PrimaryHover}"/>
    <SolidColorBrush x:Key="Brush.PrimaryLight" Color="{StaticResource Color.PrimaryLight}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.SuccessLight" Color="{StaticResource Color.SuccessLight}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.WarningLight" Color="{StaticResource Color.WarningLight}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.DangerHover" Color="{StaticResource Color.DangerHover}"/>
    <SolidColorBrush x:Key="Brush.DangerLight" Color="{StaticResource Color.DangerLight}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>
    <SolidColorBrush x:Key="Brush.InfoLight" Color="{StaticResource Color.InfoLight}"/>

    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Color.Text}"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}"/>
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="{StaticResource Color.TextPlaceholder}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="Brush.BorderSoft" Color="{StaticResource Color.BorderSoft}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}"/>
    <SolidColorBrush x:Key="Brush.SurfaceMuted" Color="{StaticResource Color.SurfaceMuted}"/>
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="{StaticResource Color.HeaderBackground}"/>
    <SolidColorBrush x:Key="Brush.HeaderText" Color="{StaticResource Color.HeaderText}"/>
</ResourceDictionary>
