# ApexHMI EditorConfig / Analyzer Configuration
root = true

# ── General formatting ──────────────────────────────────────
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{xaml,xml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.json]
indent_size = 2

# ── C# coding style ─────────────────────────────────────────
[*.cs]
csharp_indent_labels = one_left
csharp_using_directive_placement = outside_namespace
csharp_prefer_braces = true
csharp_preserve_single_line_blocks = true
dotnet_diagnostic.IDE0055.severity = suggestion

# ── StyleCop.Analyzers ─────────────────────────────────────
dotnet_diagnostic.SA0001.severity = none        # XML comment analysis disabled
dotnet_diagnostic.SA1101.severity = none        # prefix local calls with this.
dotnet_diagnostic.SA1309.severity = none        # field names must not begin with underscore
dotnet_diagnostic.SA1404.severity = suggestion   # Code analysis suppression
dotnet_diagnostic.SA1413.severity = none        # Use trailing comma in multi-line initializers
dotnet_diagnostic.SA1600.severity = none        # Elements must be documented
dotnet_diagnostic.SA1601.severity = none        # Partial elements must be documented
dotnet_diagnostic.SA1602.severity = none        # Enumeration items must be documented
dotnet_diagnostic.SA1633.severity = none        # File must have header
dotnet_diagnostic.SA1649.severity = none        # File name must match type name
dotnet_diagnostic.SA1652.severity = none        # Enable XML documentation output

# ── V2-LINT-01: 降级高频噪声规则 ─────────────────────────
dotnet_diagnostic.SA1005.severity = suggestion  # Single line comment should begin with space
dotnet_diagnostic.SA1025.severity = suggestion  # Code should not contain multiple whitespace in a row
dotnet_diagnostic.SA1111.severity = none        # Closing parenthesis should be on line of last parameter
dotnet_diagnostic.SA1116.severity = none        # Parameters should begin on line after declaration
dotnet_diagnostic.SA1137.severity = none        # Elements should have same indentation
dotnet_diagnostic.SA1201.severity = suggestion  # Field should not follow method
dotnet_diagnostic.SA1208.severity = suggestion  # Using directives should be ordered by namespace
dotnet_diagnostic.SA1210.severity = suggestion  # Using directives alphabetical
dotnet_diagnostic.SA1501.severity = none        # Statement should not be on a single line
dotnet_diagnostic.SA1502.severity = none        # Element should not be on a single line
dotnet_diagnostic.SA1503.severity = none        # Braces should not be omitted
dotnet_diagnostic.SA1513.severity = none        # Closing brace should be preceded by blank line
dotnet_diagnostic.SA1515.severity = none        # Single-line comment should be preceded by blank line
dotnet_diagnostic.SA1516.severity = none        # Elements should be separated by blank line
dotnet_diagnostic.SA1518.severity = none        # File should not have blank lines at end
dotnet_diagnostic.SA1124.severity = suggestion  # Do not use regions
dotnet_diagnostic.SA1134.severity = suggestion  # Each attribute on own line
dotnet_diagnostic.SA1202.severity = suggestion  # Public before private ordering
dotnet_diagnostic.SA1204.severity = suggestion  # Static before non-static ordering
dotnet_diagnostic.SA1214.severity = suggestion  # Readonly before non-readonly ordering
dotnet_diagnostic.SA1009.severity = suggestion  # Closing parenthesis spacing
dotnet_diagnostic.SA1128.severity = suggestion  # Constructor initializer on own line
dotnet_diagnostic.SA1401.severity = suggestion  # Fields should be private
dotnet_diagnostic.SA1001.severity = suggestion  # Commas should be spaced correctly
dotnet_diagnostic.SA1008.severity = suggestion  # Opening parenthesis spacing
dotnet_diagnostic.SA1010.severity = suggestion  # Closing square bracket spacing
dotnet_diagnostic.SA1028.severity = suggestion  # Trailing whitespace
dotnet_diagnostic.SA1107.severity = suggestion  # One statement per line
dotnet_diagnostic.SA1118.severity = suggestion  # Parameter spans multiple lines
dotnet_diagnostic.SA1122.severity = suggestion  # Use string.Empty
dotnet_diagnostic.SA1130.severity = suggestion  # Lambda expression
dotnet_diagnostic.SA1132.severity = suggestion  # Namespace should be file-scoped
dotnet_diagnostic.SA1133.severity = suggestion  # Attributes on separate lines
dotnet_diagnostic.SA1300.severity = suggestion  # Element should begin with uppercase
dotnet_diagnostic.SA1312.severity = suggestion  # Variable names should begin with lower-case
dotnet_diagnostic.SA1402.severity = suggestion  # File may only contain single type
dotnet_diagnostic.SA1507.severity = suggestion  # Code should not contain multiple blank lines
dotnet_diagnostic.SA1508.severity = suggestion  # Closing brace spacing
dotnet_diagnostic.SA1512.severity = suggestion  # Single-line comment indentation
dotnet_diagnostic.SA1519.severity = suggestion  # Braces multi-line
dotnet_diagnostic.SA1520.severity = suggestion  # Braces consistent
dotnet_diagnostic.SA1642.severity = suggestion  # Constructor XML summary
dotnet_diagnostic.SA1117.severity = suggestion  # Parameters line formatting
dotnet_diagnostic.SA1127.severity = suggestion  # Generic type constraints on own line
dotnet_diagnostic.SA1407.severity = suggestion  # Arithmetic expression precedence

# ── Roslynator.Analyzers ───────────────────────────────────
dotnet_diagnostic.RCS1001.severity = suggestion  # Add braces to if-else
dotnet_diagnostic.RCS1018.severity = suggestion  # Add accessibility modifiers
dotnet_diagnostic.RCS1036.severity = suggestion  # Remove empty line
dotnet_diagnostic.RCS1058.severity = suggestion  # Use compound assignment
dotnet_diagnostic.RCS1102.severity = suggestion  # Mark class as static
dotnet_diagnostic.RCS1163.severity = suggestion  # Unused parameter

# ── .NET analyzers ─────────────────────────────────────────
dotnet_diagnostic.CA2007.severity = suggestion    # Do not directly await a Task
dotnet_diagnostic.IDE0018.severity = suggestion    # Inline variable declaration
dotnet_diagnostic.IDE0028.severity = suggestion    # Simplify collection initializer
dotnet_diagnostic.IDE0290.severity = suggestion    # Use primary constructor
