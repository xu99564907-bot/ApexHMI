# ApexHMI EditorConfig / Analyzer Configuration
root = true

# ── General formatting ──────────────────────────────────────
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{xaml,xml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.json]
indent_size = 2

# ── C# coding style ─────────────────────────────────────────
[*.cs]
csharp_indent_labels = one_left
csharp_using_directive_placement = outside_namespace
csharp_prefer_braces = true
csharp_preserve_single_line_blocks = true
dotnet_diagnostic.IDE0055.severity = suggestion

# ── StyleCop.Analyzers ─────────────────────────────────────
dotnet_diagnostic.SA0001.severity = none        # XML comment analysis disabled
dotnet_diagnostic.SA1101.severity = none        # prefix local calls with this.
dotnet_diagnostic.SA1309.severity = none        # field names must not begin with underscore
dotnet_diagnostic.SA1404.severity = suggestion   # Code analysis suppression
dotnet_diagnostic.SA1413.severity = none        # Use trailing comma in multi-line initializers
dotnet_diagnostic.SA1600.severity = none        # Elements must be documented
dotnet_diagnostic.SA1601.severity = none        # Partial elements must be documented
dotnet_diagnostic.SA1602.severity = none        # Enumeration items must be documented
dotnet_diagnostic.SA1633.severity = none        # File must have header
dotnet_diagnostic.SA1649.severity = none        # File name must match type name
dotnet_diagnostic.SA1652.severity = none        # Enable XML documentation output

# ── Roslynator.Analyzers ───────────────────────────────────
dotnet_diagnostic.RCS1001.severity = suggestion  # Add braces to if-else
dotnet_diagnostic.RCS1018.severity = suggestion  # Add accessibility modifiers
dotnet_diagnostic.RCS1036.severity = suggestion  # Remove empty line
dotnet_diagnostic.RCS1058.severity = suggestion  # Use compound assignment
dotnet_diagnostic.RCS1102.severity = suggestion  # Mark class as static
dotnet_diagnostic.RCS1163.severity = suggestion  # Unused parameter

# ── .NET analyzers ─────────────────────────────────────────
dotnet_diagnostic.CA2007.severity = suggestion    # Do not directly await a Task
dotnet_diagnostic.IDE0018.severity = suggestion    # Inline variable declaration
dotnet_diagnostic.IDE0028.severity = suggestion    # Simplify collection initializer
dotnet_diagnostic.IDE0290.severity = suggestion    # Use primary constructor
