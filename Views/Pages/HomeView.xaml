<UserControl x:Class="ApexHMI.Views.Pages.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l="clr-namespace:ApexHMI.Converters"
             xmlns:controls="clr-namespace:ApexHMI.Views.Controls"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid Margin="12" DataContext="{Binding ShellViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding RuntimeHeaderText}" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="{l:Loc Home_RuntimeHint}" Foreground="#64748B" Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,10,0"><StackPanel><TextBlock Text="{l:Loc Home_ModeInfo}" Foreground="#6366F1"/><TextBlock Text="{Binding DesignerModeText}" FontSize="18" FontWeight="Bold" Foreground="#3730A3"/></StackPanel></Border>
                                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,10,0"><StackPanel><TextBlock Text="{l:Loc Home_CommStatus}" Foreground="#059669"/><TextBlock Text="{Binding CommunicationStatus}" FontSize="18" FontWeight="Bold" Foreground="#047857"/></StackPanel></Border>
                                    <!-- H1 班次目标完成度环形进度 + H2 倒计时 (Phase 3 切到 RingProgressBar) -->
                                    <Border Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1" CornerRadius="10" Padding="14,10" Width="220">
                                        <DockPanel>
                                            <controls:RingProgressBar DockPanel.Dock="Left"
                                                                      Diameter="78" Thickness="9"
                                                                      Value="{Binding ProductionProgressPercent}"
                                                                      Caption="完成率"
                                                                      ValueFontSize="16"
                                                                      Margin="0,0,12,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="本班次产量" Foreground="#0369A1" FontSize="11"/>
                                                <TextBlock Text="{Binding ProductionProgressText}" FontSize="16" FontWeight="Bold" Foreground="#0369A1" Margin="0,2,0,4"/>
                                                <TextBlock Text="{Binding ShiftRemainingText}" Foreground="#0369A1" FontSize="11"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="2.2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="16" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="{l:Loc Home_ProductionStatus}" Foreground="#64748B"/><TextBlock Text="{Binding DeviceStatusText}" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/></StackPanel>
                                        <StackPanel Grid.Column="1"><TextBlock Text="{l:Loc Home_ProductionCount}" Foreground="#64748B"/><TextBlock Text="{Binding ProductionCount}" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/><Path Data="{Binding ProductionTrendPath}" Stroke="#2563EB" StrokeThickness="1.5" Stretch="Fill" Height="18" Margin="0,4,8,0" SnapsToDevicePixels="True"/></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock Text="{l:Loc Home_OeeRate}" Foreground="#64748B"/><TextBlock Text="{Binding OeeRate, StringFormat={}{0:F1}%}" FontSize="22" FontWeight="Bold" Foreground="#16A34A"/><Path Data="{Binding OeeTrendPath}" Stroke="#16A34A" StrokeThickness="1.5" Stretch="Fill" Height="18" Margin="0,4,8,0" SnapsToDevicePixels="True"/></StackPanel>
                                        <StackPanel Grid.Column="3"><TextBlock Text="{l:Loc Home_DeviceStatus}" Foreground="#64748B"/><TextBlock Text="{Binding AxisStatusText}" FontSize="18" FontWeight="Bold" Foreground="#0F172A" TextWrapping="Wrap"/></StackPanel>
                                        <StackPanel Grid.Column="4"><TextBlock Text="{l:Loc Home_ActiveAlarms}" Foreground="#64748B"/><TextBlock Text="{Binding ActiveAlarmCount}" FontSize="22" FontWeight="Bold" Foreground="#D97706"/></StackPanel>
                                        <StackPanel Grid.Column="5"><TextBlock Text="{l:Loc Home_UnackAlarms}" Foreground="#64748B"/><TextBlock Text="{Binding UnacknowledgedAlarmCount}" FontSize="22" FontWeight="Bold" Foreground="#DC2626"/></StackPanel>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock Text="{l:Loc Home_RuntimePage}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{l:Loc Home_OverviewHint}" Foreground="#64748B" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <Grid Grid.Row="1" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="14" Margin="0,0,10,0">
                                                <StackPanel>
                                                    <TextBlock Text="{l:Loc Home_LineControl}" Foreground="#64748B"/>
                                                    <TextBlock Text="{l:Loc Home_LineHint}" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,12"/>
                                                    <WrapPanel Margin="0,0,0,8">
                                                        <Button Content="{l:Loc Home_GotoManual}" Command="{Binding NavigateCommand}" CommandParameter="手动操作" Style="{StaticResource PrimaryButtonStyle}"/>
                                                        <Button Content="{l:Loc Home_GotoAlarm}" Command="{Binding NavigateCommand}" CommandParameter="报警画面" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="12,8" Margin="0,0,8,8"/>
                                                        <Button Content="{l:Loc Home_RefreshStatus}" Command="{Binding RefreshTagsCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,8"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{l:Loc Home_RunMode}" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,8"/>
                                                    <WrapPanel Margin="0,0,0,8">
                                                        <primitives:ToggleButton Content="{l:Loc Home_Mode_Debug}" IsChecked="{Binding IsDebugMode, Mode=OneWay}" Command="{Binding SetDebugModeCommand}" Style="{StaticResource ModeToggleButtonStyle}"/>
                                                        <primitives:ToggleButton Content="{l:Loc Home_Mode_DryRun}" IsChecked="{Binding IsDryRunMode, Mode=OneWay}" Command="{Binding SetDryRunModeCommand}" Style="{StaticResource ModeToggleButtonStyle}"/>
                                                        <primitives:ToggleButton Content="{l:Loc Home_Mode_Bypass}" IsChecked="{Binding IsBypassStationMode, Mode=OneWay}" Command="{Binding SetBypassStationModeCommand}" Style="{StaticResource ModeToggleButtonStyle}"/>
                                                        <primitives:ToggleButton Content="{l:Loc Home_Mode_Manual}" IsChecked="{Binding IsManualMode, Mode=OneWay}" Command="{Binding SetManualModeCommand}" Style="{StaticResource ModeToggleButtonStyle}"/>
                                                        <primitives:ToggleButton Content="{l:Loc Home_Mode_Auto}" IsChecked="{Binding IsAutoMode, Mode=OneWay}" Command="{Binding SetAutoModeCommand}" Style="{StaticResource ModeToggleButtonStyle}"/>
                                                    </WrapPanel>
                                                    <TextBlock Text="{l:Loc Home_RunOps}" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,8"/>
                                                    <WrapPanel>
                                                        <Button x:Name="StartDeviceButton" Content="{l:Loc Home_LongPressStart}" Width="116" Height="38" Margin="0,0,8,8" PreviewMouseLeftButtonDown="StartDeviceButton_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="StartDeviceButton_PreviewMouseLeftButtonUp" MouseLeave="StartDeviceButton_PreviewMouseLeftButtonUp" Background="#2563EB" Foreground="White" BorderBrush="#60A5FA" BorderThickness="1.5"/>
                                                        <Button Content="{l:Loc Home_ImmediateStop}" Width="116" Height="38" Margin="0,0,8,8" Command="{Binding StopDeviceCommand}" Background="#DC2626" Foreground="White" BorderBrush="#FCA5A5" BorderThickness="1.5"/>
                                                        <Button Content="{l:Loc Home_AlarmReset}" Width="116" Height="38" Margin="0,0,8,8" Command="{Binding ResetAlarmFromHomeCommand}" Background="#D97706" Foreground="White" BorderBrush="#FCD34D" BorderThickness="1.5"/>
                                                    </WrapPanel>
                                                    <ProgressBar Value="{Binding StartHoldProgress}" Maximum="100" Height="10" Margin="0,8,0,0" Foreground="#60A5FA" Background="#E2E8F0"/>
                                                    <TextBlock Text="{l:Loc Home_StartHint}" Foreground="#64748B" Margin="0,8,0,0"/>
                                                    <UniformGrid Columns="3" Margin="0,10,0,0">
                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,6,0" ToolTip="{Binding StartReadyDetail}"><StackPanel><TextBlock Text="{l:Loc Home_ModeReady}" Foreground="#64748B" FontSize="12"/><TextBlock Text="{Binding StartModeReady}" Foreground="#16A34A" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="3,0" ToolTip="{Binding StartReadyDetail}"><StackPanel><TextBlock Text="{l:Loc Home_AlarmClear}" Foreground="#64748B" FontSize="12"/><TextBlock Text="{Binding StartAlarmReady}" Foreground="#16A34A" FontWeight="Bold"/></StackPanel></Border>
                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="6,0,0,0" ToolTip="{Binding StartReadyDetail}"><StackPanel><TextBlock Text="{l:Loc Home_InterlockReady}" Foreground="#64748B" FontSize="12"/><TextBlock Text="{Binding StartInterlockReady}" Foreground="#16A34A" FontWeight="Bold"/></StackPanel></Border>
                                                    </UniformGrid>
                                                    <TextBlock Text="{Binding StartReadyDetail}" Foreground="#64748B" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- H4 重点报警卡可点击 → 跳报警页对应记录 -->
                                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="14"
                                                    Cursor="Hand" ToolTip="点击跳转到报警画面查看详情">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding JumpToFocusAlarmCommand}"/>
                                                </Border.InputBindings>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{l:Loc Home_KeyAlarms}" Foreground="#64748B"/>
                                                        <TextBlock DockPanel.Dock="Right" Text="↗ 详情" Foreground="#2563EB" FontSize="12" FontWeight="SemiBold"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding FocusAlarmHint}" FontSize="18" FontWeight="Bold" Foreground="#DC2626" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding EstimatedDowntimeMinutes, StringFormat=预计停机：{0:F1} min}" Foreground="#D97706" Margin="0,10,0,4"/>
                                                    <TextBlock Text="{Binding EstimatedProductionLoss, StringFormat=预计影响产量：{0}}" Foreground="#DC2626"/>
                                                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,12,0,0">
                                                        <TextBlock Text="{Binding RunModeSummary, StringFormat=当前运行模式：{0}}" Foreground="#1D4ED8"/>
                                                    </Border>
                                                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding StartStopSummary}" Foreground="#047857"/>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{l:Loc Home_RuntimeSummary}" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                                    <Border Background="#FFFFFF" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12"><StackPanel><TextBlock Text="{l:Loc Home_AutoFlowStatus}" Foreground="#64748B"/><TextBlock Text="{Binding CurrentFlowStepText}" Foreground="#2563EB" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/><TextBlock Text="{Binding CurrentFlowComment}" Foreground="#334155" TextWrapping="Wrap" Margin="0,6,0,0"/></StackPanel></Border>
                                    <Border Background="#FFFFFF" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- H6 / H7 流程日志过滤 + 搜索 -->
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Text="{l:Loc Home_FlowLog}" Foreground="#64748B" VerticalAlignment="Center"/>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <CheckBox Content="信息" IsChecked="{Binding FlowLogShowInfo}" Foreground="#2563EB" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <CheckBox Content="警告" IsChecked="{Binding FlowLogShowWarn}" Foreground="#D97706" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <CheckBox Content="错误" IsChecked="{Binding FlowLogShowError}" Foreground="#DC2626" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DockPanel>
                                            <TextBox Text="{Binding FlowLogSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="搜索流程日志（步号 / 流程名 / 关键字）"
                                                     BorderBrush="#D7DFEA" Padding="6,4" Margin="0,0,0,6" FontSize="12"/>
                                            <ListBox ItemsSource="{Binding FlowStepsView}" Height="290" BorderThickness="0" Background="Transparent"
                                                     VirtualizingPanel.IsVirtualizing="True"
                                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                                     ScrollViewer.CanContentScroll="True">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,5">
                                                            <TextBlock FontSize="12" Foreground="#334155" TextWrapping="Wrap">
                                                                <Run Text="{Binding Time, StringFormat={}{0:HH:mm:ss}}"/>
                                                                <Run Text="  "/>
                                                                <Run Text="{Binding Comment}"/>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                    </ScrollViewer>
</UserControl>
