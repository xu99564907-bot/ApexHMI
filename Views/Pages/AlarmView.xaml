<UserControl x:Class="ApexHMI.Views.Pages.AlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- A5 直方图单 bar 模板：高度由 NormalizedHeight × MaxHeight 决定 -->
        <Style x:Key="HistogramBarStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Fill" Value="#DC2626"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- A1 高级别报警横幅（HighAlarmBannerText 非空时显示） -->
        <Border Grid.Row="0" Background="#DC2626" CornerRadius="8" Padding="14,10" Margin="0,0,0,10"
                Visibility="{Binding HighAlarmBannerText, Converter={StaticResource StringNotEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="🔔" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button DockPanel.Dock="Right" Content="✕"
                        Command="{Binding DismissHighAlarmBannerCommand}"
                        Background="Transparent" Foreground="White" BorderBrush="{x:Null}"
                        Padding="8,2" FontSize="14" Cursor="Hand"/>
                <TextBlock Text="{Binding HighAlarmBannerText}" Foreground="White" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- 顶部信息卡 + 全局按钮 -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Padding="16"
                Margin="0,0,0,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentAlarmTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text="左侧子导航切换：当前报警 / 历史报警 / 日志 / 报警统计" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,8,0,0"/>
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right">
                    <Button Content="确认全部报警" Command="{Binding AcknowledgeAllAlarmsCommand}"
                            Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                            Padding="14,8" Margin="0,0,8,8"
                            ToolTip="A6: 二次确认弹层后才生效"/>
                    <Button Content="复位全部报警" Command="{Binding ResetAllAlarmsCommand}"
                            Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="14,8" Margin="0,0,8,8"/>
                    <Button Content="导出筛选结果"
                            Command="{Binding ExportFilteredAlarmsCommand}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            Padding="14,8" Margin="0,0,8,8"
                            ToolTip="A4: 导出当前筛选条件下的当前+历史报警为 CSV"/>
                    <Button Content="保存报警历史" Command="{Binding SaveAlarmHistoryCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8" Margin="0,0,8,8"/>
                    <Button Content="加载报警历史" Command="{Binding LoadAlarmHistoryCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8" Margin="0,0,0,8"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- A2/A9 过滤工具栏：级别 / 来源 / 时间 / 关键字（当前+历史共用） -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="12,8" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="级别：" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="100" Height="26" Margin="0,0,12,0"
                          ItemsSource="{Binding AlarmListLevelOptions}"
                          SelectedItem="{Binding AlarmListLevelFilter}"/>
                <TextBlock Text="来源：" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="160" Height="26" Margin="0,0,12,0"
                          ItemsSource="{Binding AlarmSourceOptions}"
                          SelectedItem="{Binding AlarmListSourceFilter}"/>
                <TextBlock Text="时间：" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="100" Height="26" Margin="0,0,12,0"
                          ItemsSource="{Binding AlarmListTimeRangeOptions}"
                          SelectedItem="{Binding AlarmListTimeRange}"/>
                <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="220" Height="26" Margin="0,0,12,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding AlarmListKeyword, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="搜索来源 / 内容 / 备注（A9）"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="3">
            <!-- 当前报警：表格 + 右侧 A3 详情侧边栏 -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="12"
                    Visibility="{Binding IsAlarmCurrentPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="当前报警" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding CurrentAlarmsView}"
                                  SelectedItem="{Binding SelectedAlarmDetail, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}"
                                  BorderBrush="{DynamicResource Brush.BorderSoft}" RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                                  RowStyle="{StaticResource HighlightRowStyle}"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Height="540">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat='HH:mm:ss'}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="60" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="已确认" Binding="{Binding Acknowledged}" Width="70"/>
                                <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                <!-- A8: 跳流程按钮 -->
                                <DataGridTemplateColumn Header="" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="跳流程"
                                                    Command="{Binding DataContext.JumpToFlowByAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Source}"
                                                    Background="Transparent" BorderBrush="#CBD5E1" Foreground="{DynamicResource Brush.TextSecondary}"
                                                    FontSize="11" Padding="6,2" Height="22"
                                                    ToolTip="跳到程序监控页对应流程步号（A8）"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- A3 详情侧边栏 -->
                    <Border Grid.Column="1" Margin="10,0,0,0"
                            Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1" CornerRadius="6"
                            Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedAlarmDetail}">
                                <TextBlock Text="📋 报警详情" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                                <StackPanel Visibility="{Binding ., Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="时间"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                                               Text="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="级别 / 状态"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8">
                                        <Run Text="{Binding Level}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding State}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="来源"/>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                                               Text="{Binding Source}" TextWrapping="Wrap"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="内容"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                                               Text="{Binding Message}" TextWrapping="Wrap"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="处理建议"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8"
                                               Text="{Binding HandlingSuggestion}" TextWrapping="Wrap"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="原因归档"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8"
                                               Text="{Binding CauseArchive}" TextWrapping="Wrap"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="关联流程步号"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8"
                                               Text="{Binding RelatedFlowStep, FallbackValue='--'}"/>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="累计次数 / 确认人"/>
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8">
                                        <Run Text="{Binding Count}"/>
                                        <Run Text=" 次  /  "/>
                                        <Run Text="{Binding AcknowledgedBy, FallbackValue='--'}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Text="备注（操作员可填）"/>
                                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                             BorderBrush="#CBD5E1" BorderThickness="1" Padding="6"/>
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextPlaceholder}" FontStyle="Italic"
                                           Text="（点击左侧表格中的一行查看详情）"
                                           Visibility="{Binding ., Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- 历史报警：用 AlarmHistoryView -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="12"
                    Visibility="{Binding IsAlarmHistoryPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="历史报警" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding AlarmHistoryView}"
                              SelectedItem="{Binding SelectedAlarmDetail, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}"
                              BorderBrush="{DynamicResource Brush.BorderSoft}" RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                              RowStyle="{StaticResource HighlightRowStyle}"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Height="600">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="确认人" Binding="{Binding AcknowledgedBy}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="跳流程"
                                                Command="{Binding DataContext.JumpToFlowByAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Source}"
                                                Background="Transparent" BorderBrush="#CBD5E1" Foreground="{DynamicResource Brush.TextSecondary}"
                                                FontSize="11" Padding="6,2" Height="22"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 日志：原样 -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="12"
                    Visibility="{Binding IsAlarmLogPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="日志" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False"
                              Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{DynamicResource Brush.BorderSoft}"
                              Height="620">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat='HH:mm:ss'}" Width="*"/>
                            <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/>
                            <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                            <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 报警统计：原有 + A5 频率直方图 -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="12"
                    Visibility="{Binding IsAlarmStatisticsPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="报警统计" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
                    <WrapPanel Margin="0,0,0,10">
                        <TextBlock Text="级别：" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="120" ItemsSource="{Binding AlarmLevelOptions}" SelectedItem="{Binding SelectedAlarmLevel}" Margin="0,0,12,0"/>
                        <TextBlock Text="时间：" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="120" ItemsSource="{Binding AlarmTimeRangeOptions}" SelectedItem="{Binding SelectedAlarmTimeRange}" Margin="0,0,12,0"/>
                        <CheckBox Content="只看重点报警" IsChecked="{Binding ShowOnlyFocusAlarms}" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                    </WrapPanel>

                    <!-- A5 报警发生频率（最近 24h，每小时一个 bar；按级别堆叠） -->
                    <Border Style="{StaticResource CardBorderStyle}" Background="#F8FAFC" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="📊 报警发生频率（最近 24h，按小时）" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                                <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Right">
                                    <Run Text="🟥 Alarm  "/>
                                    <Run Text="🟧 Error  " Foreground="#EA580C"/>
                                    <Run Text="🟨 Warning"/>
                                </TextBlock>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding AlarmFrequencyBars}" Height="120" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" Margin="3,0">
                                            <Grid Height="100" Width="14" VerticalAlignment="Bottom">
                                                <Rectangle Style="{StaticResource HistogramBarStyle}"
                                                           Height="{Binding NormalizedHeight, Converter={StaticResource NormalizedHeightConverter}, ConverterParameter=100}"
                                                           ToolTip="{Binding Total, StringFormat='共 {0} 条'}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Label}" FontSize="9" Foreground="{DynamicResource Brush.TextPlaceholder}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Background="#FEF2F2" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="重点处理建议" FontSize="16" FontWeight="Bold" Foreground="#B91C1C"/>
                            <TextBlock Text="{Binding FocusAlarmHint}" Foreground="#7F1D1D" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding EstimatedDowntimeMinutes, StringFormat=预计停机：{0:F1} min}" Foreground="#92400E" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding EstimatedProductionLoss, StringFormat=预计影响产量：{0}}" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding AlarmStatisticsView}" AutoGenerateColumns="False"
                              Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{DynamicResource Brush.BorderSoft}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                            <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/>
                            <DataGridTextColumn Header="累计次数" Binding="{Binding Count}" Width="*"/>
                            <DataGridTextColumn Header="处理建议" Binding="{Binding HandlingSuggestion}" Width="2*"/>
                            <DataGridTemplateColumn Header="联动" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="看流程" Command="{Binding DataContext.JumpToFlowByAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Source}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
