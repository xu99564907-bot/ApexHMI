<UserControl x:Class="ApexHMI.Views.Pages.AlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="16"
                    Margin="0,0,0,12">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentAlarmTitle}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="报警父页面已按左侧子导航切换显示。" Foreground="#94A3B8" Margin="0,8,0,0"/>
                    </StackPanel>
                    <WrapPanel DockPanel.Dock="Right">
                        <Button Content="确认全部报警" Command="{Binding AcknowledgeAllAlarmsCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="复位全部报警" Command="{Binding ResetAllAlarmsCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="14,8" Margin="0,0,8,0"/>
                        <Button Content="保存报警历史" Command="{Binding SaveAlarmHistoryCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8" Margin="0,0,8,0"/>
                        <Button Content="加载报警历史" Command="{Binding LoadAlarmHistoryCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="14,8"/>
                    </WrapPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmCurrentPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="当前报警" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding CurrentAlarms}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937" RowStyle="{StaticResource HighlightRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/>
                                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/>
                                <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="*"/>
                                <DataGridCheckBoxColumn Header="已确认" Binding="{Binding Acknowledged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmHistoryPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="历史报警" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding AlarmHistory}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937" RowStyle="{StaticResource HighlightRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/>
                                <DataGridTextColumn Header="确认人" Binding="{Binding AcknowledgedBy}" Width="*"/>
                                <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmLogPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="日志" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/>
                                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/>
                                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                                <DataGridTextColumn Header="内容" Binding="{Binding Message}" Width="2*"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Visibility="{Binding IsAlarmStatisticsPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="报警统计" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <WrapPanel Margin="0,0,0,10">
                            <TextBlock Text="级别：" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="120" ItemsSource="{Binding AlarmLevelOptions}" SelectedItem="{Binding SelectedAlarmLevel}" Margin="0,0,12,0"/>
                            <TextBlock Text="时间：" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Width="120" ItemsSource="{Binding AlarmTimeRangeOptions}" SelectedItem="{Binding SelectedAlarmTimeRange}" Margin="0,0,12,0"/>
                            <CheckBox Content="只看重点报警" IsChecked="{Binding ShowOnlyFocusAlarms}" Foreground="White" VerticalAlignment="Center"/>
                        </WrapPanel>
                        <Border Style="{StaticResource CardBorderStyle}" Background="#0B1324" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="重点处理建议" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding FocusAlarmHint}" Foreground="#FCA5A5" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding EstimatedDowntimeMinutes, StringFormat=预计停机：{0:F1} min}" Foreground="#FCD34D" Margin="0,8,0,0"/>
                                <TextBlock Text="{Binding EstimatedProductionLoss, StringFormat=预计影响产量：{0}}" Foreground="#FCA5A5" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <DataGrid ItemsSource="{Binding AlarmStatisticsView}" AutoGenerateColumns="False" Background="#111827" Foreground="White" BorderBrush="#1F2937">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="*"/>
                                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="*"/>
                                <DataGridTextColumn Header="累计次数" Binding="{Binding Count}" Width="*"/>
                                <DataGridTextColumn Header="处理建议" Binding="{Binding HandlingSuggestion}" Width="2*"/>
                                <DataGridTemplateColumn Header="联动" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="看流程" Command="{Binding DataContext.JumpToFlowByAlarmCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Source}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
