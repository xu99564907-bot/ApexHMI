<UserControl x:Class="ApexHMI.Views.Pages.ManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:ApexHMI.Models"
             xmlns:controls="clr-namespace:ApexHMI.Views.Controls"
             xmlns:conv="clr-namespace:ApexHMI.Converters">
    <UserControl.Resources>
        <conv:ViewportToCylinderItemWidthConverter x:Key="ViewportToCylinderItemWidthConverter"/>
        <Style x:Key="CylinderActionButtonBaseStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid x:Name="ManualRootGrid" Margin="12" DataContext="{Binding ShellViewModel}">
                        <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentManualTitle}" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                                <StackPanel>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,0,12" Visibility="{Binding IsManualCylinderPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <!-- MA5 气缸搜索框 -->
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="搜索：" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding ManualCylinderSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderBrush="#D7DFEA" Padding="6,4" Width="280" HorizontalAlignment="Left"
                                                     ToolTip="按气缸名称 / 命令地址 / 传感器地址 模糊匹配（如输入 CY3 只看 CY3 相关）"/>
                                        </DockPanel>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MinHeight="420" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                            <ItemsControl ItemsSource="{Binding ManualCylinderBlockCards}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel ItemWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource ViewportToCylinderItemWidthConverter}}"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type model:ManualCylinderBlockItem}">
                                                        <!-- MA2 报警态: ErrorActive=true 时整卡红边框 + 浅红底 -->
                                                        <Border Padding="8" Margin="0,0,10,10">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ErrorActive}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#DC2626"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                            <Setter Property="Background" Value="#FEF2F2"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <DockPanel LastChildFill="False">
                                                                    <StackPanel DockPanel.Dock="Left">
                                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                                                        <TextBlock Text="{Binding StatusText}" Foreground="#2563EB" Margin="0,2,0,0" FontSize="12" FontWeight="SemiBold"/>
                                                                    </StackPanel>
                                                                    <Button DockPanel.Dock="Right" Content="参数设定" Tag="{Binding}" Click="OpenCylinderSettingsButton_Click" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="8,4" FontSize="11" Focusable="False"/>
                                                                </DockPanel>
                                                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,6">
                                                                    <Button Command="{Binding DataContext.CylinderMoveToWorkCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="#0F172A" Padding="8,6" Margin="0,0,5,0" Focusable="False">
                                                                        <Button.Content>
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding WorkCommandLabel}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                                                                <TextBlock Text="{Binding WorkCommandAddress}" HorizontalAlignment="Center" Foreground="#64748B" FontSize="9" Margin="0,1,0,0"/>
                                                                            </StackPanel>
                                                                        </Button.Content>
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CylinderActionButtonBaseStyle}">
                                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding WorkCommandActive}" Value="True">
                                                                                        <Setter Property="Background" Value="#FFF0BF"/>
                                                                                        <Setter Property="BorderBrush" Value="#D6A12E"/>
                                                                                        <Setter Property="Foreground" Value="#5C3B00"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.CylinderMoveToHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="#0F172A" Padding="8,6" Margin="5,0,0,0" Focusable="False">
                                                                        <Button.Content>
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding HomeCommandLabel}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                                                                <TextBlock Text="{Binding HomeCommandAddress}" HorizontalAlignment="Center" Foreground="#64748B" FontSize="9" Margin="0,1,0,0"/>
                                                                            </StackPanel>
                                                                        </Button.Content>
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource CylinderActionButtonBaseStyle}">
                                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HomeCommandActive}" Value="True">
                                                                                        <Setter Property="Background" Value="#D9F4E1"/>
                                                                                        <Setter Property="BorderBrush" Value="#63A77A"/>
                                                                                        <Setter Property="Foreground" Value="#0B3B1F"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                </UniformGrid>
                                                                <StackPanel Grid.Row="2" Margin="0,0,0,4">
                                                                    <UniformGrid Columns="2" Margin="0,0,0,3">
                                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,0,5,0">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding WorkPositionLabel}" Foreground="#64748B" FontSize="10"/>
                                                                            <TextBlock Text="{Binding WorkSensorAddress}" Foreground="#94A3B8" FontSize="9" Margin="0,1,0,0"/>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                                <Ellipse Width="9" Height="9" Margin="0,2,5,0">
                                                                                    <Ellipse.Style>
                                                                                        <Style TargetType="Ellipse">
                                                                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding WorkActive}" Value="True">
                                                                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Ellipse.Style>
                                                                                </Ellipse>
                                                                                <TextBlock Text="{Binding WorkActive, StringFormat={}{0}}" Foreground="#0F172A" FontWeight="Bold" FontSize="12"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="6" Padding="6" Margin="5,0,0,0">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding HomePositionLabel}" Foreground="#64748B" FontSize="10"/>
                                                                            <TextBlock Text="{Binding HomeSensorAddress}" Foreground="#94A3B8" FontSize="9" Margin="0,1,0,0"/>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                                <Ellipse Width="9" Height="9" Margin="0,2,5,0">
                                                                                    <Ellipse.Style>
                                                                                        <Style TargetType="Ellipse">
                                                                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HomeActive}" Value="True">
                                                                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Ellipse.Style>
                                                                                </Ellipse>
                                                                                <TextBlock Text="{Binding HomeActive, StringFormat={}{0}}" Foreground="#0F172A" FontWeight="Bold" FontSize="12"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    </UniformGrid>
                                                                    <UniformGrid Columns="2">
                                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="6" Padding="6,0" Margin="0,0,5,0" Height="30">
                                                                        <DockPanel LastChildFill="False">
                                                                            <TextBlock Text="{Binding WorkInterlockLabel}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                                                                <Ellipse Width="9" Height="9" Margin="0,1,0,0">
                                                                                    <Ellipse.Style>
                                                                                        <Style TargetType="Ellipse">
                                                                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding WorkInterlockActive}" Value="True">
                                                                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Ellipse.Style>
                                                                                </Ellipse>
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                    </Border>
                                                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="6" Padding="6,0" Margin="5,0,0,0" Height="30">
                                                                        <DockPanel LastChildFill="False">
                                                                            <TextBlock Text="{Binding HomeInterlockLabel}" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>
                                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                                                                <Ellipse Width="9" Height="9" Margin="0,1,0,0">
                                                                                    <Ellipse.Style>
                                                                                        <Style TargetType="Ellipse">
                                                                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding HomeInterlockActive}" Value="True">
                                                                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Ellipse.Style>
                                                                                </Ellipse>
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                    </Border>
                                                                    </UniformGrid>
                                                                </StackPanel>
                                                                <Border Grid.Row="3" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="6">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding CurrentStateText}" Foreground="#1D4ED8" FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap"/>
                                                                        <TextBlock Text="{Binding InterlockHint}" Foreground="#1D4ED8" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                        <!-- MA10 最近一条操作（点击工作 / 原点 后由 SetCylinderPositionAsync 写入）-->
                                                                        <TextBlock Text="{Binding LastOperationText}" Foreground="#0F766E" FontSize="10" Margin="0,4,0,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding LastOperationText}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                                <!-- ========== 轴操作画面 ========== -->
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,0,12" Visibility="{Binding IsManualAxisPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <!-- MA9 轴搜索框 -->
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="搜索：" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding ManualAxisSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderBrush="#D7DFEA" Padding="6,4" Width="280" HorizontalAlignment="Left"
                                                     ToolTip="按轴名称模糊匹配"/>
                                        </DockPanel>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MinHeight="420" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                            <ItemsControl ItemsSource="{Binding ManualAxisBlockCards}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel ItemWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource ViewportToCylinderItemWidthConverter}, ConverterParameter=Axis}"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type model:ManualAxisBlockItem}">
                                                        <Border Background="#FFFFFF" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="16,18" Margin="0,0,16,16">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/><!-- Row0: 标题行 (图标+名称+Badge+参数设定) -->
                                                                    <RowDefinition Height="Auto"/><!-- Row1: 实时数值 (3列卡片) -->
                                                                    <RowDefinition Height="Auto"/><!-- Row2: 设定参数输入 -->
                                                                    <RowDefinition Height="Auto"/><!-- Row3: 操作按钮 -->
                                                                    <RowDefinition Height="Auto"/><!-- Row4: 状态标签 Chip -->
                                                                    <RowDefinition Height="Auto"/><!-- Row5: 信息栏 -->
                                                                    <RowDefinition Height="Auto"/><!-- Row6: 示教区域 -->
                                                                </Grid.RowDefinitions>

                                                                <!-- ═══ Row 0: 标题行 ═══ -->
                                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- 轴图标 -->
                                                                    <Border Grid.Column="0" Width="34" Height="34" CornerRadius="9" Margin="0,0,10,0">
                                                                        <Border.Background>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                <GradientStop Color="#3B82F6" Offset="0"/>
                                                                                <GradientStop Color="#2563EB" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Border.Background>
                                                                        <TextBlock Text="Axis" FontSize="14" FontWeight="ExtraBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <!-- 轴名称 -->
                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="15" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                                                                    <!-- 状态 Badge -->
                                                                    <Border Grid.Column="2" CornerRadius="99" Padding="12,3" Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ServoEnabledFeedback}" Value="True">
                                                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding MotorRunning}" Value="True">
                                                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding MotorError}" Value="True">
                                                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#6B7280"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding ServoEnabledFeedback}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#6987B0"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding MotorRunning}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#2563EB"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding MotorError}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <!-- 参数设定按钮 -->
                                                                    <Button Grid.Column="3" Content="参数设定" Focusable="False" Click="OpenAxisSettingsButton_Click"
                                                                            Background="#F1F5F9" Foreground="#475569" BorderBrush="#E2E8F0" BorderThickness="1"
                                                                            Padding="12,5" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                </Grid>

                                                                <!-- ═══ Row 1: 实时数值区 (3列卡片) ═══ -->
                                                                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
                                                                    <!-- 当前位置 -->
                                                                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#F1F5F9" BorderThickness="1" Padding="10,12" Margin="0,0,4,0">
                                                                        <StackPanel>
                                                                            <TextBlock Text="当前位置" FontSize="11" Foreground="#94A3B8" FontWeight="Medium"/>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                                <TextBlock Text="{Binding ActualPositionDisplay}" FontSize="20" FontWeight="ExtraBold" Foreground="#0F172A" FontFamily="Consolas"/>
                                                                                <TextBlock Text="mm" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- 当前速度 -->
                                                                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#F1F5F9" BorderThickness="1" Padding="10,12" Margin="4,0,4,0">
                                                                        <StackPanel>
                                                                            <TextBlock Text="当前速度" FontSize="11" Foreground="#94A3B8" FontWeight="Medium"/>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                                <TextBlock Text="{Binding ActualVelocityDisplay}" FontSize="20" FontWeight="ExtraBold" Foreground="#0F172A" FontFamily="Consolas"/>
                                                                                <TextBlock Text="mm/s" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- 当前力矩 -->
                                                                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#F1F5F9" BorderThickness="1" Padding="10,12" Margin="4,0,0,0">
                                                                        <StackPanel>
                                                                            <TextBlock Text="当前力矩" FontSize="11" Foreground="#94A3B8" FontWeight="Medium"/>
                                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                                <TextBlock Text="{Binding ActualTorqueDisplay}" FontSize="20" FontWeight="ExtraBold" Foreground="#0F172A" FontFamily="Consolas"/>
                                                                                <TextBlock Text="%" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </UniformGrid>

                                                                <!-- ═══ Row 2: 设定参数输入 (2列) ═══ -->
                                                                <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,12">
                                                                    <StackPanel Margin="0,0,4,0">
                                                                        <TextBlock Text="设定位置 (mm)" FontSize="11" Foreground="#64748B" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                        <TextBox Text="{Binding SetPositionInput, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#0F172A"
                                                                                 Padding="7,10" BorderBrush="#E2E8F0" BorderThickness="1.5"/>
                                                                    </StackPanel>
                                                                    <StackPanel Margin="4,0,0,0">
                                                                        <TextBlock Text="设定速度 (mm/s)" FontSize="11" Foreground="#64748B" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                        <TextBox Text="{Binding SetVelocityInput, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontFamily="Consolas" FontWeight="SemiBold" Foreground="#0F172A"
                                                                                 Padding="7,10" BorderBrush="#E2E8F0" BorderThickness="1.5"/>
                                                                    </StackPanel>
                                                                </UniformGrid>

                                                                <!-- ═══ Row 3: 操作按钮 ═══ -->
                                                                <Grid Grid.Row="3" Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>    <!-- 启动定位 -->
                                                                        <ColumnDefinition Width="0.8*"/> <!-- 点动前进 -->
                                                                        <ColumnDefinition Width="0.8*"/> <!-- 点动后退 -->
                                                                        <ColumnDefinition Width="*"/>    <!-- 参考点 -->
                                                                        <ColumnDefinition Width="*"/>    <!-- 停止 -->
                                                                        <ColumnDefinition Width="*"/>    <!-- 使能 -->
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- 启动定位 (蓝) -->
                                                                    <Button Grid.Column="0" Content="启动定位" Padding="9,4" Margin="0,0,4,0" Focusable="False" FontSize="12" FontWeight="Bold"
                                                                            Command="{Binding DataContext.AxisStartPositioningCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                            Background="#3B82F6" Foreground="White" BorderBrush="#3B82F6"/>
                                                                    <!-- 点动前进 (灰·按钮组左) -->
                                                                    <Button Grid.Column="1" Content="点动前进" Padding="9,4" Margin="3,0,0,0" Focusable="False" FontSize="12" FontWeight="Bold"
                                                                            Command="{Binding DataContext.AxisJogForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                            Background="#F1F5F9" Foreground="#334155" BorderBrush="#E2E8F0"/>
                                                                    <!-- 点动后退 (灰·按钮组右) -->
                                                                    <Button Grid.Column="2" Content="点动后退" Padding="9,4" Margin="0,0,4,0" Focusable="False" FontSize="12" FontWeight="Bold"
                                                                            Command="{Binding DataContext.AxisJogBackwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                            Background="#F1F5F9" Foreground="#334155" BorderBrush="#E2E8F0"/>
                                                                    <!-- 参考点 (橙) -->
                                                                    <Button Grid.Column="3" Content="参考点" Padding="9,4" Margin="3,0,4,0" Focusable="False" FontSize="12" FontWeight="Bold"
                                                                            Command="{Binding DataContext.AxisSetReferenceCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                            Background="#F59E0B" Foreground="White" BorderBrush="#F59E0B"/>
                                                                    <!-- 停止 (红) -->
                                                                    <Button Grid.Column="4" Content="停 止" Padding="9,4" Margin="0,0,4,0" Focusable="False" FontSize="12" FontWeight="Bold"
                                                                            Command="{Binding DataContext.AxisStopCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                            Background="#EF4444" Foreground="White" BorderBrush="#EF4444"/>
                                                                    <!-- 使能 (绿) -->
                                                                    <Button Grid.Column="5" Content="使 能" Padding="9,4" Margin="0,0,0,0" Focusable="False" FontSize="12" FontWeight="Bold"
                                                                            Command="{Binding DataContext.AxisToggleEnableCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                            Background="#10B981" Foreground="White" BorderBrush="#10B981"/>
                                                                </Grid>

                                                                <!-- ═══ Row 4: 状态标签 Chip ═══ -->
                                                                <WrapPanel Grid.Row="4" Margin="0,0,0,12">
                                                                    <!-- ── 运动状态组 ── -->
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding MotorRunning}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding MotorRunning}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="运行中" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding MotorRunning}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding MotorActionDone}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding MotorActionDone}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="动作结束" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding MotorActionDone}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding ServoEnabledFeedback}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding ServoEnabledFeedback}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="伺服使能" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding ServoEnabledFeedback}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding HomingComplete}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding HomingComplete}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="原点完成" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding HomingComplete}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- 分隔线 -->
                                                                    <Border Width="1" Height="18" Background="#E2E8F0" Margin="2,0,7,5" VerticalAlignment="Center"/>
                                                                    <!-- ── 设备信号组 (新增) ── -->
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding PositiveLimitActive}" Value="True"><Setter Property="Background" Value="#FEF2F2"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding PositiveLimitActive}" Value="True"><Setter Property="Fill" Value="#EF4444"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="正极限" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding PositiveLimitActive}" Value="True"><Setter Property="Foreground" Value="#991B1B"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding NegativeLimitActive}" Value="True"><Setter Property="Background" Value="#FEF2F2"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding NegativeLimitActive}" Value="True"><Setter Property="Fill" Value="#EF4444"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="负极限" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding NegativeLimitActive}" Value="True"><Setter Property="Foreground" Value="#991B1B"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding HomeSignalActive}" Value="True"><Setter Property="Background" Value="#EFF6FF"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding HomeSignalActive}" Value="True"><Setter Property="Fill" Value="#3B82F6"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="原点" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding HomeSignalActive}" Value="True"><Setter Property="Foreground" Value="#1E40AF"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding BrakeActive}" Value="True"><Setter Property="Background" Value="#FFFBEB"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding BrakeActive}" Value="True"><Setter Property="Fill" Value="#F59E0B"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="刹车" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding BrakeActive}" Value="True"><Setter Property="Foreground" Value="#92400E"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- 分隔线 -->
                                                                    <Border Width="1" Height="18" Background="#E2E8F0" Margin="2,0,7,5" VerticalAlignment="Center"/>
                                                                    <!-- ── 互锁条件组 ── -->
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding HomeInterlock}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding HomeInterlock}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="回原互锁" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding HomeInterlock}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,5,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding JogInterlock}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding JogInterlock}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="点动互锁" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding JogInterlock}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <Border CornerRadius="99" Padding="10,3" Margin="0,0,0,5">
                                                                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#F3F4F6"/><Style.Triggers><DataTrigger Binding="{Binding PositioningInterlock}" Value="True"><Setter Property="Background" Value="#ECFDF5"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#D1D5DB"/><Style.Triggers><DataTrigger Binding="{Binding PositioningInterlock}" Value="True"><Setter Property="Fill" Value="#10B981"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse>
                                                                            <TextBlock Text="定位互锁" FontSize="11" FontWeight="SemiBold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9CA3AF"/><Style.Triggers><DataTrigger Binding="{Binding PositioningInterlock}" Value="True"><Setter Property="Foreground" Value="#065F46"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </WrapPanel>

                                                                <!-- ═══ Row 5: 信息栏 ═══ -->
                                                                <Border Grid.Row="5" Background="#F8FAFC" CornerRadius="8" BorderBrush="#F1F5F9" BorderThickness="1" Padding="7,12" Margin="0,0,0,10">
                                                                    <WrapPanel>
                                                                        <TextBlock Text="状态" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="{Binding StateCodeText}" FontSize="13" FontWeight="Bold" Foreground="#0F172A" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <Border Width="1" Height="16" Background="#E2E8F0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="停止位置" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="{Binding StopPositionDisplay}" FontSize="13" FontWeight="Bold" Foreground="#0F172A" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <Border Width="1" Height="16" Background="#E2E8F0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="报警" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="{Binding ErrorIdText}" FontSize="13" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding MotorError}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </WrapPanel>
                                                                </Border>

                                                                <!-- ═══ Row 6: 示教区域 (蓝色调) ═══ -->
                                                                <Border Grid.Row="6" Background="#EFF6FF" CornerRadius="10" BorderBrush="#BFDBFE" BorderThickness="1.5" Padding="11,14">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- 示教使能 -->
                                                                        <Button Grid.Column="0" Content="示教使能" Focusable="False" Padding="6,14" Margin="0,0,8,0"
                                                                                Command="{Binding DataContext.AxisTeachEnableCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                                Background="#DBEAFE" Foreground="#1E40AF" BorderBrush="#93C5FD" BorderThickness="1" FontSize="12" FontWeight="Bold"/>
                                                                        <!-- 位置号 -->
                                                                        <TextBlock Grid.Column="1" Text="位置标签" FontSize="11" Foreground="#1E40AF" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,6,0"/>
                                                                        <ComboBox Grid.Column="2" ItemsSource="{Binding PointOptions}" DisplayMemberPath="Label" SelectedValuePath="Index" SelectedValue="{Binding SelectedPointIndex}"
                                                                                  IsEditable="False" FontSize="12" Padding="20,8" MinWidth="70" Margin="10,0,8,0" VerticalAlignment="Center"/>
                                                                        <!-- 写入位置 -->
                                                                        <Button Grid.Column="3" Content="写入位置" Focusable="False" Padding="20,14" Margin="10,0,6,0"
                                                                                Command="{Binding DataContext.AxisWritePositionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                                Background="#DBEAFE" Foreground="#1E40AF" BorderBrush="#93C5FD" BorderThickness="1" FontSize="12" FontWeight="Bold"/>
                                                                        <!-- 位置定位 -->
                                                                        <Button Grid.Column="4" Content="位置定位" Focusable="False" Padding="20,14" Margin="10,0,8,0"
                                                                                Command="{Binding DataContext.AxisMoveToPointCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"
                                                                                Background="#DBEAFE" Foreground="#1E40AF" BorderBrush="#93C5FD" BorderThickness="1" FontSize="12" FontWeight="Bold"/>
                                                                        <!-- 生效位置 -->
                                                                        <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                            <TextBlock Text="生效位置:" FontSize="12" Foreground="#1E40AF" VerticalAlignment="Center" Margin="0,0,30,0"/>
                                                                            <TextBlock Text="{Binding HmiPositionDisplay}" FontSize="12" FontWeight="Bold" Foreground="#0F172A" FontFamily="Consolas" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,8,8" Visibility="{Binding IsManualMotorPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="电机单元" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/><TextBlock Text="--" Foreground="#64748B" Margin="0,8,0,12"/><WrapPanel><Button Content="电机 启停" Command="{Binding ToggleDeviceCommand}" CommandParameter="Y_RunLamp" Style="{StaticResource PrimaryButtonStyle}"/><Button Content="故障复位" Command="{Binding ResetMotorFaultCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,8"/></WrapPanel></StackPanel></Border>
                                    <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="8,0,0,8" Visibility="{Binding IsManualRobotPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="机械手单元" FontSize="16" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                                            <controls:RobotControl DataContext="{Binding RobotControlViewModel}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Visibility="{Binding IsManualStopperPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"><StackPanel><TextBlock Text="挡停单元" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/><WrapPanel Margin="0,8,0,0"><Button Content="挡停 升降" Command="{Binding ToggleDeviceCommand}" CommandParameter="Stopper_Up" Style="{StaticResource PrimaryButtonStyle}"/></WrapPanel></StackPanel></Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </ScrollViewer>
</UserControl>
