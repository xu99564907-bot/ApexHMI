<UserControl x:Class="ApexHMI.Views.Pages.DesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:ApexHMI.Models"
             xmlns:behavior="clr-namespace:ApexHMI.Behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid Margin="12" DataContext="{Binding ShellViewModel}" Visibility="{Binding IsDesignMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Row 0: 设计器标题栏 -->
                        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                            <DockPanel>
                                <TextBlock Text="{Binding CurrentDesignerTitle}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock DockPanel.Dock="Right" Text="仅设计态可用" Foreground="#64748B" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <Grid Grid.Row="1" Visibility="{Binding IsDesignerCanvasPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="*"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="页面与工具箱" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/><TextBlock Text="工程名称" Foreground="#475569"/><TextBox Text="{Binding DesignerProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="当前页面" Foreground="#475569"/><ComboBox ItemsSource="{Binding DesignerPages}" SelectedItem="{Binding SelectedDesignerPage}" Margin="0,4,0,8"/><WrapPanel Margin="0,0,0,8"><Button Content="新建页面" Command="{Binding AddNewPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/><Button Content="删除页面" Command="{Binding RemoveCurrentPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/><Button Content="加载工程" Command="{Binding LoadDesignerProjectCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/></WrapPanel><TextBlock Text="运行页模板" Foreground="#475569"/><ComboBox ItemsSource="{Binding RuntimeTemplates}" SelectedItem="{Binding SelectedRuntimeTemplate}" Margin="0,4,0,8"/><Button Content="应用模板" Command="{Binding ApplyRuntimeTemplateCommand}" CommandParameter="{Binding SelectedRuntimeTemplate}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,0,8"/><TextBlock Text="页面名称" Foreground="#475569"/><TextBox Text="{Binding DesignerPageName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/><TextBlock Text="画布尺寸" Foreground="#475569"/><UniformGrid Columns="2" Margin="0,4,0,8"><TextBox Text="{Binding DesignerCanvasWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/><TextBox Text="{Binding DesignerCanvasHeight, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,0,0"/></UniformGrid><TextBlock Text="工具箱" Foreground="#475569" Margin="0,0,0,8"/></StackPanel><ItemsControl ItemsSource="{Binding ToolboxItems}"><ItemsControl.ItemTemplate><DataTemplate><Button Content="{Binding}" Command="{Binding DataContext.AddDesignerElementCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,0,8" Padding="10" Background="#F8FAFC" Foreground="#334155" BorderBrush="#D7DFEA" PreviewMouseMove="ToolboxItem_PreviewMouseMove"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></DockPanel></Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,10"><TextBlock Text="设计画布" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/><TextBlock DockPanel.Dock="Right" Text="仅设计态可编辑" Foreground="#64748B"/></DockPanel><ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView"><Canvas x:Name="DesignerCanvas" Width="{Binding DesignerCanvasWidth}" Height="{Binding DesignerCanvasHeight}" Background="#0F172A" ClipToBounds="True" AllowDrop="True" DragOver="DesignerCanvas_DragOver" Drop="DesignerCanvas_Drop"><ItemsControl ItemsSource="{Binding DesignerElements}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemContainerStyle><Style TargetType="ContentPresenter"><Setter Property="Canvas.Left" Value="{Binding Left}"/><Setter Property="Canvas.Top" Value="{Binding Top}"/></Style></ItemsControl.ItemContainerStyle><ItemsControl.Resources><DataTemplate DataType="{x:Type model:DesignerElement}"><Border Width="{Binding Width}" Height="{Binding Height}" Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}" BorderBrush="{Binding BorderBrush, Converter={StaticResource StringToBrushConverter}}" BorderThickness="2" CornerRadius="8" behavior:DragCanvasBehavior.EnableDrag="True"><Button Command="{Binding DataContext.SelectDesignerElementCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0"><Grid><StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="{Binding ElementType}" FontSize="10" Foreground="#E2E8F0" HorizontalAlignment="Center"/><TextBlock Text="{Binding Text}" FontSize="{Binding FontSize}" FontWeight="SemiBold" Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}" HorizontalAlignment="Center" TextWrapping="Wrap"/></StackPanel></Grid></Button></Border></DataTemplate></ItemsControl.Resources></ItemsControl></Canvas></ScrollViewer></Grid></Border>
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                    <StackPanel>
                                        <TextBlock Text="属性编辑器" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,12"/>
                                        <WrapPanel Margin="0,0,0,10">
                                            <Button Content="删除" Command="{Binding RemoveSelectedDesignerElementCommand}" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="复制" Command="{Binding CopySelectedDesignerElementCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="粘贴" Command="{Binding PasteDesignerElementCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                        </WrapPanel>
                                        <TextBlock Text="名称" Foreground="#475569"/>
                                        <TextBox Text="{Binding SelectedDesignerElement.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                                        <TextBlock Text="类型" Foreground="#475569"/>
                                        <TextBox Text="{Binding SelectedDesignerElement.ElementType, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                                        <TextBlock Text="显示文本" Foreground="#475569"/>
                                        <TextBox Text="{Binding SelectedDesignerElement.Text, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                                        <TextBlock Text="变量绑定" Foreground="#475569"/>
                                        <ComboBox ItemsSource="{Binding Tags}" DisplayMemberPath="Name" SelectedValuePath="Name" SelectedValue="{Binding SelectedDesignerElement.TagBinding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                                        <TextBlock Text="动作方式" Foreground="#475569" Visibility="{Binding IsSelectedDesignerElementButtonLike, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <ComboBox ItemsSource="{Binding DesignerActionOptions}" SelectedItem="{Binding SelectedDesignerElement.CommandBinding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Visibility="{Binding IsSelectedDesignerElementButtonLike, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="跳转目标" Foreground="#475569" Visibility="{Binding IsSelectedDesignerElementNavigationAction, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <ComboBox ItemsSource="{Binding DesignerNavigationTargetOptions}" SelectedItem="{Binding SelectedDesignerElement.NavigationTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" Visibility="{Binding IsSelectedDesignerElementNavigationAction, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Foreground="#64748B" TextWrapping="Wrap" Text="按钮类控件现在可直接选择绑定变量和动作方式；页面跳转动作可单独设置目标页面。" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Visibility="{Binding IsDesignerIoProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,10,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                    <StackPanel>
                                        <TextBlock Text="手动程序生成" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding IoGenerationHeadline}" Foreground="#2563EB" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding IoImportSummary}" Foreground="#0F172A" Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding IoGenerationCountSummary}" Foreground="#64748B" Margin="0,4,0,12"/>

                                        <TextBlock Text="PLC 模板" Foreground="#475569"/>
                                        <ComboBox ItemsSource="{Binding IoPlcTemplateOptions}" SelectedItem="{Binding SelectedIoPlcTemplate}" Margin="0,4,0,10"/>
                                        <TextBlock Text="工位号 / OP 编号" Foreground="#475569"/>
                                        <TextBox Text="{Binding IoOperationNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>
                                        <TextBlock Text="保存间隔 / 分钟" Foreground="#475569"/>
                                        <Grid Margin="0,4,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding IoSaveIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="小于 5 分钟时，重复保存会写入同一文件并追加履历" Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                                        </Grid>

                                        <WrapPanel Margin="0,0,0,12">
                                            <Button Content="导入 IO 表" Command="{Binding ImportIoTableCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="保存 IO 表" Command="{Binding SaveIoTableToSourceCommand}" IsEnabled="{Binding CanSaveIoTable}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="生成程序" Command="{Binding GenerateIoProgramsCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="打开目录" Command="{Binding OpenGeneratedIoFolderCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="清空" Command="{Binding ClearIoTableCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="10,6" Margin="0,0,6,6"/>
                                        </WrapPanel>

                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left" Text="Git 代码拉取" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding GitPullStatus}" Foreground="#2563EB" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </DockPanel>
                                                <TextBlock Text="从远程 Git 仓库拉取最新代码到指定目录，支持首次克隆与后续增量拉取。" Foreground="#64748B" Margin="0,4,0,8" TextWrapping="Wrap"/>

                                                <TextBlock Text="仓库地址 (Repository URL)" Foreground="#475569"/>
                                                <TextBox Text="{Binding GitRepositoryUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" ToolTip="例如 https://github.com/your/repo.git"/>

                                                <TextBlock Text="分支 (可选，留空使用默认分支)" Foreground="#475569"/>
                                                <TextBox Text="{Binding GitBranch, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>

                                                <TextBlock Text="保存目录" Foreground="#475569"/>
                                                <Grid Margin="0,4,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Text="{Binding GitTargetFolder, UpdateSourceTrigger=PropertyChanged}" ToolTip="本地目录。首次拉取时若目录非空且非 Git 仓库将报错。"/>
                                                    <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseGitTargetFolderCommand}" Margin="6,0,0,0" Padding="10,4" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1"/>
                                                </Grid>

                                                <TextBlock Text="项目文件夹 / 分支名" Foreground="#475569"/>
                                                <TextBox Text="{Binding GitProjectFolderName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4" ToolTip="留空则直接拉到保存目录。若填写，将作为保存目录下的子文件夹名（总文件夹），并在拉取后自动 checkout 到同名本地分支（不存在则基于源分支创建）。"/>
                                                <TextBlock Text="例如填写 OP80，将克隆到 保存目录/OP80，并自动切换到本地分支 OP80。" Foreground="#94A3B8" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                                <Expander Header="认证 (可选 · 私有仓库)" Foreground="#475569" Margin="0,0,0,8">
                                                    <StackPanel Margin="0,6,0,0">
                                                        <TextBlock Text="用户名" Foreground="#475569"/>
                                                        <TextBox Text="{Binding GitUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                                                        <TextBlock Text="访问令牌 / Personal Access Token" Foreground="#475569"/>
                                                        <TextBox Text="{Binding GitAccessToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                                                        <TextBlock Text="令牌将写入本地配置文件，请妥善保管。" Foreground="#94A3B8" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Expander>

                                                <CheckBox Content="生成程序后自动追加到 Git 目录对应 .st 文件" IsChecked="{Binding IsSyncGeneratedToGitEnabled}" Margin="0,0,0,4" Foreground="#0F172A" ToolTip="按映射规则把 DBXX_IO → 2.Main/Main_IO.ST；DI/DO_ACT_Comment → OPXX_DI/DO_Mirror/ACT_Comment.st；ACT_* → OPXX_DriveControl/ACT_*.st"/>

                                                <CheckBox Content="拉取 .project 工程文件" IsChecked="{Binding IsIncludeProjectFilesOnPullEnabled}" Margin="0,0,0,4" Foreground="#0F172A" ToolTip="默认不勾选：拉取代码时不会把远端 *.project 检出到本地，避免覆盖/锁定现场工程文件。勾选后会完整检出 .project 文件。"/>

                                                <CheckBox Content="强制覆盖本地 (reset --hard origin/branch + clean -fd)" IsChecked="{Binding IsForceResetLocalEnabled}" Margin="0,0,0,4" Foreground="#B91C1C" ToolTip="勾选后拉取时会丢弃本地所有未提交改动（含生成追加内容），把工作区重置成远端分支的状态。"/>

                                                <CheckBox Content="拉取后把新分支推送到远端 (git push -u origin branch)" IsChecked="{Binding IsPushProjectBranchToRemoteEnabled}" Margin="0,0,0,4" Foreground="#0F172A" ToolTip="勾选后若本地项目分支还没有上游，会执行 git push -u origin 分支名 把分支上传到远端。需要仓库写权限。"/>

                                                <CheckBox Content="生成程序后自动 commit + push 到远端" IsChecked="{Binding IsCommitAndPushAfterGenerateEnabled}" Margin="0,0,0,4" Foreground="#0F172A" ToolTip="勾选后每次点击&quot;生成程序&quot;结束，如果产生了追加内容，会自动 git add -A → commit → push 到远端当前分支。没有实际变更时不会产生空 commit。"/>

                                                <TextBlock Text="自动提交消息 (可选，支持 {time} / {op})" Foreground="#475569" Visibility="{Binding IsCommitAndPushAfterGenerateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBox Text="{Binding GitAutoCommitMessageTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Visibility="{Binding IsCommitAndPushAfterGenerateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="留空使用默认模板 &quot;HMI 生成程序 ({op}) @ {time}&quot;。{op} 替换为当前工位号，{time} 替换为提交时间戳。"/>


                                                <WrapPanel>
                                                    <Button Content="拉取代码" Command="{Binding PullGitRepositoryCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"/>
                                                    <Button Content="打开目录" Command="{Binding OpenGitTargetFolderCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                                    <TextBlock Text="拉取中..." Foreground="#0F766E" VerticalAlignment="Center" Margin="4,0,0,0" Visibility="{Binding IsGitPullRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </WrapPanel>

                                                <TextBlock Text="执行日志" Foreground="#475569" Margin="0,6,0,4"/>
                                                <TextBox Text="{Binding GitPullLog, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="120" FontFamily="Consolas" Background="#FFFFFF" BorderBrush="#D7DFEA" Foreground="#0F172A"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="400"/>
                                    <RowDefinition Height="300"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,10" MouseLeftButtonDown="IoPreviewHeader_MouseLeftButtonDown" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="IO 表预览" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Width="30" Height="30" Margin="8,0,0,0" Padding="0" HorizontalAlignment="Right" Command="{Binding SaveIoTableToSourceCommand}" IsEnabled="{Binding CanSaveIoTable}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" ToolTip="保存 IO 表 (Ctrl+S)">
                                                <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                        <DataGrid x:Name="IoPreviewDataGrid" Grid.Row="1" ItemsSource="{Binding IoTableRows}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserSortColumns="False" HeadersVisibility="Column" Background="#FFFFFF" Foreground="#0F172A" BorderBrush="#D7DFEA" RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC" PreviewMouseWheel="IoPreviewDataGrid_PreviewMouseWheel" ScrollViewer.CanContentScroll="True" MaxHeight="340" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="输入地址" Binding="{Binding InputAddress}" Width="*"/>
                                                <DataGridTextColumn Header="输入注释" Binding="{Binding InputComment}" Width="*"/>
                                                <DataGridTextColumn Header="输出地址" Binding="{Binding OutputAddress}" Width="*"/>
                                                <DataGridTextColumn Header="输出注释" Binding="{Binding OutputComment}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,10" MouseLeftButtonDown="IoProgramPreviewHeader_MouseLeftButtonDown" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="程序预览" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="3" Width="220" ItemsSource="{Binding GeneratedIoPrograms}" SelectedItem="{Binding SelectedGeneratedIoProgram}" DisplayMemberPath="DisplayName" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                <Button Content="复制当前文件" Click="CopyCurrentIoProgramButton_Click" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,8,0"/>
                                                <Button Content="打开当前文件" Command="{Binding OpenGeneratedIoFileCommand}" CommandParameter="{Binding SelectedGeneratedIoProgram}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="8,4"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBox x:Name="IoProgramPreviewTextBox" Grid.Row="1" Text="{Binding SelectedGeneratedIoProgramContent, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F8FAFC" BorderBrush="#D7DFEA" Foreground="#0F172A" PreviewMouseWheel="CodePreviewTextBox_PreviewMouseWheel"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1" Visibility="{Binding IsDesignerAutoProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="440"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,10,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                    <StackPanel>
                                        <TextBlock Text="自动程序生成" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding AutoProgramHeadline}" Foreground="#2563EB" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding AutoProgramSummary}" Foreground="#64748B" Margin="0,6,0,12" TextWrapping="Wrap"/>

                                        <TextBlock Text="流程名称" Foreground="#475569"/>
                                        <TextBox Text="{Binding AutoProgramName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                        <TextBlock Text="工位 / Station" Foreground="#475569"/>
                                        <TextBox Text="{Binding AutoProgramStation, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                                        <WrapPanel Margin="0,0,0,12">
                                            <Button Content="新增步骤" Command="{Binding AddAutoProgramStepCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="生成程序" Command="{Binding GenerateAutoProgramsCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="打开目录" Command="{Binding OpenGeneratedAutoFolderCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="重置流程" Command="{Binding ResetAutoProgramFlowCommand}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="10,6" Margin="0,0,6,6"/>
                                        </WrapPanel>

                                        <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1" CornerRadius="8" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="流程步骤配置" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10"/>
                                                <DataGrid ItemsSource="{Binding AutoProgramFlowNodes}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False" HeadersVisibility="Column" Background="#FFFFFF" Foreground="#0F172A" BorderBrush="#D7DFEA" RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC" MinHeight="340">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="步序" Binding="{Binding StepNo}" Width="70"/>
                                                        <DataGridTextColumn Header="步骤名称" Binding="{Binding Title}" Width="120"/>
                                                        <DataGridTextColumn Header="动作说明" Binding="{Binding Action}" Width="*"/>
                                                        <DataGridTextColumn Header="流向" Binding="{Binding NextStep}" Width="80"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="300"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10" MinHeight="260">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="流程图绘制" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                            <ItemsControl ItemsSource="{Binding AutoProgramFlowNodes}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,10" HorizontalAlignment="Center">
                                                            <Border Width="520" Background="{Binding Fill}" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Padding="14">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding StepCode}" FontWeight="Bold" Foreground="#1E3A8A"/>
                                                                        <TextBlock Text="{Binding NextStep, StringFormat=流向 {0}}" Foreground="#64748B" Margin="0,4,0,0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Margin="12,0">
                                                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                                        <TextBlock Text="{Binding Action}" Foreground="#475569" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                    <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="16" Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding NextStep}" Foreground="#2563EB" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                            <materialDesign:PackIcon Kind="ArrowDownThin" Width="26" Height="26" Foreground="#94A3B8" Margin="0,6,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12" Height="300" MinHeight="300">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,10" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="程序预览" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="2" Width="220" ItemsSource="{Binding GeneratedAutoPrograms}" SelectedItem="{Binding SelectedGeneratedAutoProgram}" DisplayMemberPath="DisplayName" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                <Button Content="复制当前文件" Click="CopyCurrentAutoProgramButton_Click" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,8,0"/>
                                                <Button Content="打开当前文件" Command="{Binding OpenGeneratedIoFileCommand}" CommandParameter="{Binding SelectedGeneratedAutoProgram}" Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1" Padding="8,4"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBox x:Name="AutoProgramPreviewTextBox" Grid.Row="1" Text="{Binding SelectedGeneratedAutoProgramContent, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F8FAFC" BorderBrush="#D7DFEA" Foreground="#0F172A" PreviewMouseWheel="CodePreviewTextBox_PreviewMouseWheel"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                    </ScrollViewer>
</UserControl>
