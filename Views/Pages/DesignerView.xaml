<UserControl x:Class="ApexHMI.Views.Pages.DesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:ApexHMI.Models"
             xmlns:models="clr-namespace:ApexHMI.Models.Sfc"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid Margin="12" DataContext="{Binding ShellViewModel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Visibility="{Binding IsDesignerIoProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,10,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                    <StackPanel>
                                        <TextBlock Text="手动程序生成" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                                        <TextBlock Text="{Binding IoGenerationHeadline}" Foreground="#2563EB" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding IoImportSummary}" Foreground="{DynamicResource Brush.Text}" Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding IoGenerationCountSummary}" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,12"/>

                                        <TextBlock Text="PLC 模板" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                        <ComboBox ItemsSource="{Binding IoPlcTemplateOptions}" SelectedItem="{Binding SelectedIoPlcTemplate}" Margin="0,4,0,10"/>
                                        <TextBlock Text="工位号 / OP 编号" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                        <TextBox Text="{Binding IoOperationNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>
                                        <TextBlock Text="保存间隔 / 分钟" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                        <Grid Margin="0,4,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding IoSaveIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="小于 5 分钟时，重复保存会写入同一文件并追加履历" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap"/>
                                        </Grid>

                                        <WrapPanel Margin="0,0,0,4">
                                            <Button Content="导入 IO 表" Command="{Binding ImportIoTableCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="保存 IO 表" Command="{Binding SaveIoTableToSourceCommand}" IsEnabled="{Binding CanSaveIoTable}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="生成程序" Command="{Binding GenerateIoProgramsCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"
                                                    ToolTip="D1: 生成前自动校验，存在地址重复 / 类型不匹配会被阻止"/>
                                            <Button Content="打开目录" Command="{Binding OpenGeneratedIoFolderCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                            <Button Content="清空" Command="{Binding ClearIoTableCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="10,6" Margin="0,0,6,6"/>
                                        </WrapPanel>

                                        <!-- D3: 多工位批量生成 -->
                                        <Border Background="#EEF2F7" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="多工位批量生成 (D3)" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
                                                <TextBlock Text="工位号 CSV (e.g. OP30,OP40,OP50)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding IoBatchOperationNumbers, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="28" VerticalContentAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="批量生成"
                                                            Command="{Binding BatchGenerateIoProgramsCommand}"
                                                            Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                                                            Padding="10,4" Margin="6,0,0,0"
                                                            ToolTip="逐个切换 IoOperationNumber 后跑生成"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#F8FAFC" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left" Text="Git 代码拉取" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding GitPullStatus}" Foreground="#2563EB" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </DockPanel>
                                                <TextBlock Text="从远程 Git 仓库拉取最新代码到指定目录，支持首次克隆与后续增量拉取。" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,8" TextWrapping="Wrap"/>

                                                <TextBlock Text="仓库地址 (Repository URL)" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                <TextBox Text="{Binding GitRepositoryUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" ToolTip="例如 https://github.com/your/repo.git"/>

                                                <TextBlock Text="分支 (可选，留空使用默认分支)" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                <TextBox Text="{Binding GitBranch, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>

                                                <TextBlock Text="保存目录" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                <Grid Margin="0,4,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Text="{Binding GitTargetFolder, UpdateSourceTrigger=PropertyChanged}" ToolTip="本地目录。首次拉取时若目录非空且非 Git 仓库将报错。"/>
                                                    <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseGitTargetFolderCommand}" Margin="6,0,0,0" Padding="10,4" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"/>
                                                </Grid>

                                                <TextBlock Text="项目文件夹 / 分支名" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                <TextBox Text="{Binding GitProjectFolderName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,4" ToolTip="留空则直接拉到保存目录。若填写，将作为保存目录下的子文件夹名（总文件夹），并在拉取后自动 checkout 到同名本地分支（不存在则基于源分支创建）。"/>
                                                <TextBlock Text="例如填写 OP80，将克隆到 保存目录/OP80，并自动切换到本地分支 OP80。" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                                <!-- D6: 场内代理 (HTTP_PROXY / HTTPS_PROXY) -->
                                                <TextBlock Text="代理地址 (可选, 场内代理需求)" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                <TextBox Text="{Binding GitProxyUrl, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="0,4,0,8"
                                                         ToolTip="形如 http://proxy.local:8080。运行时通过 HTTP_PROXY / HTTPS_PROXY 环境变量传给 git 子进程，留空则不启用代理。"/>

                                                <Expander Header="认证 (可选 · 私有仓库)" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8">
                                                    <StackPanel Margin="0,6,0,0">
                                                        <TextBlock Text="用户名" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                        <TextBox Text="{Binding GitUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8"/>
                                                        <TextBlock Text="访问令牌 / Personal Access Token" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                                        <TextBox Text="{Binding GitAccessToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0"/>
                                                        <TextBlock Text="令牌将写入本地配置文件，请妥善保管。" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Expander>

                                                <CheckBox Content="生成程序后自动追加到 Git 目录对应 .st 文件" IsChecked="{Binding IsSyncGeneratedToGitEnabled}" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text}" ToolTip="按映射规则把 DBXX_IO → 2.Main/Main_IO.ST；DI/DO_ACT_Comment → OPXX_DI/DO_Mirror/ACT_Comment.st；ACT_* → OPXX_DriveControl/ACT_*.st"/>

                                                <CheckBox Content="拉取 .project 工程文件" IsChecked="{Binding IsIncludeProjectFilesOnPullEnabled}" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text}" ToolTip="默认不勾选：拉取代码时不会把远端 *.project 检出到本地，避免覆盖/锁定现场工程文件。勾选后会完整检出 .project 文件。"/>

                                                <CheckBox Content="强制覆盖本地 (reset --hard origin/branch + clean -fd)" IsChecked="{Binding IsForceResetLocalEnabled}" Margin="0,0,0,4" Foreground="#B91C1C" ToolTip="勾选后拉取时会丢弃本地所有未提交改动（含生成追加内容），把工作区重置成远端分支的状态。"/>

                                                <CheckBox Content="拉取后把新分支推送到远端 (git push -u origin branch)" IsChecked="{Binding IsPushProjectBranchToRemoteEnabled}" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text}" ToolTip="勾选后若本地项目分支还没有上游，会执行 git push -u origin 分支名 把分支上传到远端。需要仓库写权限。"/>

                                                <CheckBox Content="生成程序后自动 commit + push 到远端" IsChecked="{Binding IsCommitAndPushAfterGenerateEnabled}" Margin="0,0,0,4" Foreground="{DynamicResource Brush.Text}" ToolTip="勾选后每次点击&quot;生成程序&quot;结束，如果产生了追加内容，会自动 git add -A → commit → push 到远端当前分支。没有实际变更时不会产生空 commit。"/>

                                                <TextBlock Text="自动提交消息 (可选，支持 {time} / {op})" Foreground="{DynamicResource Brush.TextSecondary}" Visibility="{Binding IsCommitAndPushAfterGenerateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <TextBox Text="{Binding GitAutoCommitMessageTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" Visibility="{Binding IsCommitAndPushAfterGenerateEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="留空使用默认模板 &quot;HMI 生成程序 ({op}) @ {time}&quot;。{op} 替换为当前工位号，{time} 替换为提交时间戳。"/>


                                                <WrapPanel>
                                                    <Button Content="拉取代码" Command="{Binding PullGitRepositoryCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,6,6"/>
                                                    <Button Content="打开目录" Command="{Binding OpenGitTargetFolderCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,6,6"/>
                                                    <TextBlock Text="拉取中..." Foreground="#0F766E" VerticalAlignment="Center" Margin="4,0,0,0" Visibility="{Binding IsGitPullRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </WrapPanel>

                                                <TextBlock Text="执行日志" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,4"/>
                                                <TextBox Text="{Binding GitPullLog, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="120" FontFamily="Consolas" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" Foreground="{DynamicResource Brush.Text}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="400"/>
                                    <RowDefinition Height="300"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,10" MouseLeftButtonDown="IoPreviewHeader_MouseLeftButtonDown" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="IO 表预览" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Width="30" Height="30" Margin="8,0,0,0" Padding="0" HorizontalAlignment="Right" Command="{Binding SaveIoTableToSourceCommand}" IsEnabled="{Binding CanSaveIoTable}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" ToolTip="保存 IO 表 (Ctrl+S)">
                                                <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                        <DataGrid x:Name="IoPreviewDataGrid" Grid.Row="1" ItemsSource="{Binding IoTableRows}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserSortColumns="False" HeadersVisibility="Column" Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{DynamicResource Brush.Border}" RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC" PreviewMouseWheel="IoPreviewDataGrid_PreviewMouseWheel" ScrollViewer.CanContentScroll="True" MaxHeight="340" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.RowStyle>
                                                <!-- D1: 校验失败行红底 + tooltip 显示原因 -->
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="#FFFFFF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                            <Setter Property="ToolTip" Value="{Binding ValidationError}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="输入地址" Binding="{Binding InputAddress, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                                <!-- D8: 输入注释可直接编辑（不必导出再改 Excel 再导入） -->
                                                <DataGridTextColumn Header="输入注释" Binding="{Binding InputComment, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                                <DataGridTextColumn Header="输出地址" Binding="{Binding OutputAddress, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                                <DataGridTextColumn Header="输出注释" Binding="{Binding OutputComment, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,10" MouseLeftButtonDown="IoProgramPreviewHeader_MouseLeftButtonDown" Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="程序预览" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                                            <ComboBox Grid.Column="3" Width="220" ItemsSource="{Binding GeneratedIoPrograms}" SelectedItem="{Binding SelectedGeneratedIoProgram}" DisplayMemberPath="DisplayName" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                <Button Content="对比 Git" Command="{Binding ShowGeneratedDiffCommand}" CommandParameter="{Binding SelectedGeneratedIoProgram}"
                                                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Padding="8,4" Margin="0,0,8,0"
                                                        ToolTip="D2: 弹层 side-by-side 对比 Git 当前版本 vs 本次生成"/>
                                                <Button Content="复制当前文件" Click="CopyCurrentIoProgramButton_Click" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,8,0"/>
                                                <Button Content="打开当前文件" Command="{Binding OpenGeneratedIoFileCommand}" CommandParameter="{Binding SelectedGeneratedIoProgram}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="8,4"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBox x:Name="IoProgramPreviewTextBox" Grid.Row="1" Text="{Binding SelectedGeneratedIoProgramContent, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F8FAFC" BorderBrush="{DynamicResource Brush.Border}" Foreground="{DynamicResource Brush.Text}" PreviewMouseWheel="CodePreviewTextBox_PreviewMouseWheel"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- SFC 步骤式自动程序生成 -->
                        <Grid Grid.Row="0"
                              Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                              Visibility="{Binding IsDesignerAutoProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左栏：步骤列表 -->
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="SFC 步骤列表" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,10"/>

                                    <!-- 程序设置 -->
                                    <Grid Grid.Row="1" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="程序名称" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                            <TextBox Text="{Binding SfcProgramName, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="工位号" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                            <TextBox Text="{Binding SfcStationNo, UpdateSourceTrigger=LostFocus}" Padding="6,4" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 操作按钮 -->
                                    <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                                        <Button Content="+ 添加" Command="{Binding AddSfcStepCommand}" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Padding="8,4" Margin="0,0,4,4"/>
                                        <Button Content="删除" Command="{Binding DeleteSfcStepCommand}" Background="#DC2626" Foreground="White" BorderBrush="#DC2626" Padding="8,4" Margin="0,0,4,4"/>
                                        <Button Content="↑" Command="{Binding MoveSfcStepUpCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,4,4" FontWeight="Bold"/>
                                        <Button Content="↓" Command="{Binding MoveSfcStepDownCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,4,4" FontWeight="Bold"/>
                                    </WrapPanel>

                                    <!-- 步骤表格 -->
                                    <DataGrid Grid.Row="3"
                                              ItemsSource="{Binding SfcSteps}"
                                              SelectedItem="{Binding SelectedSfcStep}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                                              HeadersVisibility="Column" SelectionMode="Single"
                                              Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{DynamicResource Brush.Border}"
                                              RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                                              MinHeight="300">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="步序" Binding="{Binding StepNo}" Width="50" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="动作" Binding="{Binding ActionSummary}" Width="*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="跳转" Binding="{Binding NextSummary}" Width="70" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- 中栏：步骤属性（多动作 + 多分支） -->
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,8,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                    <StackPanel>
                                        <TextBlock Text="步骤属性" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>

                                        <!-- 无选中提示 -->
                                        <TextBlock Text="← 在左侧选择一个步骤" Foreground="{DynamicResource Brush.TextPlaceholder}" FontStyle="Italic" TextWrapping="Wrap"
                                                   Visibility="{Binding SelectedSfcStep, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>

                                        <!-- 属性面板（有选中时显示） -->
                                        <StackPanel Visibility="{Binding SelectedSfcStep, Converter={StaticResource NullToVisibilityConverter}}">

                                            <!-- 步序号 -->
                                            <TextBlock Text="步序号" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SelectedSfcStep.StepNo, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,0,12"/>

                                            <!-- 动作列表标题栏 -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="动作列表" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" FontSize="13" VerticalAlignment="Center"/>
                                                <Button DockPanel.Dock="Right" Content="+ 添加动作" Command="{Binding AddSfcActionCommand}"
                                                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                                                        Padding="6,3" FontSize="12" HorizontalAlignment="Right"/>
                                            </DockPanel>

                                            <!-- 动作行列表（每行内联编辑） -->
                                            <ItemsControl ItemsSource="{Binding SelectedSfcStep.Actions}" Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1" CornerRadius="4"
                                                                Padding="4,3" Margin="0,0,0,4" Background="#FAFAFA">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="88"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="72"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="22"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- 设备类型 -->
                                                                <ComboBox Grid.Column="0"
                                                                          ItemsSource="{Binding AllDeviceTypes}"
                                                                          SelectedItem="{Binding DeviceType, UpdateSourceTrigger=PropertyChanged}"
                                                                          Padding="4,2" FontSize="12"/>

                                                                <!-- 气缸选择下拉 -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding DataContext.SfcCylinderOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          SelectedItem="{Binding SelectedDeviceOption, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowCylinderPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 轴选择下拉 -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding DataContext.SfcAxisOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          SelectedItem="{Binding SelectedDeviceOption, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowAxisPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 真空选择下拉 -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding DataContext.SfcVacuumOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          SelectedItem="{Binding SelectedDeviceOption, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowVacuumPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 电机序号输入框 -->
                                                                <TextBox Grid.Column="2"
                                                                         Text="{Binding DeviceIndex, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"
                                                                         Visibility="{Binding ShowDeviceIndex, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 动作类型 -->
                                                                <ComboBox Grid.Column="4"
                                                                          ItemsSource="{Binding AvailableActionTypes}"
                                                                          SelectedItem="{Binding ActionType, UpdateSourceTrigger=PropertyChanged}"
                                                                          Padding="4,2" FontSize="12"/>

                                                                <!-- 轴点位选择下拉（Axis+MoveToPoint） -->
                                                                <ComboBox Grid.Column="6"
                                                                          ItemsSource="{Binding AxisPointOptions}"
                                                                          SelectedItem="{Binding SelectedAxisPoint, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="Label"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowAxisPointPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 延时输入（Wait+Timer） -->
                                                                <TextBox Grid.Column="6"
                                                                         Text="{Binding PointIndex, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"
                                                                         Visibility="{Binding ShowTimerInput, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 自定义指令（Custom 或 Wait+Condition） -->
                                                                <TextBox Grid.Column="6"
                                                                         Text="{Binding CustomCommand, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"
                                                                         Visibility="{Binding ShowCustom, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 删除按钮 -->
                                                                <Button Grid.Column="8" Content="×" FontSize="12"
                                                                        Command="{Binding DataContext.DeleteSfcActionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" BorderBrush="#FCA5A5"
                                                                        Foreground="#DC2626" Padding="2,1" VerticalAlignment="Stretch"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 跳转分支标题栏 -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="跳转分支" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" FontSize="13" VerticalAlignment="Center"/>
                                                <Button DockPanel.Dock="Right" Content="+ 添加分支" Command="{Binding AddSfcBranchCommand}"
                                                        Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                                                        Padding="6,3" FontSize="12" HorizontalAlignment="Right"/>
                                            </DockPanel>

                                            <!-- 分支行列表（条件 → 目标步序） -->
                                            <ItemsControl ItemsSource="{Binding SelectedSfcStep.Branches}" Margin="0,0,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="4"
                                                                Padding="4,3" Margin="0,0,0,4" Background="#FAFAFA">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="4"/>
                                                                    <ColumnDefinition Width="16"/>
                                                                    <ColumnDefinition Width="4"/>
                                                                    <ColumnDefinition Width="52"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="22"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0"
                                                                         Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"/>
                                                                <TextBlock Grid.Column="2" Text="→" VerticalAlignment="Center"
                                                                           FontSize="13" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center"/>
                                                                <TextBox Grid.Column="4"
                                                                         Text="{Binding TargetStep, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"/>
                                                                <Button Grid.Column="6" Content="×" FontSize="12"
                                                                        Command="{Binding DataContext.DeleteSfcBranchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" BorderBrush="#DDD6FE"
                                                                        Foreground="#7C3AED" Padding="2,1" VerticalAlignment="Stretch"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 分支说明（有分支时显示） -->
                                            <TextBlock Text="无分支时使用下方默认跳转" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" Margin="0,0,0,6"/>

                                            <!-- 默认下一步 -->
                                            <TextBlock Text="默认下一步（步序号 或 END）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SelectedSfcStep.NextStep, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,0,10"/>

                                            <!-- 完成条件（覆盖自动生成） -->
                                            <TextBlock Text="完成条件（留空则自动生成）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SelectedSfcStep.CompletionCondition, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="6,4" Margin="0,0,0,4"/>
                                            <Button Content="自动填充完成条件" Command="{Binding AutoFillSelectedSfcStepCommand}"
                                                    Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0"
                                                    Padding="8,4" Margin="0,0,0,12" HorizontalAlignment="Left"/>

                                            <!-- 报警条目 -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="报警条目" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Button Content="+" DockPanel.Dock="Right"
                                                        Command="{Binding AddSfcAlarmCommand}"
                                                        Background="#FEF3C7" Foreground="#92400E" BorderBrush="#FDE68A"
                                                        Padding="6,2" FontWeight="Bold"/>
                                            </DockPanel>

                                            <ItemsControl ItemsSource="{Binding SelectedSfcStep.AlarmEntries}" Margin="0,0,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="4"
                                                                Background="#FFFBEB" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <!-- 类型选择 -->
                                                                    <DockPanel Margin="0,0,0,4">
                                                                        <TextBlock Text="类型：" Foreground="#78350F" FontSize="11" Width="40" VerticalAlignment="Center"/>
                                                                        <ComboBox ItemsSource="{x:Static models:SfcStepAlarm.AlarmTypes}"
                                                                                  SelectedItem="{Binding AlarmType, UpdateSourceTrigger=PropertyChanged}"
                                                                                  Padding="4,2" FontSize="12"/>
                                                                    </DockPanel>
                                                                    <!-- 报警信息 -->
                                                                    <DockPanel Margin="0,0,0,4">
                                                                        <TextBlock Text="信息：" Foreground="#78350F" FontSize="11" Width="40" VerticalAlignment="Center"/>
                                                                        <TextBox Text="{Binding AlarmMessage, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Padding="4,2" FontSize="12" ToolTip="报警显示信息（注释用途）"/>
                                                                    </DockPanel>
                                                                    <!-- 报警条件 -->
                                                                    <DockPanel>
                                                                        <TextBlock Text="条件：" Foreground="#78350F" FontSize="11" Width="40" VerticalAlignment="Center"/>
                                                                        <TextBox Text="{Binding AlarmCondition, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Padding="4,2" FontSize="12" FontFamily="Consolas"
                                                                                 ToolTip="ST 表达式，如 DB1050.CylCtrl[...].Status.Error"/>
                                                                    </DockPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="1" Content="×" VerticalAlignment="Top"
                                                                        Command="{Binding DataContext.DeleteSfcAlarmCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" Foreground="#DC2626" BorderThickness="0"
                                                                        Padding="4,0" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- 右栏：代码预览 -->
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 工具栏 -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,10" MouseLeftButtonDown="SfcCodePreviewHeader_MouseLeftButtonDown">
                                        <TextBlock Text="生成代码" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="生成代码" Command="{Binding GenerateSfcCodeCommand}"
                                                    Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,5" Margin="0,0,6,0"/>
                                            <Button Content="复制" Command="{Binding CopySfcCodeCommand}"
                                                    Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="10,5" Margin="0,0,6,0"/>
                                            <Button Content="保存文件" Command="{Binding SaveSfcCodeToFileCommand}"
                                                    Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,5" Margin="0,0,6,0"/>
                                            <Button Content="术语表" Click="OpenAlarmTermsDialog_Click"
                                                    Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED" Padding="10,5"
                                                    ToolTip="编辑中文→英文报警术语对照表"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- 代码文本框（可手动编辑，独立滚动） -->
                                    <TextBox Grid.Row="1"
                                             x:Name="SfcCodePreviewTextBox"
                                             Text="{Binding SfcGeneratedCode, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="13"
                                             Background="#F8FAFC" BorderBrush="{DynamicResource Brush.Border}" Foreground="{DynamicResource Brush.Text}"
                                             MouseLeftButtonDown="SfcCodePreviewHeader_MouseLeftButtonDown"
                                             PreviewMouseWheel="CodePreviewTextBox_PreviewMouseWheel"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 初始化程序生成页 (独立步骤集合，与自动程序页等级相同) -->
                        <Grid Grid.Row="0"
                              Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                              Visibility="{Binding IsDesignerInitProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="380"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左栏：初始化步骤列表 -->
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="初始化步骤列表" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,10"/>

                                    <!-- 程序设置 -->
                                    <Grid Grid.Row="1" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="程序名称" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                            <TextBox Text="{Binding SfcInitProgramName, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="工位号" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                            <TextBox Text="{Binding SfcInitStationNo, UpdateSourceTrigger=LostFocus}" Padding="6,4" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 操作按钮 -->
                                    <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                                        <Button Content="+ 添加" Command="{Binding AddSfcInitStepCommand}" Background="#9333EA" Foreground="White" BorderBrush="#9333EA" Padding="8,4" Margin="0,0,4,4"/>
                                        <Button Content="删除" Command="{Binding DeleteSfcInitStepCommand}" Background="#DC2626" Foreground="White" BorderBrush="#DC2626" Padding="8,4" Margin="0,0,4,4"/>
                                        <Button Content="↑" Command="{Binding MoveSfcInitStepUpCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,4,4" FontWeight="Bold"/>
                                        <Button Content="↓" Command="{Binding MoveSfcInitStepDownCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="8,4" Margin="0,0,4,4" FontWeight="Bold"/>
                                    </WrapPanel>

                                    <!-- 步骤表格 -->
                                    <DataGrid Grid.Row="3"
                                              ItemsSource="{Binding SfcInitSteps}"
                                              SelectedItem="{Binding SelectedSfcInitStep}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False"
                                              HeadersVisibility="Column" SelectionMode="Single"
                                              Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{DynamicResource Brush.Border}"
                                              RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                                              MinHeight="300">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="步序" Binding="{Binding StepNo}" Width="50" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="动作" Binding="{Binding ActionSummary}" Width="*" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="跳转" Binding="{Binding NextSummary}" Width="70" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- 中栏：初始化步骤属性（与自动程序中栏完全一致，绑定 Init 版本） -->
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,8,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                                    <StackPanel>
                                        <TextBlock Text="步骤属性" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>

                                        <!-- 无选中提示 -->
                                        <TextBlock Text="← 在左侧选择一个步骤" Foreground="{DynamicResource Brush.TextPlaceholder}" FontStyle="Italic" TextWrapping="Wrap"
                                                   Visibility="{Binding SelectedSfcInitStep, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>

                                        <!-- 属性面板（有选中时显示） -->
                                        <StackPanel Visibility="{Binding SelectedSfcInitStep, Converter={StaticResource NullToVisibilityConverter}}">

                                            <!-- 步序号 -->
                                            <TextBlock Text="步序号" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SelectedSfcInitStep.StepNo, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,0,12"/>

                                            <!-- 动作列表标题栏 -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="动作列表" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" FontSize="13" VerticalAlignment="Center"/>
                                                <Button DockPanel.Dock="Right" Content="+ 添加动作" Command="{Binding AddSfcInitActionCommand}"
                                                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                                                        Padding="6,3" FontSize="12" HorizontalAlignment="Right"/>
                                            </DockPanel>

                                            <!-- 动作行列表（每行内联编辑，与自动程序完全相同布局） -->
                                            <ItemsControl ItemsSource="{Binding SelectedSfcInitStep.Actions}" Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1" CornerRadius="4"
                                                                Padding="4,3" Margin="0,0,0,4" Background="#FAFAFA">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="88"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="72"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="22"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- 设备类型 -->
                                                                <ComboBox Grid.Column="0"
                                                                          ItemsSource="{Binding AllDeviceTypes}"
                                                                          SelectedItem="{Binding DeviceType, UpdateSourceTrigger=PropertyChanged}"
                                                                          Padding="4,2" FontSize="12"/>

                                                                <!-- 气缸选择下拉 -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding DataContext.SfcCylinderOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          SelectedItem="{Binding SelectedDeviceOption, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowCylinderPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 轴选择下拉 -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding DataContext.SfcAxisOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          SelectedItem="{Binding SelectedDeviceOption, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowAxisPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 真空选择下拉 -->
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding DataContext.SfcVacuumOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          SelectedItem="{Binding SelectedDeviceOption, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowVacuumPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 电机序号输入框 -->
                                                                <TextBox Grid.Column="2"
                                                                         Text="{Binding DeviceIndex, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"
                                                                         Visibility="{Binding ShowDeviceIndex, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 动作类型 -->
                                                                <ComboBox Grid.Column="4"
                                                                          ItemsSource="{Binding AvailableActionTypes}"
                                                                          SelectedItem="{Binding ActionType, UpdateSourceTrigger=PropertyChanged}"
                                                                          Padding="4,2" FontSize="12"/>

                                                                <!-- 轴点位选择下拉（Axis+MoveToPoint） -->
                                                                <ComboBox Grid.Column="6"
                                                                          ItemsSource="{Binding AxisPointOptions}"
                                                                          SelectedItem="{Binding SelectedAxisPoint, UpdateSourceTrigger=PropertyChanged}"
                                                                          DisplayMemberPath="Label"
                                                                          Padding="4,2" FontSize="12"
                                                                          Visibility="{Binding ShowAxisPointPicker, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 延时输入（Wait+Timer） -->
                                                                <TextBox Grid.Column="6"
                                                                         Text="{Binding PointIndex, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"
                                                                         Visibility="{Binding ShowTimerInput, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 自定义指令（Custom 或 Wait+Condition） -->
                                                                <TextBox Grid.Column="6"
                                                                         Text="{Binding CustomCommand, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"
                                                                         Visibility="{Binding ShowCustom, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                <!-- 删除按钮 -->
                                                                <Button Grid.Column="8" Content="×" FontSize="12"
                                                                        Command="{Binding DataContext.DeleteSfcInitActionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" BorderBrush="#FCA5A5"
                                                                        Foreground="#DC2626" Padding="2,1" VerticalAlignment="Stretch"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 跳转分支标题栏 -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="跳转分支" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" FontSize="13" VerticalAlignment="Center"/>
                                                <Button DockPanel.Dock="Right" Content="+ 添加分支" Command="{Binding AddSfcInitBranchCommand}"
                                                        Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                                                        Padding="6,3" FontSize="12" HorizontalAlignment="Right"/>
                                            </DockPanel>

                                            <!-- 分支行列表（条件 → 目标步序） -->
                                            <ItemsControl ItemsSource="{Binding SelectedSfcInitStep.Branches}" Margin="0,0,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="4"
                                                                Padding="4,3" Margin="0,0,0,4" Background="#FAFAFA">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="4"/>
                                                                    <ColumnDefinition Width="16"/>
                                                                    <ColumnDefinition Width="4"/>
                                                                    <ColumnDefinition Width="52"/>
                                                                    <ColumnDefinition Width="3"/>
                                                                    <ColumnDefinition Width="22"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0"
                                                                         Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"/>
                                                                <TextBlock Grid.Column="2" Text="→" VerticalAlignment="Center"
                                                                           FontSize="13" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center"/>
                                                                <TextBox Grid.Column="4"
                                                                         Text="{Binding TargetStep, UpdateSourceTrigger=PropertyChanged}"
                                                                         Padding="3,2" FontSize="12"/>
                                                                <Button Grid.Column="6" Content="×" FontSize="12"
                                                                        Command="{Binding DataContext.DeleteSfcInitBranchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" BorderBrush="#DDD6FE"
                                                                        Foreground="#7C3AED" Padding="2,1" VerticalAlignment="Stretch"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 分支说明（有分支时显示） -->
                                            <TextBlock Text="无分支时使用下方默认跳转" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" Margin="0,0,0,6"/>

                                            <!-- 默认下一步 -->
                                            <TextBlock Text="默认下一步（步序号 或 END）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SelectedSfcInitStep.NextStep, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,0,10"/>

                                            <!-- 完成条件（覆盖自动生成） -->
                                            <TextBlock Text="完成条件（留空则自动生成）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SelectedSfcInitStep.CompletionCondition, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="6,4" Margin="0,0,0,4"/>
                                            <Button Content="自动填充完成条件" Command="{Binding AutoFillSelectedSfcInitStepCommand}"
                                                    Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0"
                                                    Padding="8,4" Margin="0,0,0,12" HorizontalAlignment="Left"/>

                                            <!-- 报警条目 -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="报警条目" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Button Content="+" DockPanel.Dock="Right"
                                                        Command="{Binding AddSfcInitAlarmCommand}"
                                                        Background="#FEF3C7" Foreground="#92400E" BorderBrush="#FDE68A"
                                                        Padding="6,2" FontWeight="Bold"/>
                                            </DockPanel>

                                            <ItemsControl ItemsSource="{Binding SelectedSfcInitStep.AlarmEntries}" Margin="0,0,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="4"
                                                                Background="#FFFBEB" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <!-- 类型选择 -->
                                                                    <DockPanel Margin="0,0,0,4">
                                                                        <TextBlock Text="类型：" Foreground="#78350F" FontSize="11" Width="40" VerticalAlignment="Center"/>
                                                                        <ComboBox ItemsSource="{x:Static models:SfcStepAlarm.AlarmTypes}"
                                                                                  SelectedItem="{Binding AlarmType, UpdateSourceTrigger=PropertyChanged}"
                                                                                  Padding="4,2" FontSize="12"/>
                                                                    </DockPanel>
                                                                    <!-- 报警信息 -->
                                                                    <DockPanel Margin="0,0,0,4">
                                                                        <TextBlock Text="信息：" Foreground="#78350F" FontSize="11" Width="40" VerticalAlignment="Center"/>
                                                                        <TextBox Text="{Binding AlarmMessage, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Padding="4,2" FontSize="12" ToolTip="报警显示信息（注释用途）"/>
                                                                    </DockPanel>
                                                                    <!-- 报警条件 -->
                                                                    <DockPanel>
                                                                        <TextBlock Text="条件：" Foreground="#78350F" FontSize="11" Width="40" VerticalAlignment="Center"/>
                                                                        <TextBox Text="{Binding AlarmCondition, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Padding="4,2" FontSize="12" FontFamily="Consolas"
                                                                                 ToolTip="ST 表达式，如 DB1050.CylCtrl[...].Status.Error"/>
                                                                    </DockPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="1" Content="×" VerticalAlignment="Top"
                                                                        Command="{Binding DataContext.DeleteSfcInitAlarmCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Background="Transparent" Foreground="#DC2626" BorderThickness="0"
                                                                        Padding="4,0" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- 右栏：初始化程序代码预览 -->
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="初始化程序代码" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="生成初始化程序" Command="{Binding GenerateSfcInitCodeCommand}"
                                                    Background="#9333EA" Foreground="White" BorderBrush="#9333EA" Padding="10,5" Margin="0,0,6,0"/>
                                            <Button Content="复制" Command="{Binding CopySfcInitCodeCommand}"
                                                    Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="10,5" Margin="0,0,6,0"/>
                                            <Button Content="保存文件" Command="{Binding SaveSfcInitCodeToFileCommand}"
                                                    Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,5"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBox Grid.Row="1"
                                             Text="{Binding SfcInitGeneratedCode, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="13"
                                             Background="#F8FAFC" BorderBrush="{DynamicResource Brush.Border}" Foreground="{DynamicResource Brush.Text}"
                                             PreviewMouseWheel="CodePreviewTextBox_PreviewMouseWheel"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                    </ScrollViewer>
</UserControl>
