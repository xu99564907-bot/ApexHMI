<UserControl x:Class="ApexHMI.Views.Pages.RuntimeDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:ApexHMI.Models">
    <Grid Margin="12" DataContext="{Binding ShellViewModel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="设计运行页" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="这里直接渲染当前设计页面，新增控件和页面切换会在运行页即时验证。" Margin="0,6,0,0" Foreground="#475569"/>
                </StackPanel>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding DesignerPages}"
                          SelectedItem="{Binding SelectedDesignerPage}"
                          VerticalAlignment="Center"
                          Margin="12,0,12,0"/>

                <Button Grid.Column="2"
                        Content="打开设计器"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="画布设计"
                        Background="#374151"
                        Foreground="White"
                        BorderBrush="#374151"
                        Padding="12,8"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding DesignerPageName}" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="当前页面按运行逻辑执行点击动作，可直接验证页面跳转和变量绑定。" Foreground="#2563EB" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="10" Padding="10,6">
                        <TextBlock Text="点击元素即可执行页面跳转或绑定动作" Foreground="#4338CA"/>
                    </Border>
                </DockPanel>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Width="{Binding DesignerCanvasWidth}"
                            Height="{Binding DesignerCanvasHeight}"
                            Background="#E2E8F0"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Canvas ClipToBounds="True">
                            <ItemsControl ItemsSource="{Binding DesignerElements}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.Resources>
                                    <DataTemplate DataType="{x:Type model:DesignerElement}">
                                        <Button Width="{Binding Width}"
                                                Height="{Binding Height}"
                                                Command="{Binding DataContext.ExecuteRuntimeElementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}"
                                                BorderBrush="{Binding BorderBrush, Converter={StaticResource StringToBrushConverter}}"
                                                BorderThickness="2"
                                                Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                                                Padding="10,6">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="10">
                                                        <Grid>
                                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding ElementType}" FontSize="10" Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Text}"
                                                                           FontSize="{Binding FontSize}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{TemplateBinding Foreground}"
                                                                           HorizontalAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,4,0,0"/>
                                                                <TextBlock Text="{Binding TagBinding}"
                                                                           FontSize="10"
                                                                           Foreground="#CBD5E1"
                                                                           HorizontalAlignment="Center"
                                                                           Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.Resources>
                            </ItemsControl>
                        </Canvas>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>