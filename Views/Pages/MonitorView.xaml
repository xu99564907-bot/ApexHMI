<UserControl x:Class="ApexHMI.Views.Pages.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="clr-namespace:ApexHMI.Models">
    <UserControl.InputBindings>
        <!-- M13 Alt+PageUp/Down 翻页（用 Alt 修饰避免跟 DataGrid 默认 PageUp/Down 冲突）-->
        <KeyBinding Modifiers="Alt" Key="PageUp" Command="{Binding IoMonitorPageUpCommand}"/>
        <KeyBinding Modifiers="Alt" Key="PageDown" Command="{Binding IoMonitorPageDownCommand}"/>
    </UserControl.InputBindings>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonDown="PageScrollViewer_PreviewMouseLeftButtonDown" PreviewGotKeyboardFocus="PageScrollViewer_PreviewGotKeyboardFocus" RequestBringIntoView="PageScrollViewer_RequestBringIntoView">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}" Padding="16" Visibility="{Binding IsMonitorProductionPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="详细生产数据" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
                                <WrapPanel Margin="0,0,0,12">
                                    <TextBlock Text="监视分类：" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Width="140" ItemsSource="{Binding MonitorCategoryOptions}" SelectedItem="{Binding SelectedMonitorCategory}" Margin="0,0,12,0"/>
                                    <TextBlock Text="流程：" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Width="120" ItemsSource="{Binding FlowFilterOptions}" SelectedItem="{Binding SelectedFlowFilter}" Margin="0,0,12,0"/>
                                    <TextBlock Text="步号：" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Width="90" ItemsSource="{Binding FlowStepFilterOptions}" SelectedItem="{Binding SelectedFlowStepFilter}" Margin="0,0,12,0"/>
                                    <TextBlock Text="时间：" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Width="120" ItemsSource="{Binding FlowTimeRangeOptions}" SelectedItem="{Binding SelectedFlowTimeRange}" Margin="0,0,12,0"/>
                                    <!-- M5 自定义时间范围：DatePicker 仅在 SelectedFlowTimeRange == "自定义" 时显示 -->
                                    <DatePicker SelectedDate="{Binding CustomTimeFrom, Mode=TwoWay}" Margin="0,0,4,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsCustomTimeRangeVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                ToolTip="起始日期"/>
                                    <TextBlock Text="~" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"
                                               Visibility="{Binding IsCustomTimeRangeVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <DatePicker SelectedDate="{Binding CustomTimeTo, Mode=TwoWay}" Margin="0,0,12,0" VerticalAlignment="Center"
                                                Visibility="{Binding IsCustomTimeRangeVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                ToolTip="结束日期"/>
                                    <CheckBox Content="仅异常" IsChecked="{Binding ShowOnlyAbnormalFlow}" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Button Content="刷新视图" Command="{Binding RefreshTagsCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,0"/>
                                    <Button Content="加载历史趋势" Command="{Binding LoadTrendHistoryCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="12,8" Margin="0,0,8,0"/>
                                    <Button Content="导入流程CSV分析" Command="{Binding ImportFlowCsvCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="12,8"/>
                                </WrapPanel>
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                <!-- M3 KPI ToolTip 显示明细 + M6 工单 / 配方切换提示 -->
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,8,8" ToolTip="{Binding OrderKpiDetail}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="工单号" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding OrderChangeHint}" Foreground="#0EA5E9" FontSize="11" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding CurrentOrderText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="8,0,0,8" ToolTip="{Binding RecipeKpiDetail}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="配方" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding RecipeChangeHint}" Foreground="#0EA5E9" FontSize="11" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding CurrentRecipeText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,8,8" ToolTip="{Binding ShiftKpiDetail}"><StackPanel><TextBlock Text="班次状态" Foreground="{DynamicResource Brush.TextMuted}"/><TextBlock Text="{Binding ShiftStatusText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/></StackPanel></Border>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="8,0,0,8" ToolTip="{Binding TargetKpiDetail}"><StackPanel><TextBlock Text="目标产量" Foreground="{DynamicResource Brush.TextMuted}"/><TextBlock Text="{Binding TargetCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/></StackPanel></Border>
                                </UniformGrid>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,0,12"><StackPanel><TextBlock Text="历史趋势落盘状态" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/><TextBlock Text="系统每次刷新时会自动将 OEE / 产量 / 报警数追加写入 trend-history.csv。" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,8,0,0" TextWrapping="Wrap"/></StackPanel></Border>
                                <Grid Margin="0,12,0,0">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="#0B1324" Padding="12" Margin="0,0,8,8"><StackPanel><TextBlock Text="生产 KPI" FontSize="16" FontWeight="Bold" Foreground="White"/><TextBlock Text="{Binding ShiftProductionCount, StringFormat=班次：{0}}" Foreground="#CBD5E1" Margin="0,8,0,6"/><TextBlock Text="{Binding GoodCount, StringFormat=良品：{0}}" Foreground="#CBD5E1" Margin="0,0,0,6"/><TextBlock Text="{Binding NgCount, StringFormat=不良：{0}}" Foreground="#CBD5E1" Margin="0,0,0,6"/><TextBlock Text="{Binding HourlyThroughput, StringFormat=UPH：{0}}" Foreground="#CBD5E1" Margin="0,0,0,6"/><TextBlock Text="{Binding CycleTimeSeconds, StringFormat=节拍：{0:F1}s}" Foreground="#CBD5E1"/></StackPanel></Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#0B1324" Padding="12" Margin="8,0,0,8"><StackPanel><TextBlock Text="设备运行统计" FontSize="16" FontWeight="Bold" Foreground="White"/><TextBlock Text="{Binding MachineRunTimeMin, StringFormat=运行时间：{0} min}" Foreground="#CBD5E1" Margin="0,8,0,6"/><TextBlock Text="{Binding MachineStopTimeMin, StringFormat=停机时间：{0} min}" Foreground="#CBD5E1" Margin="0,0,0,6"/><TextBlock Text="{Binding AvailabilityRate, StringFormat=Availability：{0:F1}%}" Foreground="#CBD5E1" Margin="0,0,0,6"/><TextBlock Text="{Binding PerformanceRate, StringFormat=Performance：{0:F1}%}" Foreground="#CBD5E1" Margin="0,0,0,6"/><TextBlock Text="{Binding QualityRate, StringFormat=Quality：{0:F1}%}" Foreground="#CBD5E1"/></StackPanel></Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="#10203A" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="产量趋势" FontSize="16" FontWeight="Bold" Foreground="White"/><TextBlock Text="{Binding ProductionTrendSummary}" Foreground="#BFDBFE" Margin="0,8,0,6"/><TextBlock Text="{Binding TimeAxisSummary}" Foreground="#93C5FD" Margin="0,0,0,10"/><Grid Height="56"><Rectangle Fill="#0B1220" RadiusX="6" RadiusY="6"/><Path Data="{Binding ProductionTrendPath}" Stroke="#60A5FA" Style="{StaticResource SparklinePathStyle}" Margin="8,8"/></Grid></StackPanel></Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#0F2A1F" Padding="12" Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="流程 / OEE / 报警趋势" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="{Binding OeeTrendSummary}" Foreground="#BBF7D0" Margin="0,8,0,6"/>
                                            <TextBlock Text="{Binding AlarmTrendSummary}" Foreground="#FECACA" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding TimeAxisSummary}" Foreground="#86EFAC" Margin="0,0,0,10"/>
                                            <Grid Height="56">
                                                <Rectangle Fill="#0B1220" RadiusX="6" RadiusY="6"/>
                                                <Path Data="{Binding OeeTrendPath}" Stroke="#22C55E" Style="{StaticResource SparklinePathStyle}" Margin="8,8"
                                                      Visibility="{Binding ShowOeeTrendLine, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <Path Data="{Binding AlarmTrendPath}" Stroke="#F59E0B" Style="{StaticResource SparklinePathStyle}" Margin="8,8" Opacity="0.85"
                                                      Visibility="{Binding ShowAlarmTrendLine, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <Path Data="{Binding FlowStepTrendPath}" Stroke="#60A5FA" Style="{StaticResource SparklinePathStyle}" Margin="8,8" Opacity="0.9"
                                                      Visibility="{Binding ShowFlowStepTrendLine, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <Path Data="{Binding FlowIssueTrendPath}" Stroke="#A78BFA" Style="{StaticResource SparklinePathStyle}" Margin="8,8" Opacity="0.75"
                                                      Visibility="{Binding ShowFlowIssueTrendLine, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </Grid>
                                            <!-- M8 趋势线显示开关 -->
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <CheckBox Content="OEE" IsChecked="{Binding ShowOeeTrendLine}" Foreground="#22C55E" FontSize="11" Margin="0,0,10,0"/>
                                                <CheckBox Content="报警" IsChecked="{Binding ShowAlarmTrendLine}" Foreground="#F59E0B" FontSize="11" Margin="0,0,10,0"/>
                                                <CheckBox Content="流程步号" IsChecked="{Binding ShowFlowStepTrendLine}" Foreground="#60A5FA" FontSize="11" Margin="0,0,10,0"/>
                                                <CheckBox Content="异常" IsChecked="{Binding ShowFlowIssueTrendLine}" Foreground="#A78BFA" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding FlowRankingSummary}" Foreground="#DDD6FE" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}" Padding="16" Visibility="{Binding IsMonitorSinglePanelPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentMonitorTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>
                                <!-- IO 状态监控表格 -->
                                <Grid Visibility="{Binding IsMonitorIoPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- 切换按钮行：输入监控 / 输出监控 + M9 搜索 + M15 导出 CSV -->
                                    <DockPanel Margin="0,0,0,12">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                            <Button Content="输入监控"
                                                    Command="{Binding SwitchIoMonitorTypeCommand}"
                                                    CommandParameter="DI"
                                                    Background="{Binding IoMonitorDiButtonBackground, Converter={StaticResource StringToBrushConverter}}"
                                                    Foreground="{Binding IoMonitorDiButtonForeground, Converter={StaticResource StringToBrushConverter}}"
                                                    Width="120" Height="36" Margin="0,0,8,0"/>
                                            <Button Content="输出监控"
                                                    Command="{Binding SwitchIoMonitorTypeCommand}"
                                                    CommandParameter="DO"
                                                    Background="{Binding IoMonitorDoButtonBackground, Converter={StaticResource StringToBrushConverter}}"
                                                    Foreground="{Binding IoMonitorDoButtonForeground, Converter={StaticResource StringToBrushConverter}}"
                                                    Width="120" Height="36"/>
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right" Content="导出 CSV"
                                                Command="{Binding ExportIoSnapshotCsvCommand}"
                                                Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                                                Padding="14,8" Margin="8,0,0,0" Height="36"
                                                ToolTip="导出当前所有 IO 状态 + 翻转计数到 CSV 文件"/>
                                        <TextBox Text="{Binding IoMonitorSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderBrush="{DynamicResource Brush.Border}" Padding="6,4" Margin="16,0,0,0" Height="36" VerticalContentAlignment="Center"
                                                 ToolTip="搜索 IO（按地址 / 注释模糊匹配，比如输入 CY3 只看 CY3 相关）"/>
                                    </DockPanel>
                                    <!-- 标题 -->
                                    <TextBlock Grid.Row="1" Text="{Binding IoMonitorTitle}" 
                                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" 
                                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <!-- IO 状态表格 -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 左半表格 -->
                                        <DataGrid Grid.Column="0" ItemsSource="{Binding IoMonitorLeftItems}"
                                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                                  HeadersVisibility="Column" IsReadOnly="True"
                                                  Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}"
                                                  RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                                                  Margin="0,0,4,0">
                                            <!-- M11 IsRecentlyChanged 高亮（1.5s 内有过变化的行黄底）-->
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecentlyChanged}" Value="True">
                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="状态" Width="50">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Ellipse Width="14" Height="14" HorizontalAlignment="Center">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="#94A3B8"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="True">
                                                                                <Setter Property="Fill" Value="#22C55E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="80"/>
                                                <DataGridTextColumn Header="注释" Binding="{Binding Comment}" Width="*"/>
                                                <!-- M10 翻转计数 -->
                                                <DataGridTextColumn Header="翻转" Binding="{Binding ToggleCount}" Width="55"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <!-- 右半表格 -->
                                        <DataGrid Grid.Column="1" ItemsSource="{Binding IoMonitorRightItems}"
                                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                                  HeadersVisibility="Column" IsReadOnly="True"
                                                  Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}"
                                                  RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                                                  Margin="4,0,8,0">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecentlyChanged}" Value="True">
                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="状态" Width="50">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Ellipse Width="14" Height="14" HorizontalAlignment="Center">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="#94A3B8"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="True">
                                                                                <Setter Property="Fill" Value="#22C55E"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="80"/>
                                                <DataGridTextColumn Header="注释" Binding="{Binding Comment}" Width="*"/>
                                                <DataGridTextColumn Header="翻转" Binding="{Binding ToggleCount}" Width="55"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <!-- 翻页按钮 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <Button Content="▲" Command="{Binding IoMonitorPageUpCommand}" 
                                                    Width="50" Height="50" Margin="0,0,0,8"
                                                    Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" FontSize="18"/>
                                            <Button Content="▼" Command="{Binding IoMonitorPageDownCommand}" 
                                                    Width="50" Height="50"
                                                    Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" FontSize="18"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFF" Padding="12" Margin="0,0,0,12" Visibility="{Binding IsMonitorCommunicationPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="OPC UA 内置调试器" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                                            <WrapPanel DockPanel.Dock="Right">
                                                <Button Content="浏览根节点" Command="{Binding LoadOpcUaBrowserRootCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6" Margin="0,0,8,0"/>
                                                <Button Content="读取选中节点" Command="{Binding RefreshSelectedOpcUaNodeCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="10,6" Margin="0,0,8,0"/>
                                                <Button Content="加入变量表" Command="{Binding AddSelectedOpcUaNodeAsTagCommand}" Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1" Padding="10,6"/>
                                            </WrapPanel>
                                        </DockPanel>
                                        <!-- M17 节点搜索框 -->
                                        <DockPanel Grid.Row="1" Margin="0,0,0,10">
                                            <TextBlock Text="搜索：" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBox DockPanel.Dock="Left" Text="{Binding OpcUaBrowserSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="240" BorderBrush="{DynamicResource Brush.Border}" Padding="6,4"
                                                     ToolTip="按 DisplayName / NodeId 模糊匹配，命中节点黄底高亮（不展开节点）"/>
                                            <TextBlock Text="{Binding OpcUaBrowserStatus}" Foreground="{DynamicResource Brush.TextMuted}" Margin="12,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" MinHeight="320">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.1*"/>
                                                    <ColumnDefinition Width="0.9*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Margin="12" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8">
                                                    <TreeView ItemsSource="{Binding OpcUaBrowserNodes}" Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderThickness="0" SelectedItemChanged="OpcUaBrowserTreeView_SelectedItemChanged">
                                                        <TreeView.ItemContainerStyle>
                                                            <Style TargetType="TreeViewItem">
                                                                <EventSetter Event="Expanded" Handler="OpcUaBrowserTreeViewItem_Expanded"/>
                                                                <Setter Property="Foreground" Value="#0F172A"/>
                                                                <!-- M17 搜索命中黄底高亮 -->
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSearchHit}" Value="True">
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TreeView.ItemContainerStyle>
                                                        <TreeView.Resources>
                                                            <HierarchicalDataTemplate DataType="{x:Type model:OpcUaBrowseNode}" ItemsSource="{Binding Children}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Brush.Text}"/>
                                                                    <TextBlock Text="  " />
                                                                    <TextBlock Text="{Binding NodeClass}" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                                </StackPanel>
                                                            </HierarchicalDataTemplate>
                                                        </TreeView.Resources>
                                                    </TreeView>
                                                </Border>
                                                <!-- M20 节点详情面板配色统一为浅色（之前白底白字看不清）-->
                                                <Border Grid.Column="1" Margin="0,12,12,12" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="12">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Grid.Row="0">
                                                            <TextBlock Text="节点详情" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,10"/>
                                                            <TextBlock Text="显示名" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaBrowseNode.DisplayName}" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                                            <TextBlock Text="NodeId" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaBrowseNode.NodeId}" Foreground="#1D4ED8" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                                            <TextBlock Text="节点类型" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaBrowseNode.NodeClass}" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,10"/>
                                                            <TextBlock Text="数据类型" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaBrowseNode.DataType}" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,10"/>
                                                            <TextBlock Text="当前值" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaNodeValue}" Foreground="#16A34A" FontWeight="SemiBold" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                                            <TextBlock Text="状态" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaNodeStatus}" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,10"/>
                                                            <TextBlock Text="时间戳" Foreground="{DynamicResource Brush.TextMuted}"/>
                                                            <TextBlock Text="{Binding SelectedOpcUaNodeTimestamp}" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,10"/>
                                                        </StackPanel>
                                                        <!-- M19 OPC UA 订阅 quality 变化日志 -->
                                                        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,8,0,0">
                                                            <DockPanel>
                                                                <TextBlock DockPanel.Dock="Top" Text="订阅 quality 日志（最近 50 条）" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" Margin="0,0,0,6"/>
                                                                <ListBox ItemsSource="{Binding OpcUaQualityLog}" Background="Transparent" BorderThickness="0"
                                                                         FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}"
                                                                         MaxHeight="120" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                                            </DockPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                                <Grid Visibility="{Binding IsMonitorProgramPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="240"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding SelectedFlowSummary}" Foreground="#93C5FD" Margin="0,0,0,8"/>
                                    <Border Grid.Row="1" Background="#0F172A" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Margin="0,0,0,10">
                                                <TextBlock Text="主流程步号 Trace" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock DockPanel.Dock="Right" Text="横轴：时间 / 纵轴：主流程步号" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                            </DockPanel>
                                            <Grid Grid.Row="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding ProgramMonitorTraceLatestText}" Foreground="#93C5FD" FontWeight="Bold"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ProgramMonitorTraceWindowText}" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                                </DockPanel>
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Margin="0,6,10,24">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding ProgramMonitorTraceAxisTopLabel}" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" VerticalAlignment="Top"/>
                                                        <TextBlock Grid.Row="1" Text="{Binding ProgramMonitorTraceAxisMidHighLabel}" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="2" Text="{Binding ProgramMonitorTraceAxisMidLowLabel}" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Row="3" Text="{Binding ProgramMonitorTraceAxisBottomLabel}" Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="11" VerticalAlignment="Bottom"/>
                                                    </Grid>
                                                    <Grid Grid.Column="1">
                                                        <Border x:Name="ProgramTraceChartHost"
                                                                Background="#111827"
                                                                CornerRadius="8"
                                                                MouseMove="ProgramTraceChartHost_MouseMove"
                                                                MouseLeave="ProgramTraceChartHost_MouseLeave"
                                                                MouseLeftButtonDown="ProgramTraceChartHost_MouseLeftButtonDown"
                                                                MouseLeftButtonUp="ProgramTraceChartHost_MouseLeftButtonUp"
                                                                MouseRightButtonDown="ProgramTraceChartHost_MouseRightButtonDown"
                                                                MouseWheel="ProgramTraceChartHost_MouseWheel">
                                                            <Grid Margin="12">
                                                                <Rectangle Fill="#111827" RadiusX="8" RadiusY="8"/>
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Border Grid.Row="0" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                    <Border Grid.Row="1" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                    <Border Grid.Row="2" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                    <Border Grid.Row="3" BorderBrush="#1F2937" BorderThickness="0,0,0,1"/>
                                                                </Grid>
                                                                <Path Data="{Binding ProgramMonitorMainFlowTracePath}" Stroke="#60A5FA" Style="{StaticResource SparklinePathStyle}" Visibility="{Binding ProgramMonitorTraceShowLine1, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <Path Data="{Binding ProgramMonitorSubFlow2TracePath}" Stroke="#F59E0B" Style="{StaticResource SparklinePathStyle}" Visibility="{Binding ProgramMonitorTraceShowLine2, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <Path Data="{Binding ProgramMonitorSubFlow3TracePath}" Stroke="#22C55E" Style="{StaticResource SparklinePathStyle}" Visibility="{Binding ProgramMonitorTraceShowLine3, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <Canvas>
                                                                    <Line x:Name="ProgramTraceHoverXLine" Visibility="Collapsed" Stroke="#64748B" StrokeThickness="1" StrokeDashArray="3,3" Y1="0" Y2="400"/>
                                                                    <Line x:Name="ProgramTraceHoverYLine" Visibility="Collapsed" Stroke="#64748B" StrokeThickness="1" StrokeDashArray="3,3" X1="0" X2="400"/>
                                                                    <Line x:Name="ProgramTraceCursorALine" Visibility="Collapsed" Stroke="#F59E0B" StrokeThickness="2" Y1="0" Y2="400"/>
                                                                    <Line x:Name="ProgramTraceCursorBLine" Visibility="Collapsed" Stroke="#22C55E" StrokeThickness="2" Y1="0" Y2="400"/>
                                                                    <Rectangle x:Name="ProgramTraceSelectionRect" Visibility="Collapsed" Fill="#60A5FA" Opacity="0.25" Stroke="#93C5FD" StrokeThickness="1"/>
                                                                </Canvas>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                            <Grid Grid.Row="2" Margin="44,10,0,0">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ProgramMonitorTraceStartLabel}" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ProgramMonitorTraceEndLabel}" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                                                    </Grid>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding ProgramMonitorCursorText}" Foreground="#CBD5E1"/>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                            <CheckBox Content="主线1" IsChecked="{Binding ProgramMonitorTraceShowLine1, Mode=TwoWay}" Foreground="#60A5FA" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                            <CheckBox Content="主线2" IsChecked="{Binding ProgramMonitorTraceShowLine2, Mode=TwoWay}" Foreground="#F59E0B" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                            <CheckBox Content="主线3" IsChecked="{Binding ProgramMonitorTraceShowLine3, Mode=TwoWay}" Foreground="#22C55E" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="光标跟随" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <ComboBox Width="90" ItemsSource="{Binding ProgramMonitorTraceFlowOptions}" SelectedItem="{Binding SelectedProgramMonitorTraceFlow, Mode=TwoWay}" Margin="0,0,16,0"/>
                                                            <TextBlock Text="Shift+左键拖拽缩放，双击复位" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                            <TextBlock Text="缩放" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <Slider Width="180" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ProgramMonitorTraceWindowMinutes, Mode=TwoWay}"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding ProgramMonitorCursorAText}" Foreground="#F59E0B" Margin="0,0,16,0"/>
                                                        <TextBlock Text="{Binding ProgramMonitorCursorBText}" Foreground="#22C55E" Margin="0,0,16,0"/>
                                                        <TextBlock Text="{Binding ProgramMonitorCursorDeltaText}" Foreground="#E2E8F0"/>
                                                    </DockPanel>
                                                    <DockPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{Binding ProgramMonitorTraceReplayText}" Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                                        <Button Content="暂停采样" Command="{Binding PauseProgramMonitorTraceCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="继续采样" Command="{Binding ResumeProgramMonitorTraceCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="历史回放" Command="{Binding EnterProgramMonitorTraceReplayCommand}" Background="#1D4ED8" Foreground="White" BorderBrush="#1D4ED8" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="回到实时" Command="{Binding ReturnProgramMonitorTraceToRealtimeCommand}" Background="#475569" Foreground="White" BorderBrush="#475569" Padding="10,4" Margin="0,0,16,0"/>
                                                        <Button Content="导出CSV" Command="{Binding ExportProgramMonitorTraceCsvCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,4" Margin="0,0,8,0"/>
                                                        <!-- M22 导出 trace 图为 PNG -->
                                                        <Button Content="导出PNG" Click="ExportProgramTracePng_Click" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,4" Margin="0,0,16,0"
                                                                ToolTip="把 trace 图当前可视区域保存为 PNG（便于汇报）"/>
                                                        <Button Content="保存会话" Command="{Binding SaveProgramMonitorTraceSessionCommand}" Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Padding="10,4" Margin="0,0,8,0"/>
                                                        <Button Content="加载会话" Command="{Binding LoadProgramMonitorTraceSessionCommand}" Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED" Padding="10,4" Margin="0,0,16,0"/>
                                                        <TextBlock Text="定位时间" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBox Width="120" Text="{Binding ProgramMonitorTraceLocateTime, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                                                        <Button Content="定位" Command="{Binding LocateProgramMonitorTraceTimeCommand}" Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED" Padding="10,4" Margin="0,0,16,0"/>
                                                        <TextBlock Text="回放" Foreground="{DynamicResource Brush.TextPlaceholder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <Slider Width="220" Minimum="0" Maximum="{Binding ProgramMonitorTraceReplayMaximum}" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ProgramMonitorTraceReplayPosition, Mode=TwoWay}" IsEnabled="{Binding HasProgramMonitorTraceHistory}"/>
                                                    </DockPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding FlowStepsView}" AutoGenerateColumns="False" IsReadOnly="True" Background="#111827" Foreground="White" BorderBrush="#1F2937" Margin="0,0,0,12" RowStyle="{StaticResource HighlightRowStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="流程" Binding="{Binding FlowName}" Width="*"/>
                                            <DataGridTextColumn Header="步号" Binding="{Binding StepNo}" Width="*"/>
                                            <DataGridTextColumn Header="开始" Binding="{Binding StartTime}" Width="*"/>
                                            <DataGridTextColumn Header="结束" Binding="{Binding EndTime}" Width="*"/>
                                            <DataGridTextColumn Header="耗时(s)" Binding="{Binding DurationSeconds}" Width="*"/>
                                            <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="*"/>
                                            <DataGridTextColumn Header="关联报警" Binding="{Binding RelatedAlarm}" Width="2*"/>
                                            <DataGridTemplateColumn Header="联动" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="看报警" Command="{Binding DataContext.JumpToAlarmByKeywordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding RelatedAlarm}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <WrapPanel Grid.Row="3" Margin="0,0,0,8"><TextBlock Text="流程异常统计汇总 / 排行榜" Foreground="#FCD34D" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/><Button Content="跳转报警页" Command="{Binding JumpToAlarmPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,8,0"/><Button Content="跳转审计页" Command="{Binding JumpToAuditPageCommand}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="10,6" Margin="0,0,8,0"/><Button Content="导出异常报告" Command="{Binding ExportFlowIssueReportCommand}" Background="#0F766E" Foreground="White" BorderBrush="#0F766E" Padding="10,6"/></WrapPanel>
                                    <DataGrid Grid.Row="4" ItemsSource="{Binding FlowIssueSummaries}" AutoGenerateColumns="False" IsReadOnly="True" Background="#111827" Foreground="White" BorderBrush="#1F2937" Height="150">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="*"/>
                                            <DataGridTextColumn Header="对象" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="指标" Binding="{Binding Metric}" Width="*"/>
                                            <DataGridTextColumn Header="结论" Binding="{Binding Conclusion}" Width="2*"/>
                                            <DataGridTemplateColumn Header="联动" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="看报警" Command="{Binding DataContext.JumpToAlarmByKeywordCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Name}" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,4"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
    </ScrollViewer>
</UserControl>
