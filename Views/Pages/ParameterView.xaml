<UserControl x:Class="ApexHMI.Views.Pages.ParameterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- P2: 分组 chip 折叠态视觉切换 -->
        <Style x:Key="CategoryChipStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="BorderBrush" Value="#93C5FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部信息卡 + 连接/加载/保存按钮 -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="当前角色：" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ShellViewModel.CurrentRoleText}" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="通讯状态：" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                        <Border Background="#DBEAFE" CornerRadius="12" Padding="12,4" Margin="8,0,0,0">
                            <TextBlock Text="{Binding ShellViewModel.CommunicationStatus}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="PLC / OPC UA 通讯参数通过独立配置窗口管理。"
                               Foreground="#64748B"
                               Margin="0,10,0,0"/>
                    <Button Content="打开 PLC 通讯配置"
                            Command="{Binding OpenCommunicationConfigCommand}"
                            Background="Transparent"
                            Foreground="#2563EB"
                            BorderBrush="{x:Null}"
                            Padding="0"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            Cursor="Hand"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="20,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button Content="连接"
                            Command="{Binding ConnectCommand}"
                            Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                            Width="90" Height="36" Margin="0,0,8,0"/>
                    <Button Content="断开"
                            Command="{Binding DisconnectCommand}"
                            Background="#DC2626" Foreground="White" BorderBrush="#DC2626"
                            Width="90" Height="36" Margin="0,0,8,0"/>
                    <Button Content="加载参数"
                            Command="{Binding LoadParametersCommand}"
                            Background="#374151" Foreground="White" BorderBrush="#374151"
                            Width="90" Height="36" Margin="0,0,8,0"/>
                    <!-- P7: 权限不足时按钮 disabled + tooltip -->
                    <Button Content="保存参数"
                            Command="{Binding SaveParametersCommand}"
                            IsEnabled="{Binding ShellViewModel.CanEditParameters}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            Width="90" Height="36"
                            ToolTip="工程师及以上角色可保存参数"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 工具栏：搜索 + 分组折叠 chips + 操作按钮 -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- P1 搜索框 -->
                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ShellViewModel.ParameterSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="28" FontSize="13"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CBD5E1" BorderThickness="1"
                         ToolTip="搜索 HMI 变量名 / PLC 变量值 / 说明"/>

                <!-- P2 分组折叠 chips：每个分组一个 ToggleButton，IsChecked=折叠态（灰），未选=展开态（蓝） -->
                <TextBlock Grid.Column="2" Text="折叠分组：" FontSize="13" FontWeight="SemiBold"
                           Foreground="#0F172A"
                           VerticalAlignment="Center" Margin="16,0,6,0"
                           ToolTip="点击下方分组按钮可隐藏 / 展开该分组下的所有参数行"/>
                <ItemsControl Grid.Column="3"
                              ItemsSource="{Binding ShellViewModel.ParameterCategoryChips}"
                              VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton IsChecked="{Binding IsCollapsed, Mode=TwoWay}"
                                          Content="{Binding Name}"
                                          Style="{StaticResource CategoryChipStyle}"
                                          ToolTip="点击折叠 / 展开该分组（折叠后该分组所有行被隐藏）"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 操作按钮组：查看修改 / 历史已合入按钮列 / 与配方对比 / 导出为配方 / 批量编辑 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="查看本次修改"
                            Command="{Binding ShellViewModel.ShowParameterDiffCommand}"
                            Background="#F59E0B" Foreground="White" BorderBrush="#F59E0B"
                            Padding="10,4" FontSize="12" Margin="6,0,0,0"
                            ToolTip="弹层显示当前会话所有 IsDirty 参数（旧值 → 新值）"/>
                    <Button Content="与配方对比"
                            Command="{Binding ShellViewModel.CompareParametersWithRecipeCommand}"
                            Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                            Padding="10,4" FontSize="12" Margin="6,0,0,0"
                            ToolTip="选择配方 → 高亮差异行 → 可一键应用配方到当前参数"/>
                    <Button Content="导出为配方"
                            Command="{Binding ShellViewModel.ExportParametersAsRecipeCommand}"
                            IsEnabled="{Binding ShellViewModel.CanEditParameters}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            Padding="10,4" FontSize="12" Margin="6,0,0,0"
                            ToolTip="把当前所有参数快照保存为新配方"/>
                    <Button Content="批量编辑"
                            x:Name="BatchEditButton"
                            Click="BatchEditButton_Click"
                            IsEnabled="{Binding ShellViewModel.CanEditParameters}"
                            Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                            Padding="10,4" FontSize="12" Margin="6,0,0,0"
                            ToolTip="先在表中多选行（Ctrl/Shift+点击），再点此按钮统一改值"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主表格 -->
        <DataGrid x:Name="ParameterGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding ParametersView}"
                  AutoGenerateColumns="False"
                  Background="#FFFFFF"
                  Foreground="#0F172A"
                  BorderBrush="#D7DFEA"
                  BorderThickness="1"
                  RowBackground="#FFFFFF"
                  AlternatingRowBackground="#F8FAFC"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowStyle="{StaticResource ParameterRowStyle}"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CanUserSortColumns="False"
                  CanUserResizeRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#EEF2F7"/>
                    <Setter Property="Foreground" Value="#334155"/>
                    <Setter Property="BorderBrush" Value="#D7DFEA"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="#0F172A"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="#0F172A"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="分组" Binding="{Binding Category}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="HMI变量" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                <!-- P3/P8: PLC变量编辑列；TextBox 校验失败时红边框 + tooltip -->
                <DataGridTemplateColumn Header="PLC变量" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="#0F172A" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsReadOnly}"
                                     ToolTip="{Binding ValidationError}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DataGridEditTextBoxStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasValidationError}" Value="True">
                                                <Setter Property="BorderBrush" Value="#DC2626"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <!-- P8: 限值列（只读） -->
                <DataGridTextColumn Header="范围" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} ~ {1}">
                            <Binding Path="MinValue"/>
                            <Binding Path="MaxValue"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/>
                <DataGridTextColumn Header="最小权限" Binding="{Binding MinRole}" Width="*" IsReadOnly="True"/>
                <!-- P7: 编辑状态用 PermissionHint 文本 + tooltip 给出明确角色要求 -->
                <DataGridTemplateColumn Header="编辑状态" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding PermissionHint}"
                                       VerticalAlignment="Center"
                                       ToolTip="{Binding PermissionHint}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- P5: 历史按钮列 -->
                <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="历史"
                                    FontSize="11" Padding="6,2" Height="22"
                                    Background="Transparent" BorderBrush="#CBD5E1" Foreground="#475569"
                                    Command="{Binding DataContext.ShellViewModel.ShowParameterHistoryCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="查看该参数最近 10 次变更"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
