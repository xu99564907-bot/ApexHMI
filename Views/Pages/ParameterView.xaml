<UserControl x:Class="ApexHMI.Views.Pages.ParameterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="16"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="当前角色：" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ShellViewModel.CurrentRoleText}" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="通讯状态：" FontSize="16" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Border Background="#DBEAFE" CornerRadius="12" Padding="12,4" Margin="8,0,0,0">
                                <TextBlock Text="{Binding ShellViewModel.CommunicationStatus}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="PLC / OPC UA 通讯参数通过独立配置窗口管理。"
                                   Foreground="#64748B"
                                   Margin="0,10,0,0"/>
                        <Button Content="打开 PLC 通讯配置"
                                Command="{Binding OpenCommunicationConfigCommand}"
                                Background="Transparent"
                                Foreground="#2563EB"
                                BorderBrush="{x:Null}"
                                Padding="0"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left"
                                Cursor="Hand"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="20,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <Button Content="连接"
                                Command="{Binding ConnectCommand}"
                                Background="#2563EB"
                                Foreground="White"
                                BorderBrush="#2563EB"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"/>
                        <Button Content="断开"
                                Command="{Binding DisconnectCommand}"
                                Background="#DC2626"
                                Foreground="White"
                                BorderBrush="#DC2626"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"/>
                        <Button Content="加载参数"
                                Command="{Binding LoadParametersCommand}"
                                Background="#374151"
                                Foreground="White"
                                BorderBrush="#374151"
                                Width="100"
                                Height="36"
                                Margin="0,0,8,0"/>
                        <Button Content="保存参数"
                                Command="{Binding SaveParametersCommand}"
                                Background="#0F766E"
                                Foreground="White"
                                BorderBrush="#0F766E"
                                Width="100"
                                Height="36"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ParametersView}"
                      AutoGenerateColumns="False"
                      Background="#FFFFFF"
                      Foreground="#0F172A"
                      BorderBrush="#D7DFEA"
                      BorderThickness="1"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="#F8FAFC"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowStyle="{StaticResource ParameterRowStyle}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      CanUserSortColumns="False"
                      CanUserResizeRows="False">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#EEF2F7"/>
                        <Setter Property="Foreground" Value="#334155"/>
                        <Setter Property="BorderBrush" Value="#D7DFEA"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="8,6"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="分组" Binding="{Binding Category}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="HMI变量" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="PLC变量" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" VerticalAlignment="Center" Foreground="#0F172A" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsReadOnly}"
                                         Style="{StaticResource DataGridEditTextBoxStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="绑定方向" Binding="{Binding Unit}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="最小权限" Binding="{Binding MinRole}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="编辑状态" Binding="{Binding PermissionHint}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </ScrollViewer>
</UserControl>
