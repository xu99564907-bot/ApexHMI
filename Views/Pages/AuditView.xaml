<UserControl x:Class="ApexHMI.Views.Pages.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,10">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="操作履历审计" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text="记录登录、确认框、联锁拦截、设备操作、弹窗提示等行为。"
                               Foreground="{DynamicResource Brush.TextMuted}" Margin="0,8,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="导出 PDF 报表"
                            Command="{Binding ExportAuditPdfCommand}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            Padding="14,8" Margin="0,0,8,0"
                            ToolTip="AU4: 导出当前筛选结果为 HTML（浏览器 Ctrl+P → 另存为 PDF）/ CSV"/>
                    <Button Content="归档 6 月前履历"
                            Command="{Binding ArchiveOldAuditsCommand}"
                            Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                            Padding="14,8"
                            ToolTip="AU8: 把 6 个月前的记录写入 audit-archive/*.zip 并从内存移除"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- AU1/AU2/AU3/AU6 过滤工具栏 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="12,8" Margin="0,0,0,10">
            <WrapPanel>
                <TextBlock Text="时间：" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="100" Height="26" Margin="0,0,12,0"
                          ItemsSource="{Binding TimeRangeOptions}"
                          SelectedItem="{Binding SelectedTimeRange}"/>
                <TextBlock Text="用户：" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="120" Height="26" Margin="0,0,12,0"
                          ItemsSource="{Binding UserOptions}"
                          SelectedItem="{Binding SelectedUser}"/>
                <TextBlock Text="分类：" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Width="120" Height="26" Margin="0,0,12,0"
                          ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding SelectedCategory}"/>
                <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="240" Height="26" Margin="0,0,12,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="AU3: 在 动作 / 目标 / 详情 / 用户 中模糊搜索"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding AuditView}"
                  SelectedItem="{Binding SelectedAudit, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{DynamicResource Brush.BorderSoft}"
                  RowBackground="#FFFFFF" AlternatingRowBackground="#F8FAFC"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="*"/>
                <DataGridTextColumn Header="用户" Binding="{Binding User}" Width="*"/>
                <!-- AU6: 分类标签 -->
                <DataGridTemplateColumn Header="分类" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="#DBEAFE" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Category}" Foreground="#1D4ED8" FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="*"/>
                <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="*"/>
                <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="*"/>
                <!-- AU7: 详情截断 + 悬停 tooltip 显示完整内容 -->
                <DataGridTemplateColumn Header="详情" Width="3*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Detail}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Detail}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- AU5: 看事件链 -->
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="事件链"
                                    Command="{Binding DataContext.ShowEventChainCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderBrush="#CBD5E1" Foreground="{DynamicResource Brush.TextSecondary}"
                                    FontSize="11" Padding="6,2" Height="22"
                                    ToolTip="AU5: 按 Target 关键字串联审计 + 报警历史"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
