<UserControl x:Class="ApexHMI.Views.Pages.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="操作履历审计" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="记录登录、确认框、联锁拦截、设备操作、弹窗提示等行为。" Foreground="#94A3B8" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding OperationAudits}"
                      AutoGenerateColumns="False"
                      Background="#111827"
                      Foreground="White"
                      BorderBrush="#1F2937">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="*"/>
                    <DataGridTextColumn Header="用户" Binding="{Binding User}" Width="*"/>
                    <DataGridTextColumn Header="动作" Binding="{Binding Action}" Width="*"/>
                    <DataGridTextColumn Header="目标" Binding="{Binding Target}" Width="*"/>
                    <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="*"/>
                    <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </ScrollViewer>
</UserControl>
