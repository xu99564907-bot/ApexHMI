<UserControl x:Class="ApexHMI.Views.Pages.CountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: 数据源切换 + 今日 / 白班 / 夜班 大数字卡 -->
            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="生产计数" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="数据源" Foreground="#64748B" Margin="0,12,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="总计数" Command="{Binding SwitchSourceCommand}" CommandParameter="Total"
                                    Width="84" Height="34" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSource}" Value="Total">
                                                <Setter Property="Background" Value="#2563EB"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#1D4ED8"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="OK" Command="{Binding SwitchSourceCommand}" CommandParameter="OK"
                                    Width="72" Height="34" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSource}" Value="OK">
                                                <Setter Property="Background" Value="#16A34A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#15803D"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="NG" Command="{Binding SwitchSourceCommand}" CommandParameter="NG"
                                    Width="72" Height="34">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Setter Property="Foreground" Value="#0F172A"/>
                                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSource}" Value="NG">
                                                <Setter Property="Background" Value="#DC2626"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#B91C1C"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- 今日 / 白班 / 夜班 三张大卡 -->
                    <Grid Grid.Column="1" Margin="24,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                CornerRadius="10" Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="今日合计" Foreground="#1D4ED8" FontSize="13"/>
                                <TextBlock Text="{Binding TodayTotal}" Foreground="#1D4ED8"
                                           FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#FEF9C3" BorderBrush="#FDE68A" BorderThickness="1"
                                CornerRadius="10" Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="白班" Foreground="#92400E" FontSize="13"/>
                                <TextBlock Text="{Binding DayTotal}" Foreground="#92400E"
                                           FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#EDE9FE" BorderBrush="#C4B5FD" BorderThickness="1"
                                CornerRadius="10" Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="夜班" Foreground="#5B21B6" FontSize="13"/>
                                <TextBlock Text="{Binding NightTotal}" Foreground="#5B21B6"
                                           FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Row 1: 提示 -->
            <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="6" Padding="10,6" Margin="0,0,0,12">
                <TextBlock Text="数据来自 SQLite 计数账本（config/production.db）。PLC 端只暴露累计计数，分时 / 班次 / 历史均由 HMI 用差值法计算。"
                           Foreground="#475569" FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Row 2: 分时 24 行 + 31 天历史 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="今日分时（按白班开始时间归桶）"
                                   FontSize="15" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Hours}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  MinHeight="500">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60"/>
                                <DataGridTextColumn Header="时段" Binding="{Binding TimeRangeText}" Width="*"/>
                                <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="12" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="最近 31 天历史"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#0F172A"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="刷新"
                                    Command="{Binding RefreshNowCommand}"
                                    Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1"
                                    Padding="10,4" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding History}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  MinHeight="500">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="*"/>
                                <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
