<UserControl x:Class="ApexHMI.Views.Pages.DesignerEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ApexHMI.ViewModels.Modules"
             xmlns:model="clr-namespace:ApexHMI.Models.RuntimeUi"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 横向工具箱 + 右侧紧凑动作组 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="10,8" Margin="0,0,0,10">
            <DockPanel>
                <!-- 右侧动作 / 状态 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <!-- PLC 变量表导入状态 -->
                    <Border Background="#0369A1" CornerRadius="12" Padding="8,3"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlcVariableStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding PlcVariableStatus}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="11"
                                   ToolTip="{Binding PlcVariableFilePath}"/>
                    </Border>
                    <Border Background="#10B981" CornerRadius="12" Padding="8,3"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SaveStatus}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="11"/>
                    </Border>
                    <!-- 紧凑图标按钮组 -->
                    <Button Command="{Binding ReloadPlcVariablesCommand}"
                            Background="#0EA5E9" Foreground="White" BorderBrush="#0EA5E9"
                            Padding="8,5" Margin="0,0,4,0"
                            ToolTip="从 PLC 程序保存目录加载 Device.Application.xml 变量表">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseImport" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="PLC 变量" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding BrowsePlcVariableFileCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,8,0"
                            ToolTip="手动选择 Device.Application.xml 文件">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14"/>
                    </Button>
                    <Button Command="{Binding PreviewCommand}"
                            Background="#0EA5E9" Foreground="White" BorderBrush="#0EA5E9"
                            Padding="8,5" Margin="0,0,4,0"
                            ToolTip="预览：保存并在运行视图中查看当前页面">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Eye" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="预览" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveCommand}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            Padding="8,5" Margin="0,0,4,0"
                            ToolTip="保存工程 (Ctrl+S)">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="保存" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PublishCommand}"
                            Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                            Padding="8,5"
                            ToolTip="发布到运行时：保存并刷新运行时页面">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Rocket" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="发布" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 横向工具箱（按分组） -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ToolboxItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Text="{Binding Title}" FontSize="10" Foreground="{DynamicResource Brush.TextMuted}" Margin="2,0,0,3"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,4,0" Padding="8,5"
                                                        Background="#F8FAFC" Foreground="#334155"
                                                        BorderBrush="{DynamicResource Brush.Border}" FontWeight="Normal"
                                                        Command="{Binding DataContext.AddWidgetCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding TypeId}"
                                                        ToolTip="{Binding TypeId}"
                                                        PreviewMouseLeftButtonDown="ToolboxItem_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="ToolboxItem_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="ToolboxItem_PreviewMouseLeftButtonUp">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="{Binding IconKind, FallbackValue=Widgets}"
                                                                                Width="16" Height="16"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#2563EB"
                                                                                Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Row 1: 三栏布局 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左栏：页面树 + 工具箱 ===== -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 工程名称 -->
                        <TextBlock Text="工程名称" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBox Text="{Binding Document.ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>

                        <!-- P3.1 模板页 RouteKey -->
                        <TextBlock Text="模板页 RouteKey (页眉/页脚共享)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding Document.Pages}"
                                  DisplayMemberPath="Title" SelectedValuePath="RouteKey"
                                  SelectedValue="{Binding Document.TemplatePageRouteKey}"
                                  IsEditable="True" Margin="0,4,0,10" FontSize="12"
                                  ToolTip="选一个页面作为全局模板;留空 = 无模板"/>

                        <!-- 页面下拉框 -->
                        <TextBlock Text="当前页面" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Document.Pages}"
                                  SelectedItem="{Binding SelectedPage}"
                                  DisplayMemberPath="Title"
                                  BorderBrush="{DynamicResource Brush.Border}"
                                  Background="#FFFFFF"
                                  Margin="0,0,0,8"/>

                        <!-- 新建页面 -->
                        <Border Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                CornerRadius="6" Padding="8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="新建页面" Foreground="{DynamicResource Brush.Text}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="标题 (留空 = 自动)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" Margin="0,6,0,2"/>
                                <TextBox Text="{Binding NewPageTitle, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"/>
                                <TextBlock Text="挂到父页面 (软件固定画面;留空 = 顶层)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" Margin="0,6,0,2"/>
                                <ComboBox ItemsSource="{Binding BuiltInParentSections}"
                                          SelectedValue="{Binding NewPageParentRouteKey, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="False" FontSize="12"
                                          ToolTip="选择软件内置的固定父画面（如 主界面/手动操作/报警画面 等）"/>
                                <Button Content="+ 新建页面" Command="{Binding AddPageCommand}"
                                        Background="#374151" Foreground="White" BorderBrush="#374151"
                                        Padding="10,6" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Button Content="🗑 删除当前页面" Command="{Binding RemovePageCommand}"
                                Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                Padding="10,6" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                        <!-- 当前页面属性 -->
                        <TextBlock Text="页面设置" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                        <TextBlock Text="页面标题" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBox Text="{Binding SelectedPage.Title, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>
                        <TextBlock Text="路由键" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBox Text="{Binding SelectedPage.RouteKey, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>
                        <TextBlock Text="父页面 (软件固定画面;留空 = 顶层)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding BuiltInParentSections}"
                                  SelectedValue="{Binding SelectedPage.ParentRouteKey, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="False" Margin="0,4,0,8" FontSize="12"
                                  ToolTip="把当前页挂到软件内置固定画面之下;留空表示独立顶层页"/>
                        <TextBlock Text="画布尺寸" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <UniformGrid Columns="2" Margin="0,4,0,10">
                            <TextBox Text="{Binding SelectedPage.CanvasWidth, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,6,0"/>
                            <TextBox Text="{Binding SelectedPage.CanvasHeight, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="6,0,0,0"/>
                        </UniformGrid>

                        <!-- 主导航 -->
                        <CheckBox Content="挂到主导航顶栏" IsChecked="{Binding SelectedPage.ShowInTopNav}"
                                  Margin="0,0,0,6" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                        <TextBlock Text="导航图标 (MaterialDesign Kind, 如 ViewDashboard)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <TextBox Text="{Binding SelectedPage.NavIcon, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,6" FontSize="12"/>
                        <TextBlock Text="导航排序 (数字越小越靠前)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <TextBox Text="{Binding SelectedPage.NavOrder, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,10" FontSize="12"/>

                        <!-- 批量生成功能块 -->
                        <Border Margin="0,16,0,0" Padding="10" CornerRadius="8"
                                Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="批量生成功能块" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#0369A1" Margin="0,0,0,8"/>

                                <TextBlock Text="功能块类型" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding BatchBlockTypes}"
                                          SelectedValue="{Binding BatchBlockType}"
                                          Margin="0,4,0,8" FontSize="12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}">
                                                        <Binding/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="命名前缀（如 CYL → CYL1, CYL2…）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                <TextBox Text="{Binding BatchNamePrefix, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,8" FontSize="12"/>

                                <TextBlock Text="数量（1-20）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                <TextBox Text="{Binding BatchCount, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,8" FontSize="12"/>

                                <TextBlock Text="起始位置 (X, Y)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12"/>
                                <UniformGrid Columns="2" Margin="0,4,0,8">
                                    <TextBox Text="{Binding BatchStartX, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,4,0" FontSize="12"/>
                                    <TextBox Text="{Binding BatchStartY, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="4,0,0,0" FontSize="12"/>
                                </UniformGrid>

                                <CheckBox Content="水平排列（取消则垂直）"
                                          IsChecked="{Binding BatchLayoutHorizontal}"
                                          Margin="0,0,0,10" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}"/>

                                <Button Content="批量生成" Command="{Binding BatchGenerateCommand}"
                                        Background="#0369A1" Foreground="White" BorderBrush="#0369A1"
                                        Padding="10,8" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== 中栏：设计画布 ===== -->
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,10">
                        <DockPanel>
                            <TextBlock Text="设计画布" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <CheckBox Content="网格" IsChecked="{Binding ShowGrid}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <CheckBox Content="吸附" IsChecked="{Binding SnapToGrid}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="间距" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Text="{Binding GridSize, UpdateSourceTrigger=PropertyChanged}" Width="44" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding MouseCoord, StringFormat=({0})}" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding CurrentWidgets.Count, Mode=OneWay, StringFormat=控件数: {0}}"
                                           Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <!-- 对齐工具栏：多选时显示 -->
                        <WrapPanel Margin="0,8,0,0"
                                   Visibility="{Binding HasMultiSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="◧ 左对齐"   Command="{Binding AlignLeftCommand}"   Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="◨ 右对齐"   Command="{Binding AlignRightCommand}"  Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="⊤ 顶对齐"   Command="{Binding AlignTopCommand}"    Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="⊥ 底对齐"   Command="{Binding AlignBottomCommand}" Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↔ 横向均布" Command="{Binding DistributeHorizontalCommand}" Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↕ 纵向均布" Command="{Binding DistributeVerticalCommand}"   Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↔ 等宽"     Command="{Binding SameWidthCommand}"   Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↕ 等高"     Command="{Binding SameHeightCommand}"  Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="🗑 删除"    Command="{Binding DeleteSelectedWidgetsCommand}"
                                    Padding="8,4" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"/>
                        </WrapPanel>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="DesignerCanvas"
                                Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}"
                                Background="#FFFFFF"
                                ClipToBounds="True"
                                AllowDrop="True"
                                MouseMove="DesignerCanvas_MouseMoveCoord"
                                MouseLeftButtonDown="DesignerCanvas_BackgroundClick"
                                MouseLeftButtonUp="DesignerCanvas_BackgroundMouseUp"
                                DragOver="DesignerCanvas_DragOver"
                                Drop="DesignerCanvas_Drop">
                            <!-- 网格背景层 -->
                            <Rectangle Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                       Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ShowGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Rectangle.Fill>
                                    <DrawingBrush TileMode="Tile" Stretch="None"
                                                  Viewport="0,0,8,8" ViewportUnits="Absolute"
                                                  Viewbox="0,0,8,8"  ViewboxUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <RectangleGeometry Rect="0,0,8,1"/>
                                                        <RectangleGeometry Rect="0,0,1,8"/>
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                                <GeometryDrawing.Brush>
                                                    <SolidColorBrush Color="#CBD5E1" Opacity="0.4"/>
                                                </GeometryDrawing.Brush>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <!-- 框选矩形可视化 -->
                            <Rectangle Canvas.Left="{Binding MarqueeX}" Canvas.Top="{Binding MarqueeY}"
                                       Width="{Binding MarqueeWidth}" Height="{Binding MarqueeHeight}"
                                       Stroke="#3B82F6" StrokeThickness="1" StrokeDashArray="4,2"
                                       Fill="#3B82F6" Opacity="0.15"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding IsMarqueeActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Panel.ZIndex="1000"/>
                            <ListBox ItemsSource="{Binding CurrentWidgetItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                     Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}">
                                <ListBox.Template>
                                    <ControlTemplate TargetType="ListBox">
                                        <ItemsPresenter/>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Canvas.Left" Value="{Binding Model.X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Model.Y}"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:DesignerWidgetItem}">
                                        <!-- 外层 Grid 控制 widget 占位尺寸；包含选中层 + 8 个尺寸调整手柄 -->
                                        <Grid Width="{Binding Model.Width}" Height="{Binding Model.Height}">
                                            <!-- 选中层 Border：捕获鼠标 + 显示选中边框，内部为预创建的真容视图 -->
                                            <Border Cursor="Hand"
                                                    Background="Transparent"
                                                    MouseLeftButtonDown="Widget_MouseLeftButtonDown"
                                                    MouseMove="Widget_MouseMove"
                                                    MouseLeftButtonUp="Widget_MouseLeftButtonUp">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ContentPresenter Content="{Binding View}"/>
                                            </Border>

                                            <!-- 8 个尺寸调整手柄：仅选中时显示 -->
                                            <Grid Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.Resources>
                                                    <Style x:Key="ResizeHandleStyle" TargetType="Rectangle">
                                                        <Setter Property="Width" Value="8"/>
                                                        <Setter Property="Height" Value="8"/>
                                                        <Setter Property="Fill" Value="#FFFFFF"/>
                                                        <Setter Property="Stroke" Value="#F59E0B"/>
                                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                                    </Style>
                                                </Grid.Resources>
                                                <Rectangle Tag="NW" Cursor="SizeNWSE" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Left"   VerticalAlignment="Top"    Margin="-4,-4,0,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="N"  Cursor="SizeNS"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="0,-4,0,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="NE" Cursor="SizeNESW" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Right"  VerticalAlignment="Top"    Margin="0,-4,-4,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="E"  Cursor="SizeWE"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Right"  VerticalAlignment="Center" Margin="0,0,-4,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="SE" Cursor="SizeNWSE" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Right"  VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="S"  Cursor="SizeNS"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-4"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="SW" Cursor="SizeNESW" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Left"   VerticalAlignment="Bottom" Margin="-4,0,0,-4"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="W"  Cursor="SizeWE"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Left"   VerticalAlignment="Center" Margin="-4,0,0,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ===== 右栏：属性编辑器 ===== -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="属性编辑器" FontSize="18" FontWeight="Bold" 
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,12"/>

                        <!-- 未选中控件时的提示 -->
                        <TextBlock Text="请从画布中选中一个控件"
                                   Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="13"
                                   Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>

                        <!-- 控件基本信息 -->
                        <StackPanel Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}}">
                            <WrapPanel Margin="0,0,0,8">
                                <Button Content="🗑 删除" Command="{Binding RemoveSelectedWidgetCommand}"
                                        Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                        Padding="10,4" Margin="0,0,6,6"/>
                                <TextBlock Text="{Binding SelectedWidget.TypeId}" Foreground="{DynamicResource Brush.TextMuted}"
                                           VerticalAlignment="Center" FontSize="11"/>
                            </WrapPanel>

                            <!-- 几何 -->
                            <Expander Header="几何" IsExpanded="True" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="位置 (X, Y)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <UniformGrid Columns="2" Margin="0,4,0,6">
                                        <TextBox Text="{Binding SelectedWidget.X, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding SelectedWidget.Y, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                    </UniformGrid>
                                    <TextBlock Text="尺寸 (宽, 高)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <UniformGrid Columns="2" Margin="0,4,0,2">
                                        <TextBox Text="{Binding SelectedWidget.Width, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding SelectedWidget.Height, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Expander>

                            <!-- 外观 / 控件属性 -->
                            <Expander Header="外观 / 属性" IsExpanded="True" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                            <ItemsControl ItemsSource="{Binding CurrentWidgetProperties}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="92"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       ToolTip="{Binding Key}"/>
                                            <!-- 普通属性：TextBox -->
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDeviceNameProp}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <!-- deviceName 属性：下拉框（自动列出真实设备） -->
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.AvailableDeviceNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                      IsEditable="True" IsTextSearchEnabled="True"
                                                      VerticalAlignment="Center"
                                                      ToolTip="选择设备；列表为空时可手动输入设备名">
                                                <ComboBox.Style>
                                                    <Style TargetType="ComboBox">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDeviceNameProp}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ComboBox.Style>
                                            </ComboBox>
                                            <!-- 颜色属性显示色板预览 -->
                                            <Border Grid.Column="2"
                                                    Width="22" Height="22" CornerRadius="4"
                                                    Margin="6,0,0,0" BorderBrush="#CBD5E1" BorderThickness="1"
                                                    Visibility="{Binding IsColorProperty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Background="{Binding Value, Converter={StaticResource StringToBrushConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <!-- 数据绑定 -->
                            <Expander Header="数据绑定" IsExpanded="True" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="绑定 Tag" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <DockPanel Margin="0,4,0,4">
                                        <Button DockPanel.Dock="Right" Content="🔍"
                                                Command="{Binding OpenTagBrowserCommand}"
                                                Padding="6,0" Margin="4,0,0,0"
                                                ToolTip="打开 Tag 浏览器"/>
                                        <ComboBox ItemsSource="{Binding AvailableTags}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Name"
                                                  SelectedValue="{Binding CurrentBindingTagId, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="False"
                                                  ToolTip="选择要绑定的 OPC UA Tag，留空取消绑定"/>
                                    </DockPanel>
                                </StackPanel>
                            </Expander>

                            <!-- 事件 / 动作 -->
                            <Expander Header="事件 / 动作" IsExpanded="True" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="点击动作" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <ComboBox Margin="0,4,0,4"
                                              SelectedValue="{Binding SelectedWidget.ActionType, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Content="无"/>
                                        <ComboBoxItem Content="write-bool"/>
                                        <ComboBoxItem Content="write-int"/>
                                        <ComboBoxItem Content="write-float"/>
                                        <ComboBoxItem Content="navigate"/>
                                        <ComboBoxItem Content="show-dialog"/>
                                    </ComboBox>
                                    <TextBlock Text="动作参数" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedWidget.ActionParam, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,4"
                                             ToolTip="write-bool: TagName|True/False; navigate: 目标 RouteKey"/>
                                </StackPanel>
                            </Expander>

                            <!-- 状态动画 -->
                            <Expander Header="状态动画" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <Button Content="+ 添加动画" Command="{Binding AddAnimationCommand}"
                                            Padding="8,4" Margin="0,0,0,6" HorizontalAlignment="Left"
                                            Background="#0EA5E9" Foreground="White" BorderBrush="#0EA5E9"/>
                                    <ItemsControl ItemsSource="{Binding CurrentAnimations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                                        CornerRadius="4" Padding="6" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,4">
                                                            <Button DockPanel.Dock="Right" Content="✕"
                                                                    Command="{Binding DataContext.RemoveAnimationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Padding="6,0" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"/>
                                                            <TextBlock Text="动画规则" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Tag" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" FontSize="11"/>
                                                            <TextBox Grid.Column="1" Text="{Binding TagId, UpdateSourceTrigger=PropertyChanged}" FontSize="11"/>
                                                        </Grid>
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="条件" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" FontSize="11"/>
                                                            <ComboBox Grid.Column="1" Text="{Binding Op, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" FontSize="11" Margin="0,0,4,0">
                                                                <ComboBoxItem>true</ComboBoxItem>
                                                                <ComboBoxItem>false</ComboBoxItem>
                                                                <ComboBoxItem>eq</ComboBoxItem>
                                                                <ComboBoxItem>ne</ComboBoxItem>
                                                                <ComboBoxItem>gt</ComboBoxItem>
                                                                <ComboBoxItem>lt</ComboBoxItem>
                                                                <ComboBoxItem>gte</ComboBoxItem>
                                                                <ComboBoxItem>lte</ComboBoxItem>
                                                            </ComboBox>
                                                            <TextBox Grid.Column="2" Text="{Binding CompareTo, UpdateSourceTrigger=PropertyChanged}" FontSize="11" ToolTip="对比值（true/false 时忽略）"/>
                                                        </Grid>
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="设置" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" FontSize="11"/>
                                                            <TextBox Grid.Column="1" Text="{Binding TargetProperty, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,0,4,0" ToolTip="属性 key (如 background)"/>
                                                            <TextBox Grid.Column="2" Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}" FontSize="11" ToolTip="目标值"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <!-- 安全 -->
                            <Expander Header="安全 / 权限" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="所需角色 (留空 = 所有人)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <ComboBox Margin="0,4,0,4"
                                              Text="{Binding SelectedWidget.RequiredRole, UpdateSourceTrigger=LostFocus}"
                                              IsEditable="True">
                                        <ComboBoxItem Content=""/>
                                        <ComboBoxItem Content="Operator"/>
                                        <ComboBoxItem Content="Engineer"/>
                                        <ComboBoxItem Content="Administrator"/>
                                    </ComboBox>
                                </StackPanel>
                            </Expander>

                            <!-- 控件 ID（折叠默认） -->
                            <Expander Header="高级 / ID" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="控件 ID" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedWidget.Id, Mode=OneWay}" IsReadOnly="True"
                                             Background="#F1F5F9" Margin="0,4,0,0" FontFamily="Consolas" FontSize="11"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
