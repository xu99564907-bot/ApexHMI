<UserControl x:Class="ApexHMI.Views.Pages.DesignerEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ApexHMI.ViewModels.Modules"
             xmlns:model="clr-namespace:ApexHMI.Models.RuntimeUi"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:b="clr-namespace:ApexHMI.Behaviors"
             xmlns:propEditors="clr-namespace:ApexHMI.Views.Controls.PropertyEditors"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="720" d:DesignWidth="1280">
    <UserControl.Resources>
        <!-- P7C: Faceplate 接口属性类型枚举（用于 ComboBox.ItemsSource） -->
        <ObjectDataProvider x:Key="FaceplatePropertyTypes"
                            MethodName="GetValues"
                            ObjectType="{x:Type system:Enum}"
                            xmlns:system="clr-namespace:System;assembly=mscorlib">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:FaceplatePropertyType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <!-- P7.5: Schema-driven 属性编辑器模板选择器 -->
        <propEditors:PropertyEditorTemplateSelector x:Key="PropEditorSelector"/>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 横向工具箱 + 右侧紧凑动作组 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="10,8" Margin="0,0,0,10">
            <DockPanel>
                <!-- 顶部动作 / 状态（独占一行，避免被工具箱拉高） -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <!-- PLC 变量表导入状态 -->
                    <Border Background="#0369A1" CornerRadius="12" Padding="8,3"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PlcVariableStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding PlcVariableStatus}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="11"
                                   ToolTip="{Binding PlcVariableFilePath}"/>
                    </Border>
                    <Border Background="#10B981" CornerRadius="12" Padding="8,3"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SaveStatus}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="11"/>
                    </Border>
                    <!-- 紧凑图标按钮组 -->
                    <Button Command="{Binding ReloadPlcVariablesCommand}"
                            Background="#0EA5E9" Foreground="White" BorderBrush="#0EA5E9"
                            Padding="8,5" Margin="0,0,4,0"
                            ToolTip="从 PLC 程序保存目录加载 Device.Application.xml 变量表">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseImport" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="PLC 变量" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding BrowsePlcVariableFileCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,8,0"
                            ToolTip="手动选择 Device.Application.xml 文件">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14"/>
                    </Button>
                    <!-- P6A: 全局样式编辑入口 -->
                    <Button Command="{Binding OpenStyleEditorCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="全局样式：色板 + 字体预设（P6A）">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Palette" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="样式" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- P6C: 把当前选中控件存入项目库 / 全局库 -->
                    <Button Command="{Binding SaveSelectedToProjectLibraryCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="把当前选中的控件保存到项目库（P6C）">
                        <materialDesign:PackIcon Kind="BookmarkPlus" Width="14" Height="14"/>
                    </Button>
                    <Button Command="{Binding SaveSelectedToGlobalLibraryCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="把当前选中的控件保存到全局库，跨工程共享（P6C）">
                        <materialDesign:PackIcon Kind="EarthPlus" Width="14" Height="14"/>
                    </Button>
                    <!-- P6B: 多语言文本资源 + 当前语言切换 -->
                    <Button Command="{Binding OpenTextEditorCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="多语言文本资源（P6B）">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Translate" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="文本" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding CurrentLanguage, UpdateSourceTrigger=PropertyChanged}"
                              MinWidth="80" Margin="0,0,8,0" VerticalAlignment="Center"
                              ToolTip="当前显示语言（切换后所有 {text:...} 引用刷新）"/>
                    <!-- P6E: 列表资源编辑入口 -->
                    <Button Command="{Binding OpenListEditorCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="文本列表 / 图形列表资源（P6E）">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FormatListBulleted" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="列表" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- P7C: Faceplate 编辑模式切换 -->
                    <ToggleButton IsChecked="{Binding IsFaceplateEditMode}"
                                  Padding="6,4" Margin="0,0,4,0"
                                  ToolTip="切换到 Faceplate 编辑模式：复用画布编辑 Faceplate 的内部画面与接口属性">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewModule" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Faceplate" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </ToggleButton>
                    <!-- P10D: 导出 / 导入 zip 包 -->
                    <Button Command="{Binding ExportProjectZipCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="导出工程为 zip 包（P10D）">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageDown" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="导出" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ImportProjectZipCommand}"
                            Background="#E2E8F0" Foreground="{DynamicResource Brush.Text}" BorderBrush="#CBD5E1"
                            Padding="6,5" Margin="0,0,4,0"
                            ToolTip="从 zip 包导入工程（覆盖当前工程）（P10D）">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PackageUp" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="导入" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <!-- P10F: 离线模拟模式 -->
                    <ToggleButton IsChecked="{Binding DataContext.IsSimulationMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                  Padding="6,4" Margin="0,0,4,0"
                                  ToolTip="离线模拟模式：SimTag1..5/SimBool1..3/SimText1 注入假数据（P10F）">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SineWave" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="模拟" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </ToggleButton>
                    <Button Command="{Binding PublishCommand}"
                            Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                            Padding="8,5"
                            ToolTip="发布到运行时：保存并刷新运行时页面">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Rocket" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="发布" Margin="4,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 工具箱：每分组一行，组内 WrapPanel 自适应换行 -->
                <Border x:Name="ToolboxPanel" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0">
                    <DockPanel>
                        <Thumb x:Name="ToolboxDragHandle" DockPanel.Dock="Top" Height="14"
                               Background="#94A3B8" Cursor="SizeAll" Visibility="Collapsed"
                               DragDelta="ToolboxDragHandle_DragDelta"
                               ToolTip="拖动可移动工具栏"/>
                        <Button x:Name="ToolboxFloatToggle" DockPanel.Dock="Right"
                                Click="ToolboxFloatToggle_Click"
                                Background="Transparent" BorderThickness="0" Padding="4"
                                VerticalAlignment="Top" Margin="4,0,0,0"
                                ToolTip="切换悬浮 / 固定">
                            <materialDesign:PackIcon x:Name="ToolboxFloatIcon" Kind="PinOutline" Width="14" Height="14"/>
                        </Button>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="130">
                    <ItemsControl x:Name="ToolboxItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Title}" Width="60"
                                               FontSize="10" Foreground="{DynamicResource Brush.TextMuted}"
                                               VerticalAlignment="Top" Margin="0,8,6,0"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,4,4" Padding="6,4"
                                                        Background="#F8FAFC" Foreground="#334155"
                                                        BorderBrush="{DynamicResource Brush.Border}" FontWeight="Normal"
                                                        Command="{Binding DataContext.AddWidgetCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding TypeId}"
                                                        ToolTip="{Binding TypeId}"
                                                        PreviewMouseLeftButtonDown="ToolboxItem_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="ToolboxItem_PreviewMouseMove"
                                                        PreviewMouseLeftButtonUp="ToolboxItem_PreviewMouseLeftButtonUp">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="{Binding IconKind, FallbackValue=Widgets}"
                                                                                Width="14" Height="14"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#2563EB"
                                                                                Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Row 1: 三栏布局 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左栏：页面树 + 工具箱 ===== -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 工程名称 -->
                        <TextBlock Text="工程名称" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBox Text="{Binding Document.ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>

                        <!-- ===== P7C: Faceplate 编辑模式专属面板 ===== -->
                        <StackPanel Visibility="{Binding IsFaceplateEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Background="#FFEDD5" BorderBrush="#F97316" BorderThickness="1"
                                    CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                                <TextBlock Text="正在 Faceplate 编辑模式" Foreground="#9A3412" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="Faceplate 列表" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding AvailableFaceplates}"
                                     SelectedItem="{Binding SelectedFaceplate}"
                                     DisplayMemberPath="Name"
                                     MaxHeight="180"
                                     BorderBrush="{DynamicResource Brush.Border}" Margin="0,0,0,6"/>
                            <WrapPanel Margin="0,0,0,10">
                                <Button Content="+ 新建" Command="{Binding AddNewFaceplateCommand}"
                                        Background="#374151" Foreground="White" BorderBrush="#374151"
                                        Padding="8,4" Margin="0,0,4,0"/>
                                <Button Content="🗑 删除" Command="{Binding DeleteFaceplateCommand}"
                                        Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                        Padding="8,4"/>
                            </WrapPanel>
                            <!-- Faceplate 元数据 -->
                            <Expander Header="Faceplate 元数据" IsExpanded="True"
                                      FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"
                                      Visibility="{Binding SelectedFaceplate, Converter={StaticResource NullToVisibilityConverter}}">
                                <StackPanel TextElement.FontWeight="Normal" Margin="6,4,0,0">
                                    <TextBlock Text="名称" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedFaceplate.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>
                                    <TextBlock Text="版本" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedFaceplate.Version, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>
                                    <TextBlock Text="分类" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedFaceplate.Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>
                                    <TextBlock Text="图标 (MaterialDesign Kind)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedFaceplate.IconKind, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>
                                    <TextBlock Text="默认尺寸 (W, H)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <UniformGrid Columns="2" Margin="0,2,0,8">
                                        <TextBox Text="{Binding SelectedFaceplate.DefaultWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding SelectedFaceplate.DefaultHeight, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                    </UniformGrid>
                                    <TextBlock Text="接口属性 (内部 widget 用 {prop:key} 引用)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" FontWeight="SemiBold"/>
                                    <ItemsControl ItemsSource="{Binding SelectedFaceplateProperties}" Margin="0,4,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                                        CornerRadius="3" Padding="4" Margin="0,0,0,4">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,2">
                                                            <Button DockPanel.Dock="Right" Content="✕" Padding="4,0" FontSize="10"
                                                                    Background="Transparent" BorderThickness="0" Foreground="#B91C1C"
                                                                    Command="{Binding DataContext.RemoveInterfacePropertyCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                                     ToolTip="Key（内部 widget 通过 {prop:Key} 引用）" FontSize="11"/>
                                                        </DockPanel>
                                                        <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="显示名" FontSize="11" Margin="0,0,0,2"/>
                                                        <DockPanel>
                                                            <ComboBox DockPanel.Dock="Left" Width="100" FontSize="11"
                                                                      SelectedItem="{Binding Type}"
                                                                      ItemsSource="{Binding Source={StaticResource FaceplatePropertyTypes}}"/>
                                                            <TextBox Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                                     ToolTip="默认值" FontSize="11" Margin="4,0,0,0"/>
                                                        </DockPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Content="+ 添加接口属性" Command="{Binding AddInterfacePropertyCommand}"
                                            Background="#475569" Foreground="White" BorderBrush="#475569"
                                            Padding="8,4" HorizontalAlignment="Left" FontSize="11"/>
                                    <TextBlock Text="TODO: 内部 widget 属性中 [插入接口属性] 下拉留 v2.0" FontSize="10"
                                               Foreground="{DynamicResource Brush.TextMuted}" FontStyle="Italic" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- ===== 页面编辑模式专属面板（与 Faceplate 编辑模式互斥） ===== -->
                      <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFaceplateEditMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- P3.1 模板页 RouteKey -->
                        <TextBlock Text="模板页 RouteKey (页眉/页脚共享)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding Document.Pages}"
                                  DisplayMemberPath="Title" SelectedValuePath="RouteKey"
                                  SelectedValue="{Binding Document.TemplatePageRouteKey}"
                                  IsEditable="True" Margin="0,4,0,10" FontSize="12"
                                  ToolTip="选一个页面作为全局模板;留空 = 无模板"/>

                        <!-- 页面下拉框 -->
                        <TextBlock Text="当前页面" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding Document.Pages}"
                                  SelectedItem="{Binding SelectedPage}"
                                  DisplayMemberPath="Title"
                                  BorderBrush="{DynamicResource Brush.Border}"
                                  Background="#FFFFFF"
                                  Margin="0,0,0,8"/>

                        <!-- 新建页面 -->
                        <Border Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                CornerRadius="6" Padding="8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="新建页面" Foreground="{DynamicResource Brush.Text}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="标题 (留空 = 自动)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" Margin="0,6,0,2"/>
                                <TextBox Text="{Binding NewPageTitle, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"/>
                                <TextBlock Text="挂到父页面 (软件固定画面;留空 = 顶层)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" Margin="0,6,0,2"/>
                                <ComboBox ItemsSource="{Binding BuiltInParentSections}"
                                          SelectedValue="{Binding NewPageParentRouteKey, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="False" FontSize="12"
                                          ToolTip="选择软件内置的固定父画面（如 主界面/手动操作/报警画面 等）"/>
                                <Button Content="+ 新建页面" Command="{Binding AddPageCommand}"
                                        Background="#374151" Foreground="White" BorderBrush="#374151"
                                        Padding="10,6" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <Button Content="🗑 删除当前页面" Command="{Binding RemovePageCommand}"
                                Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                Padding="10,6" Margin="0,0,0,10" HorizontalAlignment="Left"/>

                        <!-- 当前页面属性 -->
                        <TextBlock Text="页面设置" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                        <TextBlock Text="页面标题" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBox Text="{Binding SelectedPage.Title, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>
                        <TextBlock Text="路由键" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBox Text="{Binding SelectedPage.RouteKey, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>
                        <TextBlock Text="父页面 (软件固定画面;留空 = 顶层)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding BuiltInParentSections}"
                                  SelectedValue="{Binding SelectedPage.ParentRouteKey, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="False" Margin="0,4,0,8" FontSize="12"
                                  ToolTip="把当前页挂到软件内置固定画面之下;留空表示独立顶层页"/>
                        <TextBlock Text="画布尺寸" Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <UniformGrid Columns="2" Margin="0,4,0,10">
                            <TextBox Text="{Binding SelectedPage.CanvasWidth, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,6,0"/>
                            <TextBox Text="{Binding SelectedPage.CanvasHeight, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="6,0,0,0"/>
                        </UniformGrid>

                        <!-- 主导航 -->
                        <CheckBox Content="挂到主导航顶栏" IsChecked="{Binding SelectedPage.ShowInTopNav}"
                                  Margin="0,0,0,6" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                        <TextBlock Text="导航图标 (MaterialDesign Kind, 如 ViewDashboard)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <TextBox Text="{Binding SelectedPage.NavIcon, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,6" FontSize="12"/>
                        <TextBlock Text="导航排序 (数字越小越靠前)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                        <TextBox Text="{Binding SelectedPage.NavOrder, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,10" FontSize="12"/>

                        <!-- ===== P6C 项目库 ===== -->
                        <Expander Header="我的库（项目级）" IsExpanded="False" Margin="0,4,0,4"
                                  FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"
                                  ToolTip="拖动库资产到画布生成实例；从画布右上角『存入库』把当前选中控件保存进来">
                            <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="200">
                                <ListBox x:Name="ProjectLibraryList"
                                         ItemsSource="{Binding ProjectLibraryAssets}"
                                         BorderThickness="0" FontSize="11"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         PreviewMouseLeftButtonDown="LibraryItem_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="LibraryItem_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <materialDesign:PackIcon Kind="Bookmark" Width="14" Height="14"
                                                                         VerticalAlignment="Center" Foreground="#0F766E" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Category}" Foreground="#64748B" FontSize="10"
                                                           VerticalAlignment="Center" Width="40"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Expander>

                        <!-- ===== P6C 全局库 ===== -->
                        <Expander Header="全局库（跨工程）" IsExpanded="False" Margin="0,0,0,4"
                                  FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"
                                  ToolTip="存放在 %USERPROFILE%\.apexhmi\global-library.json，所有工程共享">
                            <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="200">
                                <ListBox x:Name="GlobalLibraryList"
                                         ItemsSource="{Binding GlobalLibraryAssets}"
                                         BorderThickness="0" FontSize="11"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         PreviewMouseLeftButtonDown="LibraryItem_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="LibraryItem_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <materialDesign:PackIcon Kind="Earth" Width="14" Height="14"
                                                                         VerticalAlignment="Center" Foreground="#7C3AED" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding Category}" Foreground="#64748B" FontSize="10"
                                                           VerticalAlignment="Center" Width="40"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Expander>

                        <!-- ===== P6D 符号库 ===== -->
                        <Expander Header="符号库（工业图标）" IsExpanded="False" Margin="0,0,0,4"
                                  FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"
                                  ToolTip="拖到画布即生成 graphic-view + iconKind">
                            <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="240">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding SymbolGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,2,2,6">
                                                    <TextBlock Text="{Binding Title}" FontSize="10"
                                                               Foreground="{DynamicResource Brush.TextMuted}" Margin="0,2,0,2"/>
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="2" Padding="4"
                                                                        Background="#F8FAFC" BorderBrush="#CBD5E1"
                                                                        BorderThickness="1" CornerRadius="4"
                                                                        ToolTip="{Binding Name}"
                                                                        Tag="{Binding}"
                                                                        PreviewMouseLeftButtonDown="SymbolItem_PreviewMouseLeftButtonDown"
                                                                        PreviewMouseMove="SymbolItem_PreviewMouseMove">
                                                                    <StackPanel Width="56">
                                                                        <materialDesign:PackIcon Kind="{Binding IconKind, FallbackValue=Cog}"
                                                                                                 Width="22" Height="22"
                                                                                                 HorizontalAlignment="Center"
                                                                                                 Foreground="#1E40AF"/>
                                                                        <TextBlock Text="{Binding Name}" FontSize="10"
                                                                                   HorizontalAlignment="Center"
                                                                                   Foreground="#0F172A" Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Expander>

                        <!-- ===== PLC 变量（可拖到画布生成控件） ===== -->
                        <Expander Header="PLC 变量 (拖到画布)" IsExpanded="True" Margin="0,4,0,0"
                                  FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}">
                            <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                    CornerRadius="4" MaxHeight="260">
                                <ListBox x:Name="PlcVariableList"
                                         ItemsSource="{Binding PlcTags}"
                                         BorderThickness="0"
                                         FontSize="11"
                                         FontFamily="Consolas"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         PreviewMouseLeftButtonDown="PlcVariableItem_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="PlcVariableItem_PreviewMouseMove">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" ToolTip="{Binding Name}">
                                                <TextBlock Text="{Binding DataType}" Width="48"
                                                           Foreground="#2563EB" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#0F172A"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Expander>
                      </StackPanel> <!-- /P7C 页面编辑模式专属面板 -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== 中栏：设计画布 ===== -->
            <ContentControl x:Name="CanvasHost" Grid.Column="1">
            <Border x:Name="CanvasBorder" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,10">
                        <!-- P7C: Faceplate 编辑模式 banner -->
                        <Border Background="#FFEDD5" BorderBrush="#F97316" BorderThickness="1"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                                Visibility="{Binding IsFaceplateEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding FaceplateEditBannerText}" Foreground="#9A3412"
                                       FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <DockPanel>
                            <TextBlock Text="设计画布" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <CheckBox Content="网格" IsChecked="{Binding ShowGrid}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <CheckBox Content="吸附" IsChecked="{Binding SnapToGrid}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="间距" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Text="{Binding GridSize, UpdateSourceTrigger=PropertyChanged}" Width="44" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="缩放" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox ItemsSource="{Binding ZoomOptions}"
                                          SelectedItem="{Binding CanvasZoom}"
                                          Width="76" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat={}{0:P0}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Content="{Binding FitButtonText}" Click="FitToWindow_Click" Padding="8,3" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="80"/>
                                <TextBlock Text="{Binding MouseCoord, StringFormat=({0})}" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding CurrentWidgets.Count, Mode=OneWay, StringFormat=控件数: {0}}"
                                           Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <!-- 对齐工具栏：多选时显示 -->
                        <WrapPanel Margin="0,8,0,0"
                                   Visibility="{Binding HasMultiSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="◧ 左对齐"   Command="{Binding AlignLeftCommand}"   Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="◨ 右对齐"   Command="{Binding AlignRightCommand}"  Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="⊤ 顶对齐"   Command="{Binding AlignTopCommand}"    Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="⊥ 底对齐"   Command="{Binding AlignBottomCommand}" Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↔ 横向均布" Command="{Binding DistributeHorizontalCommand}" Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↕ 纵向均布" Command="{Binding DistributeVerticalCommand}"   Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↔ 等宽"     Command="{Binding SameWidthCommand}"   Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="↕ 等高"     Command="{Binding SameHeightCommand}"  Padding="8,4" Margin="0,0,4,0"/>
                            <Button Content="🗑 删除"    Command="{Binding DeleteSelectedWidgetsCommand}"
                                    Padding="8,4" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"/>
                        </WrapPanel>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1"
                                  x:Name="DesignerCanvasScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="DesignerCanvas"
                                Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}"
                                Background="#FFFFFF"
                                ClipToBounds="True"
                                AllowDrop="True"
                                MouseMove="DesignerCanvas_MouseMoveCoord"
                                MouseLeftButtonDown="DesignerCanvas_BackgroundClick"
                                MouseLeftButtonUp="DesignerCanvas_BackgroundMouseUp"
                                DragOver="DesignerCanvas_DragOver"
                                Drop="DesignerCanvas_Drop">
                            <Canvas.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding CanvasZoom}" ScaleY="{Binding CanvasZoom}"/>
                            </Canvas.LayoutTransform>
                            <!-- 画布有效范围边框 -->
                            <Rectangle Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                       Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}"
                                       Stroke="#64748B" StrokeThickness="1"
                                       Fill="Transparent"
                                       IsHitTestVisible="False"
                                       Panel.ZIndex="2000"/>
                            <!-- 网格背景层 -->
                            <Rectangle Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                       Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ShowGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Rectangle.Fill>
                                    <DrawingBrush TileMode="Tile" Stretch="None"
                                                  Viewport="0,0,8,8" ViewportUnits="Absolute"
                                                  Viewbox="0,0,8,8"  ViewboxUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <RectangleGeometry Rect="0,0,8,1"/>
                                                        <RectangleGeometry Rect="0,0,1,8"/>
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                                <GeometryDrawing.Brush>
                                                    <SolidColorBrush Color="#CBD5E1" Opacity="0.4"/>
                                                </GeometryDrawing.Brush>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <!-- 框选矩形可视化 -->
                            <Rectangle Canvas.Left="{Binding MarqueeX}" Canvas.Top="{Binding MarqueeY}"
                                       Width="{Binding MarqueeWidth}" Height="{Binding MarqueeHeight}"
                                       Stroke="#3B82F6" StrokeThickness="1" StrokeDashArray="4,2"
                                       Fill="#3B82F6" Opacity="0.15"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding IsMarqueeActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Panel.ZIndex="1000"/>
                            <ListBox ItemsSource="{Binding CurrentWidgetItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                     Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}">
                                <ListBox.Template>
                                    <ControlTemplate TargetType="ListBox">
                                        <ItemsPresenter/>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Canvas.Left" Value="{Binding Model.X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Model.Y}"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:DesignerWidgetItem}">
                                        <!-- 外层 Grid 控制 widget 占位尺寸；包含选中层 + 8 个尺寸调整手柄 -->
                                        <Grid Width="{Binding Model.Width}" Height="{Binding Model.Height}">
                                            <!-- 选中层 Border：捕获鼠标 + 显示选中边框，内部为预创建的真容视图 -->
                                            <Border Cursor="Hand"
                                                    Background="Transparent"
                                                    MouseLeftButtonDown="Widget_MouseLeftButtonDown"
                                                    MouseMove="Widget_MouseMove"
                                                    MouseLeftButtonUp="Widget_MouseLeftButtonUp">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ContentPresenter Content="{Binding View}"/>
                                            </Border>

                                            <!-- 8 个尺寸调整手柄：仅选中时显示 -->
                                            <Grid Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.Resources>
                                                    <Style x:Key="ResizeHandleStyle" TargetType="Rectangle">
                                                        <Setter Property="Width" Value="8"/>
                                                        <Setter Property="Height" Value="8"/>
                                                        <Setter Property="Fill" Value="#FFFFFF"/>
                                                        <Setter Property="Stroke" Value="#F59E0B"/>
                                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                                    </Style>
                                                </Grid.Resources>
                                                <Rectangle Tag="NW" Cursor="SizeNWSE" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Left"   VerticalAlignment="Top"    Margin="-4,-4,0,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="N"  Cursor="SizeNS"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="0,-4,0,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="NE" Cursor="SizeNESW" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Right"  VerticalAlignment="Top"    Margin="0,-4,-4,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="E"  Cursor="SizeWE"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Right"  VerticalAlignment="Center" Margin="0,0,-4,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="SE" Cursor="SizeNWSE" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Right"  VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="S"  Cursor="SizeNS"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-4"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="SW" Cursor="SizeNESW" Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Left"   VerticalAlignment="Bottom" Margin="-4,0,0,-4"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                                <Rectangle Tag="W"  Cursor="SizeWE"    Style="{StaticResource ResizeHandleStyle}"
                                                           HorizontalAlignment="Left"   VerticalAlignment="Center" Margin="-4,0,0,0"
                                                           MouseLeftButtonDown="ResizeHandle_MouseLeftButtonDown"
                                                           MouseMove="ResizeHandle_MouseMove"
                                                           MouseLeftButtonUp="ResizeHandle_MouseLeftButtonUp"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>
            </ContentControl>

            <!-- ===== 右栏：属性编辑器 V2（4 Tab） ===== -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="属性编辑器" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource Brush.Text}" Margin="12,12,12,4"/>
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">
                <TabItem Header="属性">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>

                        <!-- 未选中控件时的提示 -->
                        <TextBlock Text="请从画布中选中一个控件"
                                   Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="13"
                                   Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>

                        <!-- 控件基本信息 -->
                        <StackPanel Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}}">
                            <WrapPanel Margin="0,0,0,8">
                                <Button Content="🗑 删除" Command="{Binding RemoveSelectedWidgetCommand}"
                                        Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                        Padding="10,4" Margin="0,0,6,6"/>
                                <TextBlock Text="{Binding SelectedWidget.TypeId}" Foreground="{DynamicResource Brush.TextMuted}"
                                           VerticalAlignment="Center" FontSize="11"/>
                            </WrapPanel>

                            <!-- P7E: 版本升级提示条（仅 Faceplate 实例 + 版本落后时显示） -->
                            <Border Background="#FFEDD5" BorderBrush="#F97316" BorderThickness="1"
                                    CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsSelectedWidgetFaceplateInstance}" Value="True"/>
                                                    <Condition Binding="{Binding IsFaceplateVersionOutdated}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="升级"
                                            Command="{Binding UpgradeFaceplateInstanceCommand}"
                                            Background="#F97316" Foreground="White" BorderBrush="#F97316"
                                            Padding="8,2" FontSize="11"/>
                                    <TextBlock Text="{Binding FaceplateVersionUpgradeText}" Foreground="#9A3412"
                                               FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,8,0"/>
                                </DockPanel>
                            </Border>

                            <!-- P7D: 接口属性（仅 Faceplate 实例时显示） -->
                            <Expander Header="接口属性" IsExpanded="True" FontWeight="SemiBold"
                                      Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"
                                      Visibility="{Binding IsSelectedWidgetFaceplateInstance, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <!-- P7.5D: Schema-driven 接口属性编辑器（每行 DisplayName + 类型化编辑器） -->
                                    <ItemsControl ItemsSource="{Binding FaceplateInterfacePropertyEditors}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" MinWidth="92"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"
                                                               ToolTip="{Binding Description}"/>
                                                    <ContentControl Grid.Column="1"
                                                                    Content="{Binding}"
                                                                    ContentTemplateSelector="{StaticResource PropEditorSelector}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <!-- 几何 -->
                            <Expander Header="几何" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="位置 (X, Y)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <UniformGrid Columns="2" Margin="0,4,0,6">
                                        <TextBox Text="{Binding SelectedWidget.X, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding SelectedWidget.Y, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                    </UniformGrid>
                                    <TextBlock Text="尺寸 (宽, 高)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <UniformGrid Columns="2" Margin="0,4,0,2">
                                        <TextBox Text="{Binding SelectedWidget.Width, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                        <TextBox Text="{Binding SelectedWidget.Height, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Expander>

                            <!-- P7.5B: Schema-driven 属性面板（按 Category 分组，类型化编辑器） -->
                            <ItemsControl ItemsSource="{Binding GroupedPropertyEditors}"
                                          Visibility="{Binding HasSchemaForSelectedWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Header="{Binding Category}" IsExpanded="True" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                            <ItemsControl ItemsSource="{Binding Items}"
                                                          Margin="6,4,0,0" TextElement.FontWeight="Normal"
                                                          ItemTemplateSelector="{StaticResource PropEditorSelector}">
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.Template>
                                                    <ControlTemplate TargetType="ItemsControl">
                                                        <Grid>
                                                            <ItemsPresenter/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ItemsControl.Template>
                                            </ItemsControl>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- P7.5B: Fallback —— schema 找不到时显示旧 generic 属性面板 -->
                            <Expander Header="外观 / 属性 (回退)" IsExpanded="False" FontWeight="SemiBold"
                                      Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4"
                                      Visibility="{Binding HasNoSchemaForSelectedWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="该控件类型未注册 Schema，使用通用编辑器"
                                               Foreground="#94A3B8" FontSize="10" FontStyle="Italic" Margin="0,0,0,4"/>
                                    <ItemsControl ItemsSource="{Binding CurrentWidgetProperties}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" MinWidth="92"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"
                                                               ToolTip="{Binding Key}"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             VerticalAlignment="Center">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="b:TagAutoComplete.IsEnabled" Value="False"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Key}" Value="variable">
                                                                        <Setter Property="b:TagAutoComplete.IsEnabled" Value="True"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <Border Grid.Column="2"
                                                            Width="22" Height="22" CornerRadius="4"
                                                            Margin="6,0,0,0" BorderBrush="#CBD5E1" BorderThickness="1"
                                                            Visibility="{Binding IsColorProperty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Background="{Binding Value, Converter={StaticResource StringToBrushConverter}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <!-- 数据绑定 -->
                            <!-- P7.5E: 旧'数据绑定'Expander 隐藏，绑定能力已迁移到 schema 中的 TagAddress 字段 / 顶部「事件」Tab -->
                            <Expander Header="数据绑定" IsExpanded="True" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4"
                                      Visibility="Collapsed">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="读取地址（订阅）" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="{DynamicResource Brush.TextMuted}" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,2"
                                               Text="控件订阅此变量并实时刷新。当此变量在 PLC 端发生变化时：&#x0a;&#xa0;• 「指示灯 / 数值显示」等控件 → 直接显示新值&#xa;&#xa0;• 「切换开关」模式 → 决定下次写入的取反值&#xa;&#xa0;• 「状态动画」→ 根据条件自动改变控件外观&#xa;留空 = 不订阅，控件只响应点击不显示状态。"/>
                                    <DockPanel Margin="0,4,0,4">
                                        <Button DockPanel.Dock="Right" Content="🔍"
                                                Command="{Binding OpenTagBrowserCommand}"
                                                Padding="6,0" Margin="4,0,0,0"
                                                ToolTip="打开 Tag 浏览器"/>
                                        <TextBox Text="{Binding CurrentBindingTagId, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"
                                                 b:TagAutoComplete.IsEnabled="True"
                                                 ToolTip="绑定 Tag 名（输入时下方列出候选；Tab/Enter 补全，Esc 关闭，↑↓ 切换）"/>
                                    </DockPanel>
                                </StackPanel>
                            </Expander>

                            <!-- P7.5E: 旧'事件/动作单动作'Expander 隐藏，已被顶部「事件」Tab 多动作链取代 -->
                            <Expander Header="事件 / 动作（单动作快捷）" IsExpanded="True" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4"
                                      Visibility="Collapsed">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="提示：高级编辑请见顶部「事件」Tab 多动作链"
                                               Foreground="#0EA5E9" FontSize="10" FontStyle="Italic" Margin="0,0,0,4"/>
                                    <TextBlock Text="点击动作" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <ComboBox Margin="0,4,0,4"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{Binding SelectedWidget.ActionType, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Content="无"          Tag="无"/>
                                        <ComboBoxItem Content="设为 ON"     Tag="set-on"      ToolTip="按钮模式：单击写 True"/>
                                        <ComboBoxItem Content="设为 OFF"    Tag="set-off"     ToolTip="按钮模式：单击写 False"/>
                                        <ComboBoxItem Content="切换开关"    Tag="toggle"      ToolTip="按钮模式：单击读后写反值（读地址 = 数据绑定 Tag；留空 = 复用写地址）"/>
                                        <ComboBoxItem Content="复归型 / 点动" Tag="momentary"  ToolTip="按钮模式：按下写 True，松开写 False"/>
                                        <ComboBoxItem Content="写入布尔"    Tag="write-bool"  ToolTip="参数格式：TagName|True/False"/>
                                        <ComboBoxItem Content="写入整数"    Tag="write-int"   ToolTip="参数格式：TagName|123"/>
                                        <ComboBoxItem Content="写入浮点"    Tag="write-float" ToolTip="参数格式：TagName|1.23"/>
                                        <ComboBoxItem Content="页面跳转"    Tag="navigate"    ToolTip="参数：目标 RouteKey"/>
                                        <ComboBoxItem Content="弹窗提示"    Tag="show-dialog" ToolTip="参数：弹窗文字"/>
                                    </ComboBox>
                                    <TextBlock Text="动作参数" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <!-- 通用 TextBox：set-on/off/toggle/momentary 模式（地址）+ show-dialog（弹窗文字）+ 无动作 -->
                                    <TextBox Text="{Binding SelectedWidget.ActionParam, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,4,0,4"
                                             b:TagAutoComplete.IsEnabled="True"
                                             ToolTip="set-on/off/toggle/momentary：写入 Tag 地址（值由模式决定）&#x0a;show-dialog：弹窗文字">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="navigate">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="write-bool">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="write-int">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="write-float">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <!-- 写入布尔/整数/浮点：拆成 写入地址 + 写入值 两个独立字段，底层合并为 addr|value 存入 ActionParam -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="write-bool">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="write-int">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="write-float">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="写入地址" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                        <TextBox Text="{Binding WriteAddress, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,6"
                                                 b:TagAutoComplete.IsEnabled="True"
                                                 ToolTip="目标 Tag 地址（点击时把下面的值写入此地址）"/>
                                        <TextBlock Text="写入值" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                        <TextBox Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,4"
                                                 ToolTip="布尔：True / False&#x0a;整数：如 42&#x0a;浮点：如 3.14"/>
                                    </StackPanel>
                                    <!-- 页面下拉：仅 navigate 时显示，列出固定页 + 工程内用户页面 -->
                                    <ComboBox ItemsSource="{Binding NavigateTargets}"
                                              SelectedValuePath="RouteKey"
                                              SelectedValue="{Binding SelectedWidget.ActionParam, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,4,0,4"
                                              ToolTip="选择跳转目标（写入 RouteKey 或固定段名）">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Group, StringFormat=[{0}]}"
                                                               Foreground="#2563EB" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                    <TextBlock Text="{Binding RouteKey, StringFormat=  ({0})}"
                                                               Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedWidget.ActionType}" Value="navigate">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>
                                </StackPanel>
                            </Expander>

                            <!-- P7.5E: 旧'状态动画'Expander 隐藏，已被顶部「动画」Tab 取代 -->
                            <Expander Header="状态动画（旧版）" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4"
                                      Visibility="Collapsed">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="提示：推荐使用顶部「动画」Tab 配置外观/可见性/移动动画（结构化模型，运行更顺滑）；本区域为旧版兼容入口"
                                               Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <Button Content="+ 添加动画" Command="{Binding AddAnimationCommand}"
                                            Padding="8,4" Margin="0,0,0,6" HorizontalAlignment="Left"
                                            Background="#0EA5E9" Foreground="White" BorderBrush="#0EA5E9"/>
                                    <ItemsControl ItemsSource="{Binding CurrentAnimations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                                        CornerRadius="4" Padding="6" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,4">
                                                            <Button DockPanel.Dock="Right" Content="✕"
                                                                    Command="{Binding DataContext.RemoveAnimationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Padding="6,0" Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"/>
                                                            <TextBlock Text="动画规则" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Tag" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" FontSize="11"/>
                                                            <TextBox Grid.Column="1" Text="{Binding TagId, UpdateSourceTrigger=PropertyChanged}" FontSize="11"
                                                                     b:TagAutoComplete.IsEnabled="True"/>
                                                        </Grid>
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="条件" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" FontSize="11"/>
                                                            <ComboBox Grid.Column="1" Text="{Binding Op, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" FontSize="11" Margin="0,0,4,0">
                                                                <ComboBoxItem>true</ComboBoxItem>
                                                                <ComboBoxItem>false</ComboBoxItem>
                                                                <ComboBoxItem>eq</ComboBoxItem>
                                                                <ComboBoxItem>ne</ComboBoxItem>
                                                                <ComboBoxItem>gt</ComboBoxItem>
                                                                <ComboBoxItem>lt</ComboBoxItem>
                                                                <ComboBoxItem>gte</ComboBoxItem>
                                                                <ComboBoxItem>lte</ComboBoxItem>
                                                            </ComboBox>
                                                            <TextBox Grid.Column="2" Text="{Binding CompareTo, UpdateSourceTrigger=PropertyChanged}" FontSize="11" ToolTip="对比值（true/false 时忽略）"/>
                                                        </Grid>
                                                        <Grid Margin="0,2,0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="50"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="设置" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" FontSize="11"/>
                                                            <TextBox Grid.Column="1" Text="{Binding TargetProperty, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Margin="0,0,4,0" ToolTip="属性 key (如 background)"/>
                                                            <TextBox Grid.Column="2" Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}" FontSize="11" ToolTip="目标值"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <!-- 安全 -->
                            <Expander Header="安全 / 权限" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="所需角色 (留空 = 所有人)" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <ComboBox Margin="0,4,0,4"
                                              Text="{Binding SelectedWidget.RequiredRole, UpdateSourceTrigger=LostFocus}"
                                              IsEditable="True">
                                        <ComboBoxItem Content=""/>
                                        <ComboBoxItem Content="Operator"/>
                                        <ComboBoxItem Content="Engineer"/>
                                        <ComboBoxItem Content="Administrator"/>
                                    </ComboBox>
                                </StackPanel>
                            </Expander>

                            <!-- 控件 ID（折叠默认） -->
                            <Expander Header="高级 / ID" IsExpanded="False" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,4">
                                <StackPanel Margin="6,4,0,0" TextElement.FontWeight="Normal">
                                    <TextBlock Text="控件 ID" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                    <TextBox Text="{Binding SelectedWidget.Id, Mode=OneWay}" IsReadOnly="True"
                                             Background="#F1F5F9" Margin="0,4,0,0" FontFamily="Consolas" FontSize="11"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                </TabItem>

                <!-- ===== 动画 Tab (P2-V2) ===== -->
                <TabItem Header="动画">
                    <Grid Margin="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="请从画布中选中一个控件"
                                   Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="13"
                                   Margin="12,12,0,0"
                                   Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                        <Grid Grid.Row="1"
                              Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左：分组导航 -->
                            <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="0,0,1,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AnimationCategories}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Top"
                                                            Command="{Binding DataContext.SelectAnimationCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding CategoryId}"
                                                            BorderThickness="0" Padding="8,6"
                                                            HorizontalContentAlignment="Stretch" Margin="0,0,0,1">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Foreground" Value="#334155"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#2563EB"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <DockPanel>
                                                            <!-- 启用状态点 -->
                                                            <Ellipse DockPanel.Dock="Left" Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="#CBD5E1"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                                <Setter Property="Fill" Value="#16A34A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12"/>
                                                        </DockPanel>
                                                    </Button>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- 右：内容区按选中分类切换 -->
                            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="10,8,8,8">
                                <Grid>
                                    <!-- ====== 总览面板 ====== -->
                                    <StackPanel Visibility="{Binding IsOverviewSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="总览" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding AnimationCategories}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6" Padding="8,6"
                                                            BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1"
                                                            CornerRadius="4" Background="White"
                                                            Visibility="{Binding Group, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=总览}">
                                                        <!-- 总览自身不显示 → 用反向 visibility -->
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- 简洁版：直接渲染非总览的 6 项 -->
                                        <ItemsControl ItemsSource="{Binding AnimationCategories}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.Style>
                                                            <Style TargetType="Grid">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CategoryId}" Value="overview">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Grid.Style>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="✗"/>
                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                            <Setter Property="Text" Value="✓"/>
                                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Brush.Text}" FontSize="12"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Summary}" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Button Grid.Column="3" Content="跳转" Padding="6,2" FontSize="11" Margin="0,0,4,0"
                                                                Command="{Binding DataContext.SelectAnimationCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding CategoryId}"
                                                                Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        <Button Grid.Column="4" Content="删除" Padding="6,2" FontSize="11"
                                                                Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                                                Command="{Binding DataContext.DisableAnimationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding CategoryId}"
                                                                Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- ====== 外观面板 ====== -->
                                    <StackPanel Visibility="{Binding IsAppearanceSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="外观动画" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.Text}"/>
                                            <Button DockPanel.Dock="Right" Content="启用" Padding="10,3"
                                                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                                                    Command="{Binding EnableAnimationCommand}" CommandParameter="appearance"
                                                    Visibility="{Binding WidgetAppearance, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                            <Button DockPanel.Dock="Right" Content="停用" Padding="10,3" Margin="0,0,6,0"
                                                    Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                                    Command="{Binding DisableAnimationCommand}" CommandParameter="appearance"
                                                    Visibility="{Binding WidgetAppearance, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </DockPanel>
                                        <TextBlock Text="该控件未启用外观动画" Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0"
                                                   Visibility="{Binding WidgetAppearance, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                        <StackPanel Visibility="{Binding WidgetAppearance, Converter={StaticResource NullToVisibilityConverter}}"
                                                    DataContext="{Binding WidgetAppearance}">
                                            <!-- 变量 -->
                                            <Grid Margin="0,4,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="变量" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                                                <TextBox Grid.Column="1" Text="{Binding TagId, UpdateSourceTrigger=PropertyChanged}"
                                                         b:TagAutoComplete.IsEnabled="True"
                                                         VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <!-- 匹配类型 -->
                                            <StackPanel Orientation="Horizontal" Margin="60,0,0,8">
                                                <RadioButton Content="范围"   GroupName="AppMatch" Margin="0,0,12,0"
                                                             IsChecked="{Binding MatchType, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Range}"/>
                                                <RadioButton Content="多个位" GroupName="AppMatch" Margin="0,0,12,0"
                                                             IsChecked="{Binding MatchType, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=MultiBit}"/>
                                                <RadioButton Content="单个位" GroupName="AppMatch"
                                                             IsChecked="{Binding MatchType, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SingleBit}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- 行表格 -->
                                        <DockPanel Visibility="{Binding WidgetAppearance, Converter={StaticResource NullToVisibilityConverter}}" Margin="0,0,0,4">
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button Content="＋ 新增行" Padding="8,3"
                                                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                                                        Command="{Binding AddAppearanceRowCommand}"/>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding AppearanceRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4"
                                                                Background="White" Padding="6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="50"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- 范围编辑（按 MatchType 切换；先实现 Range：From-To） -->
                                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                    <TextBlock Text="从" VerticalAlignment="Center" Foreground="#64748B" FontSize="11" Margin="0,0,4,0"/>
                                                                    <TextBox Width="60" Text="{Binding RangeFrom, UpdateSourceTrigger=PropertyChanged}"/>
                                                                    <TextBlock Text="到" VerticalAlignment="Center" Foreground="#64748B" FontSize="11" Margin="4,0,4,0"/>
                                                                    <TextBox Width="60" Text="{Binding RangeTo, UpdateSourceTrigger=PropertyChanged}"/>
                                                                    <TextBlock Text="位号" VerticalAlignment="Center" Foreground="#64748B" FontSize="11" Margin="8,0,4,0"/>
                                                                    <TextBox Width="40" Text="{Binding BitIndex, UpdateSourceTrigger=PropertyChanged}"/>
                                                                    <TextBlock Text="掩码" VerticalAlignment="Center" Foreground="#64748B" FontSize="11" Margin="8,0,4,0"/>
                                                                    <TextBox Width="60" Text="{Binding BitMask, UpdateSourceTrigger=PropertyChanged}"/>
                                                                </StackPanel>
                                                                <!-- 背景色 + 动态化图标 demo -->
                                                                <Grid Grid.Column="1">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBox Grid.Column="0" Text="{Binding Background, UpdateSourceTrigger=PropertyChanged}" ToolTip="背景色 hex（如 #2563EB）"/>
                                                                    <materialDesign:PackIcon Grid.Column="1" Kind="TriangleSmallDown" Width="12" Height="12"
                                                                                              Foreground="#94A3B8" VerticalAlignment="Center" Margin="2,0,2,0"
                                                                                              ToolTip="动态化（点击绑定到变量，演示中）"
                                                                                              Cursor="Hand"/>
                                                                </Grid>
                                                                <TextBox Grid.Column="2" Text="{Binding Foreground, UpdateSourceTrigger=PropertyChanged}"
                                                                         ToolTip="前景色 hex（如 #FFFFFF）" Margin="4,0,0,0"/>
                                                                <CheckBox Grid.Column="3" IsChecked="{Binding Blink}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                <StackPanel Grid.Column="4" Orientation="Horizontal">
                                                                    <Button Content="↑" Padding="4,1" Margin="4,0,2,0" FontSize="11"
                                                                            Command="{Binding DataContext.MoveAppearanceRowUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"/>
                                                                    <Button Content="↓" Padding="4,1" Margin="0,0,2,0" FontSize="11"
                                                                            Command="{Binding DataContext.MoveAppearanceRowDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"/>
                                                                    <Button Content="✕" Padding="4,1" FontSize="11"
                                                                            Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                                                            Command="{Binding DataContext.RemoveAppearanceRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DockPanel>
                                    </StackPanel>

                                    <!-- ====== 可见性面板 ====== -->
                                    <StackPanel Visibility="{Binding IsVisibilitySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="可见性动画" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.Text}"/>
                                            <Button DockPanel.Dock="Right" Content="启用" Padding="10,3"
                                                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                                                    Command="{Binding EnableAnimationCommand}" CommandParameter="visibility"
                                                    Visibility="{Binding WidgetVisibility, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                            <Button DockPanel.Dock="Right" Content="停用" Padding="10,3" Margin="0,0,6,0"
                                                    Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                                    Command="{Binding DisableAnimationCommand}" CommandParameter="visibility"
                                                    Visibility="{Binding WidgetVisibility, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </DockPanel>
                                        <TextBlock Text="该控件未启用可见性动画" Foreground="#94A3B8" FontSize="12"
                                                   Visibility="{Binding WidgetVisibility, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                        <StackPanel Visibility="{Binding WidgetVisibility, Converter={StaticResource NullToVisibilityConverter}}"
                                                    DataContext="{Binding WidgetVisibility}">
                                            <Grid Margin="0,4,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="变量" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                                                <TextBox Grid.Column="1" Text="{Binding TagId, UpdateSourceTrigger=PropertyChanged}"
                                                         b:TagAutoComplete.IsEnabled="True" VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="条件" Margin="0,4,0,2" Foreground="#64748B" FontSize="12"/>
                                            <StackPanel Margin="60,0,0,6">
                                                <RadioButton Content="变量为 True 时显示" GroupName="VisMode"
                                                             IsChecked="{Binding Mode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=WhenTrue}"/>
                                                <RadioButton Content="变量为 False 时显示" GroupName="VisMode" Margin="0,4,0,0"
                                                             IsChecked="{Binding Mode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=WhenFalse}"/>
                                                <DockPanel Margin="0,4,0,0">
                                                    <RadioButton Content="值在范围" GroupName="VisMode" VerticalAlignment="Center"
                                                                 IsChecked="{Binding Mode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=WhenInRange}"/>
                                                    <TextBox Width="60" Margin="6,0,0,0" Text="{Binding RangeFrom, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="-" Margin="4,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBox Width="60" Text="{Binding RangeTo, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="内显示" Margin="6,0,0,0" Foreground="#64748B" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <TextBlock Text="否则" Margin="0,4,0,2" Foreground="#64748B" FontSize="12"/>
                                            <StackPanel Orientation="Horizontal" Margin="60,0,0,0">
                                                <RadioButton Content="隐藏" GroupName="VisOther" Margin="0,0,12,0"
                                                             IsChecked="{Binding Otherwise, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Hidden}"/>
                                                <RadioButton Content="禁用（灰色）" GroupName="VisOther"
                                                             IsChecked="{Binding Otherwise, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Disabled}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ====== 移动面板（4 类共用） ====== -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHorizontalSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding IsVerticalSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDirectSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDiagonalSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.Text}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="移动动画"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHorizontalSelected}" Value="True"><Setter Property="Text" Value="水平移动"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsVerticalSelected}" Value="True"><Setter Property="Text" Value="垂直移动"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDirectSelected}" Value="True"><Setter Property="Text" Value="直接移动"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDiagonalSelected}" Value="True"><Setter Property="Text" Value="对角线移动"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button DockPanel.Dock="Right" Content="启用" Padding="10,3"
                                                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                                                    Command="{Binding EnableAnimationCommand}"
                                                    CommandParameter="{Binding SelectedAnimationCategory}"
                                                    Visibility="{Binding WidgetMovement, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                            <Button DockPanel.Dock="Right" Content="停用" Padding="10,3" Margin="0,0,6,0"
                                                    Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                                    Command="{Binding DisableAnimationCommand}"
                                                    CommandParameter="{Binding SelectedAnimationCategory}"
                                                    Visibility="{Binding WidgetMovement, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </DockPanel>

                                        <TextBlock Text="该控件未启用此类移动动画" Foreground="#94A3B8" FontSize="12"
                                                   Visibility="{Binding WidgetMovement, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>

                                        <StackPanel Visibility="{Binding WidgetMovement, Converter={StaticResource NullToVisibilityConverter}}"
                                                    DataContext="{Binding WidgetMovement}">
                                            <!-- X 轴变量 + 范围 -->
                                            <Grid Margin="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="变量 X" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                                                <TextBox Grid.Column="1" Text="{Binding TagIdX, UpdateSourceTrigger=PropertyChanged}"
                                                         b:TagAutoComplete.IsEnabled="True" VerticalContentAlignment="Center"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="X 变量范围" VerticalAlignment="Center" Foreground="#64748B" FontSize="11"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="从" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Width="70" Text="{Binding RangeMinX, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="到" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                                    <TextBox Width="70" Text="{Binding RangeMaxX, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="X 像素范围" VerticalAlignment="Center" Foreground="#64748B" FontSize="11"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="起" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Width="70" Text="{Binding PixelStartX, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="终" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                                    <TextBox Width="70" Text="{Binding PixelEndX, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Y 轴（仅 Vertical/Direct/Diagonal 显示） -->
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MoveType, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=Vertical}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MoveType, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=Direct}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MoveType, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=Diagonal}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="变量 Y" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                                                    <TextBox Grid.Column="1" Text="{Binding TagIdY, UpdateSourceTrigger=PropertyChanged}"
                                                             b:TagAutoComplete.IsEnabled="True" VerticalContentAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Y 变量范围" VerticalAlignment="Center" Foreground="#64748B" FontSize="11"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock Text="从" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBox Width="70" Text="{Binding RangeMinY, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Text="到" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                                        <TextBox Width="70" Text="{Binding RangeMaxY, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Y 像素范围" VerticalAlignment="Center" Foreground="#64748B" FontSize="11"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock Text="起" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBox Width="70" Text="{Binding PixelStartY, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Text="终" VerticalAlignment="Center" Margin="6,0,4,0"/>
                                                        <TextBox Width="70" Text="{Binding PixelEndY, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ===== 事件 Tab ===== -->
                <TabItem Header="事件">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="请从画布中选中一个控件"
                                   Foreground="{DynamicResource Brush.TextPlaceholder}" FontSize="13"
                                   Margin="6,12,0,0"
                                   Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                        <Grid Grid.Row="1"
                              Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- 左：事件入口列表 -->
                            <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    BorderThickness="0,0,1,0">
                                <ItemsControl ItemsSource="{Binding AvailableEvents}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.SelectEventCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding EventId}"
                                                    BorderThickness="0" Padding="8,8"
                                                    HorizontalContentAlignment="Stretch" Margin="0,0,0,1">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#334155"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#2563EB"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Right" Background="#F59E0B" CornerRadius="8"
                                                            Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                                            Visibility="{Binding HasSteps, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="{Binding StepCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <!-- 右：动作列表 -->
                            <DockPanel Grid.Column="1" Margin="8,0,0,0">
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,4,0,8">
                                    <Button Content="↑" Command="{Binding MoveActionUpCommand}"
                                            CommandParameter="{Binding SelectedItem, ElementName=EventActionList}"
                                            Padding="8,3" Margin="0,0,4,0" ToolTip="上移"/>
                                    <Button Content="↓" Command="{Binding MoveActionDownCommand}"
                                            CommandParameter="{Binding SelectedItem, ElementName=EventActionList}"
                                            Padding="8,3" Margin="0,0,4,0" ToolTip="下移"/>
                                    <Button Content="✕" Command="{Binding DeleteActionCommand}"
                                            CommandParameter="{Binding SelectedItem, ElementName=EventActionList}"
                                            Padding="8,3" Margin="0,0,12,0"
                                            Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                            ToolTip="删除"/>
                                    <Button Content="＋ 新建动作" Command="{Binding AddActionCommand}"
                                            Padding="10,3"
                                            Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
                                </StackPanel>
                                <ListBox x:Name="EventActionList"
                                         ItemsSource="{Binding CurrentEventSteps}"
                                         Background="Transparent" BorderThickness="0"
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,6"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4"
                                                    Background="White" Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"
                                                               Foreground="{DynamicResource Brush.Text}"/>
                                                    <ItemsControl ItemsSource="{Binding ArgEditors}" Margin="0,4,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,4,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="80"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                                               Foreground="#64748B" VerticalAlignment="Center" FontSize="11"/>
                                                                    <!-- TagAddress: TextBox + 自动补全 -->
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                             b:TagAutoComplete.IsEnabled="True"
                                                                             VerticalContentAlignment="Center"
                                                                             Visibility="{Binding IsTagAddress, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    <!-- Text/Number: 普通 TextBox -->
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                             VerticalContentAlignment="Center"
                                                                             Visibility="{Binding IsText, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                             VerticalContentAlignment="Center"
                                                                             Visibility="{Binding IsNumber, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    <!-- Boolean: True/False ComboBox -->
                                                                    <ComboBox Grid.Column="1"
                                                                              SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                              SelectedValuePath="Content"
                                                                              IsEditable="True"
                                                                              Visibility="{Binding IsBoolean, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <ComboBoxItem Content="True"/>
                                                                        <ComboBoxItem Content="False"/>
                                                                    </ComboBox>
                                                                    <!-- PageRouteKey: NavigateTargets ComboBox -->
                                                                    <ComboBox Grid.Column="1"
                                                                              ItemsSource="{Binding DataContext.NavigateTargets, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              SelectedValuePath="RouteKey"
                                                                              SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                              Visibility="{Binding IsPageRouteKey, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                        <ComboBox.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text="{Binding Group, StringFormat=[{0}]}"
                                                                                               Foreground="#2563EB" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                                    <TextBlock Text="{Binding DisplayName}"/>
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ComboBox.ItemTemplate>
                                                                    </ComboBox>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ===== 文本 Tab（P6B）===== -->
                <TabItem Header="文本">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <TextBlock Text="多语言文本（P6B）" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Text}"/>
                            <TextBlock Text="点击下方按钮打开项目级文本资源编辑器；控件属性写 {text:welcome} 即可引用。"
                                       FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <Button Content="打开文本资源编辑器…"
                                    Command="{Binding OpenTextEditorCommand}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0" Padding="12,5"
                                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
                        </StackPanel>
                        <TextBlock Text="（当前控件用到的文本 key 检索预览将在 P7 完善。）"
                                   FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"
                                   VerticalAlignment="Top"/>
                    </DockPanel>
                </TabItem>
                </TabControl>
                </Grid>
            </Border>

            <!-- 悬浮工具栏宿主层（默认无内容；点击图钉时把 ToolboxPanel 移入此层）-->
            <Canvas x:Name="OverlayLayer" Grid.ColumnSpan="3" Background="{x:Null}" Panel.ZIndex="999"/>
        </Grid>
    </Grid>
</UserControl>
