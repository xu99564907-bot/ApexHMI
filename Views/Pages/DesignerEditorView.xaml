<UserControl x:Class="ApexHMI.Views.Pages.DesignerEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ApexHMI.ViewModels.Modules"
             xmlns:model="clr-namespace:ApexHMI.Models.RuntimeUi"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="开放平台画布设计" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="撤销 Ctrl+Z" Command="{Binding UndoCommand}"
                            IsEnabled="{Binding CanUndo}"
                            Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1"
                            Padding="10,6" Margin="0,0,6,0"/>
                    <Button Content="重做 Ctrl+Y" Command="{Binding RedoCommand}"
                            IsEnabled="{Binding CanRedo}"
                            Background="#E2E8F0" Foreground="#0F172A" BorderBrush="#CBD5E1"
                            Padding="10,6" Margin="0,0,6,0"/>
                    <Separator Style="{x:Null}" Width="1" Background="#D7DFEA" Margin="6,4"/>
                    <TextBlock Text="主题:" Foreground="#64748B" VerticalAlignment="Center" Margin="6,0,8,0"/>
                    <ComboBox ItemsSource="{Binding ThemePresets}"
                              SelectedItem="{Binding SelectedTheme}"
                              DisplayMemberPath="Name"
                              Width="120"
                              Margin="0,0,10,0"/>
                    <Button Content="应用主题" Command="{Binding ApplyThemeCommand}"
                            CommandParameter="{Binding SelectedTheme}"
                            Background="#3B82F6" Foreground="White" BorderBrush="#3B82F6"
                            Padding="10,6" Margin="0,0,6,0"/>
                    <Separator Style="{x:Null}" Width="1" Background="#D7DFEA" Margin="6,4"/>
                    <Button Content="💾 保存" Command="{Binding SaveCommand}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            Padding="14,6" Margin="0,0,6,0" FontWeight="SemiBold"
                            ToolTip="保存工程到 project.json（不刷新运行时）"/>
                    <Button Content="🚀 发布到运行时" Command="{Binding PublishCommand}"
                            Background="#7C3AED" Foreground="White" BorderBrush="#7C3AED"
                            Padding="14,6" Margin="0,0,10,0" FontWeight="SemiBold"
                            ToolTip="保存并立即刷新运行时页面"/>
                    <!-- 保存状态徽章：有内容时显示绿底白字，没内容时不可见 -->
                    <Border Background="#10B981" CornerRadius="12" Padding="10,4"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SaveStatus}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 1: 三栏布局 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左栏：页面树 + 工具箱 ===== -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 工程名称 -->
                        <TextBlock Text="工程名称" Foreground="#475569"/>
                        <TextBox Text="{Binding Document.ProjectName, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,4,0,10"/>

                        <!-- 页面列表 -->
                        <TextBlock Text="页面列表" FontSize="14" FontWeight="SemiBold" 
                                   Foreground="#0F172A" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Document.Pages}" 
                                 SelectedItem="{Binding SelectedPage}"
                                 DisplayMemberPath="Title"
                                 MaxHeight="240"
                                 BorderBrush="#D7DFEA"
                                 Background="#FFFFFF"
                                 Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="新建页面" Command="{Binding AddPageCommand}"
                                    Background="#374151" Foreground="White" BorderBrush="#374151"
                                    Padding="10,6" Margin="0,0,6,6"/>
                            <Button Content="删除页面" Command="{Binding RemovePageCommand}"
                                    Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                    Padding="10,6" Margin="0,0,6,6"/>
                        </WrapPanel>

                        <!-- 当前页面属性 -->
                        <TextBlock Text="页面设置" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#0F172A" Margin="0,0,0,8"/>
                        <TextBlock Text="页面标题" Foreground="#475569"/>
                        <TextBox Text="{Binding SelectedPage.Title, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>
                        <TextBlock Text="路由键" Foreground="#475569"/>
                        <TextBox Text="{Binding SelectedPage.RouteKey, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,8"/>
                        <TextBlock Text="画布尺寸" Foreground="#475569"/>
                        <UniformGrid Columns="2" Margin="0,4,0,10">
                            <TextBox Text="{Binding SelectedPage.CanvasWidth, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,6,0"/>
                            <TextBox Text="{Binding SelectedPage.CanvasHeight, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="6,0,0,0"/>
                        </UniformGrid>

                        <!-- 工具箱 -->
                        <TextBlock Text="工具箱" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#0F172A" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="ToolboxItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,6" Padding="10"
                                            Background="#F8FAFC" Foreground="#334155"
                                            BorderBrush="#D7DFEA"
                                            Command="{Binding DataContext.AddWidgetCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            PreviewMouseMove="ToolboxItem_PreviewMouseMove">
                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 批量生成功能块 -->
                        <Border Margin="0,16,0,0" Padding="10" CornerRadius="8"
                                Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="批量生成功能块" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#0369A1" Margin="0,0,0,8"/>

                                <TextBlock Text="功能块类型" Foreground="#475569" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding BatchBlockTypes}"
                                          SelectedValue="{Binding BatchBlockType}"
                                          Margin="0,4,0,8" FontSize="12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}">
                                                        <Binding/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="命名前缀（如 CYL → CYL1, CYL2…）" Foreground="#475569" FontSize="12"/>
                                <TextBox Text="{Binding BatchNamePrefix, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,8" FontSize="12"/>

                                <TextBlock Text="数量（1-20）" Foreground="#475569" FontSize="12"/>
                                <TextBox Text="{Binding BatchCount, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,8" FontSize="12"/>

                                <TextBlock Text="起始位置 (X, Y)" Foreground="#475569" FontSize="12"/>
                                <UniformGrid Columns="2" Margin="0,4,0,8">
                                    <TextBox Text="{Binding BatchStartX, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,4,0" FontSize="12"/>
                                    <TextBox Text="{Binding BatchStartY, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="4,0,0,0" FontSize="12"/>
                                </UniformGrid>

                                <CheckBox Content="水平排列（取消则垂直）"
                                          IsChecked="{Binding BatchLayoutHorizontal}"
                                          Margin="0,0,0,10" FontSize="12" Foreground="#475569"/>

                                <Button Content="批量生成" Command="{Binding BatchGenerateCommand}"
                                        Background="#0369A1" Foreground="White" BorderBrush="#0369A1"
                                        Padding="10,8" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== 中栏：设计画布 ===== -->
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="设计画布" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding CurrentWidgets.Count, Mode=OneWay, StringFormat=控件数: {0}}"
                                   Foreground="#64748B" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="DesignerCanvas"
                                Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}"
                                Background="#E2E8F0"
                                ClipToBounds="True"
                                AllowDrop="True"
                                DragOver="DesignerCanvas_DragOver"
                                Drop="DesignerCanvas_Drop">
                            <ListBox ItemsSource="{Binding CurrentWidgetItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     Width="{Binding SelectedPage.CanvasWidth, FallbackValue=1280}"
                                     Height="{Binding SelectedPage.CanvasHeight, FallbackValue=720}">
                                <ListBox.Template>
                                    <ControlTemplate TargetType="ListBox">
                                        <ItemsPresenter/>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Canvas.Left" Value="{Binding Model.X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Model.Y}"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:DesignerWidgetItem}">
                                        <!-- 选中层 Border：捕获鼠标 + 显示选中边框，内部为预创建的真容视图 -->
                                        <Border Width="{Binding Model.Width}"
                                                Height="{Binding Model.Height}"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="2"
                                                MouseLeftButtonDown="Widget_MouseLeftButtonDown"
                                                MouseMove="Widget_MouseMove"
                                                MouseLeftButtonUp="Widget_MouseLeftButtonUp">
                                            <ContentPresenter Content="{Binding View}"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Canvas>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ===== 右栏：属性编辑器 ===== -->
            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="属性编辑器" FontSize="18" FontWeight="Bold" 
                                   Foreground="#0F172A" Margin="0,0,0,12"/>

                        <!-- 未选中控件时的提示 -->
                        <TextBlock Text="请从画布中选中一个控件"
                                   Foreground="#94A3B8" FontSize="13"
                                   Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>

                        <!-- 控件基本信息 -->
                        <StackPanel Visibility="{Binding SelectedWidget, Converter={StaticResource NullToVisibilityConverter}}">
                            <WrapPanel Margin="0,0,0,10">
                                <Button Content="删除" Command="{Binding RemoveSelectedWidgetCommand}"
                                        Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                                        Padding="10,6" Margin="0,0,6,6"/>
                            </WrapPanel>

                            <TextBlock Text="控件ID" Foreground="#475569"/>
                            <TextBox Text="{Binding SelectedWidget.Id, Mode=OneWay}" 
                                     IsReadOnly="True" Margin="0,4,0,8"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="类型" Foreground="#475569"/>
                            <TextBox Text="{Binding SelectedWidget.TypeId, Mode=OneWay}" 
                                     IsReadOnly="True" Margin="0,4,0,8"
                                     Background="#F1F5F9"/>

                            <!-- 位置 -->
                            <TextBlock Text="位置 (X, Y)" Foreground="#475569"/>
                            <UniformGrid Columns="2" Margin="0,4,0,8">
                                <TextBox Text="{Binding SelectedWidget.X, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,6,0"/>
                                <TextBox Text="{Binding SelectedWidget.Y, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="6,0,0,0"/>
                            </UniformGrid>

                            <!-- 尺寸 -->
                            <TextBlock Text="尺寸 (宽, 高)" Foreground="#475569"/>
                            <UniformGrid Columns="2" Margin="0,4,0,10">
                                <TextBox Text="{Binding SelectedWidget.Width, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,6,0"/>
                                <TextBox Text="{Binding SelectedWidget.Height, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="6,0,0,0"/>
                            </UniformGrid>

                            <!-- 类型特定属性 （B-06: 动态属性网格） -->
                            <TextBlock Text="控件属性" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0F172A" Margin="0,8,0,8"/>
                            <ItemsControl ItemsSource="{Binding CurrentWidgetProperties}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="92"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       Foreground="#475569"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       ToolTip="{Binding Key}"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalAlignment="Center"/>
                                            <!-- 颜色属性显示色板预览 -->
                                            <Border Grid.Column="2"
                                                    Width="22" Height="22" CornerRadius="4"
                                                    Margin="6,0,0,0" BorderBrush="#CBD5E1" BorderThickness="1"
                                                    Visibility="{Binding IsColorProperty, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Background="{Binding Value, Converter={StaticResource StringToBrushConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 数据绑定（B-07） -->
                            <TextBlock Text="数据绑定" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#0F172A" Margin="0,8,0,8"/>
                            <TextBlock Text="绑定 Tag" Foreground="#475569"/>
                            <ComboBox ItemsSource="{Binding AvailableTags}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Name"
                                      SelectedValue="{Binding CurrentBindingTagId, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,4,0,10"
                                      IsEditable="False"
                                      ToolTip="选择要绑定的 OPC UA Tag，留空取消绑定"/>

                            <!-- 动作配置 -->
                            <TextBlock Text="动作类型" Foreground="#475569"/>
                            <ComboBox Margin="0,4,0,8"
                                      SelectedValue="{Binding SelectedWidget.ActionType, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="无"/>
                                <ComboBoxItem Content="write-bool"/>
                                <ComboBoxItem Content="navigate"/>
                            </ComboBox>

                            <TextBlock Text="动作参数" Foreground="#475569"/>
                            <TextBox Text="{Binding SelectedWidget.ActionParam, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,8"
                                     ToolTip="write-bool: 写入值; navigate: 目标 RouteKey"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
