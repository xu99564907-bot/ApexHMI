<Window x:Class="ApexHMI.Views.Dialogs.RecipeHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配方历史版本" Height="460" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#0F172A">
                <Run Text="配方："/>
                <Run Text="{Binding Name}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#64748B" Margin="0,4,0,0"
                       Text="每次【用当前参数覆盖配方】会自动入栈，最近 10 条。选择一条点【回滚】恢复到该版本。"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="HistoryGrid"
                  ItemsSource="{Binding History}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                  BorderBrush="#CBD5E1" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="*"/>
                <DataGridTextColumn Header="操作人" Binding="{Binding User}" Width="*"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Header="参数数" Binding="{Binding Parameters.Count}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="回滚到选中版本" Click="Restore_Click"
                    Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                    Width="140" Height="32" Margin="0,0,8,0"/>
            <Button Content="关闭" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
