<Window x:Class="ApexHMI.Views.Dialogs.StyleEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="全局样式编辑器" Height="560" Width="820"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"
                       Text="全局样式：色板 + 字体预设"/>
            <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Text="控件属性值写 {style:colors/primary} 或 {style:fonts/title} 即可引用此处定义。改一处，所有引用处联动。"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#CBD5E1">
            <!-- 色板 -->
            <TabItem Header="色板">
                <DockPanel Margin="6">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="新增色板" Padding="10,4" Click="OnAddColor"/>
                        <Button Content="删除选中" Padding="10,4" Margin="6,0,0,0" Click="OnRemoveColor"/>
                    </StackPanel>
                    <DataGrid x:Name="ColorGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" RowBackground="White"
                              AlternatingRowBackground="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Key (英文)" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                            <DataGridTextColumn Header="值 (#RRGGBB)" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTemplateColumn Header="预览" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Value}" Margin="2" BorderBrush="#CBD5E1" BorderThickness="1"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- 字体 -->
            <TabItem Header="字体预设">
                <DockPanel Margin="6">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="新增字体" Padding="10,4" Click="OnAddFont"/>
                        <Button Content="删除选中" Padding="10,4" Margin="6,0,0,0" Click="OnRemoveFont"/>
                    </StackPanel>
                    <DataGrid x:Name="FontGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" RowBackground="White"
                              AlternatingRowBackground="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Key" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Family" Binding="{Binding Family, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                            <DataGridTextColumn Header="Weight" Binding="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                            <DataGridTemplateColumn Header="预览" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="样张 Ag 中文 123"
                                                   FontFamily="{Binding Family}"
                                                   FontSize="{Binding Size}"
                                                   FontWeight="{Binding Weight}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Padding="20,6" Click="OnOk" IsDefault="True"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
            <Button Content="取消" Padding="20,6" Margin="8,0,0,0" Click="OnCancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
