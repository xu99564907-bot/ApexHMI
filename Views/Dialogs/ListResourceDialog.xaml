<Window x:Class="ApexHMI.Views.Dialogs.ListResourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="列表资源（文本 / 图形）" Height="560" Width="900"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"
                       Text="列表资源 — 文本列表 / 图形列表"/>
            <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Text="io-symbolic 控件 entries 写 {textList:运行状态} 即可引用；io-graphic 写 {graphicList:状态图}。"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#CBD5E1">
            <!-- 文本列表 -->
            <TabItem Header="文本列表（INT → 文字）">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0" Margin="0,0,6,0">
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ 新建" Padding="8,4" Click="OnAddTextList"/>
                            <Button Content="× 删除" Padding="8,4" Margin="4,0,0,0" Click="OnRemoveTextList"/>
                        </StackPanel>
                        <ListBox x:Name="TextListsList" DisplayMemberPath="Name"
                                 SelectionChanged="OnTextListSelected"
                                 BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </DockPanel>
                    <DockPanel Grid.Column="1">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="名称：" VerticalAlignment="Center"/>
                            <TextBox x:Name="TextListNameBox" VerticalAlignment="Center"
                                     TextChanged="OnTextListNameChanged"/>
                        </DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ 新增条目" Padding="8,4" Click="OnAddTextItem"/>
                            <Button Content="× 删除条目" Padding="8,4" Margin="4,0,0,0" Click="OnRemoveTextItem"/>
                        </StackPanel>
                        <DataGrid x:Name="TextItemsGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                                  BorderBrush="#CBD5E1" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Value (INT)"
                                                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                <DataGridTextColumn Header="文本"
                                                    Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- 图形列表 -->
            <TabItem Header="图形列表（INT → 图片）">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0" Margin="0,0,6,0">
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ 新建" Padding="8,4" Click="OnAddGraphicList"/>
                            <Button Content="× 删除" Padding="8,4" Margin="4,0,0,0" Click="OnRemoveGraphicList"/>
                        </StackPanel>
                        <ListBox x:Name="GraphicListsList" DisplayMemberPath="Name"
                                 SelectionChanged="OnGraphicListSelected"
                                 BorderBrush="#CBD5E1" BorderThickness="1"/>
                    </DockPanel>
                    <DockPanel Grid.Column="1">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="名称：" VerticalAlignment="Center"/>
                            <TextBox x:Name="GraphicListNameBox" VerticalAlignment="Center"
                                     TextChanged="OnGraphicListNameChanged"/>
                        </DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ 新增条目" Padding="8,4" Click="OnAddGraphicItem"/>
                            <Button Content="× 删除条目" Padding="8,4" Margin="4,0,0,0" Click="OnRemoveGraphicItem"/>
                        </StackPanel>
                        <DataGrid x:Name="GraphicItemsGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                                  BorderBrush="#CBD5E1" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Value (INT)"
                                                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                <DataGridTextColumn Header="图片路径"
                                                    Binding="{Binding Image, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Padding="20,6" Click="OnOk" IsDefault="True"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
            <Button Content="取消" Padding="20,6" Margin="8,0,0,0" Click="OnCancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
