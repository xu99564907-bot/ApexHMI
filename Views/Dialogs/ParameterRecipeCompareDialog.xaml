<Window x:Class="ApexHMI.Views.Dialogs.ParameterRecipeCompareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="与配方对比" Height="240" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="{DynamicResource Brush.Text}"
                   Text="选择要与当前参数对比的配方：" Margin="0,0,0,8"/>
        <ComboBox Grid.Row="1" x:Name="RecipeCombo"
                  ItemsSource="{Binding}"
                  DisplayMemberPath="Name"
                  Height="32" FontSize="14"/>
        <CheckBox Grid.Row="2" x:Name="ApplyCheck"
                  Content="对比后一键应用该配方到当前参数（差异行 → 配方值）"
                  Margin="0,12,0,0" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}"/>
        <TextBlock Grid.Row="3" FontSize="12" Foreground="{DynamicResource Brush.TextPlaceholder}"
                   Text="点击「对比」后，所有 HMI 变量值与配方不同的行会以蓝底高亮。再次切换/清除可点「关闭」。"
                   TextWrapping="Wrap" Margin="0,12,0,0"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="对比" Width="80" Height="32" Margin="0,0,8,0"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                    Click="Compare_Click"/>
            <Button Content="关闭" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
