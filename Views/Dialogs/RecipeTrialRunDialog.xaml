<Window x:Class="ApexHMI.Views.Dialogs.RecipeTrialRunDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配方试运行" Height="220" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8">
            <Run Text="试运行配方："/>
            <Run Text="{Binding Name}" FontWeight="Bold"/>
        </TextBlock>
        <TextBlock Grid.Row="1" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,0,0,8"
                   Text="将配方加载到参数页（不切换 Active），空跑指定件数验证。"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
            <TextBlock Text="空跑件数：" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="QtyBox" Text="10" Width="100" Height="28" FontSize="14"
                     VerticalContentAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="开始试运行" Click="Confirm_Click"
                    Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                    Width="110" Height="32" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
