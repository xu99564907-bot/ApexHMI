<Window x:Class="ApexHMI.Views.Dialogs.ParameterHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="参数变更历史" Height="440" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#0F172A">
                <Run Text="参数："/>
                <Run Text="{Binding Name}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#64748B" Margin="0,4,0,0"
                       Text="{Binding Description}" TextWrapping="Wrap"/>
            <TextBlock FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0">
                <Run Text="基线值（OriginalValue）："/>
                <Run Text="{Binding OriginalValue}"/>
                <Run Text="    当前值："/>
                <Run Text="{Binding Value}"/>
            </TextBlock>
        </StackPanel>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ChangeHistory}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                  BorderBrush="#CBD5E1" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="*"/>
                <DataGridTextColumn Header="用户" Binding="{Binding User}" Width="*"/>
                <DataGridTextColumn Header="旧值" Binding="{Binding OldValue}" Width="*"/>
                <DataGridTextColumn Header="新值" Binding="{Binding NewValue}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="关闭" IsCancel="True" Width="90" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
