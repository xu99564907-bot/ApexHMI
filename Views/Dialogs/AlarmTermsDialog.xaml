<Window x:Class="ApexHMI.Views.Dialogs.AlarmTermsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ApexHMI.ViewModels.Modules"
        Title="中文工业术语对照表" Height="560" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC">
    <Window.DataContext>
        <vm:AlarmTermsViewModel/>
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 说明 -->
        <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="12" Foreground="#475569"
                   TextWrapping="Wrap"
                   Text="按中文由长到短排列，优先匹配更长的词组。修改后点击「保存」立即生效，下次生成时使用新对照表。"/>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Terms}"
                  SelectedItem="{Binding SelectedTerm}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#CBD5E1" BorderThickness="1"
                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="中文术语" Binding="{Binding Cn, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                <DataGridTextColumn Header="英文缩写" Binding="{Binding En, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="↑" Width="24" Height="22" Margin="1,0"
                                        FontSize="11" Padding="0"
                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"/>
                                <Button Content="↓" Width="24" Height="22" Margin="1,0"
                                        FontSize="11" Padding="0"
                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="×" Width="28" Height="22" Margin="2,0"
                                    FontSize="13" Padding="0"
                                    Foreground="#DC2626" Background="Transparent" BorderThickness="0"
                                    Command="{Binding DataContext.DeleteTermCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部工具栏 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4">
            <Button Content="+ 新增" Command="{Binding AddTermCommand}"
                    Padding="10,4" FontSize="13" Margin="0,0,8,0"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       FontSize="12" Foreground="#16A34A" Margin="4,0"/>
        </StackPanel>

        <!-- 确认/取消按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="恢复默认" Command="{Binding ResetCommand}"
                    Padding="14,5" FontSize="13" Margin="0,0,8,0"
                    Background="#F59E0B" Foreground="White" BorderBrush="#F59E0B"
                    ToolTip="恢复内置默认对照表（不可撤销）"/>
            <Button Content="保存并关闭" Command="{Binding SaveCommand}"
                    Padding="14,5" FontSize="13" Margin="0,0,8,0"
                    Background="#16A34A" Foreground="White" BorderBrush="#16A34A"
                    Click="SaveAndClose_Click"/>
            <Button Content="关闭" IsCancel="True"
                    Padding="14,5" FontSize="13"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
