<Window x:Class="ApexHMI.Views.Dialogs.RecipeCompareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配方对比" Height="540" Width="780"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                   Text="选择两个配方进行对比，点【对比】按钮。差异行会以蓝底高亮，相同参数自动隐藏。"
                   TextWrapping="Wrap"/>
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="配方 A：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ComboA" Width="200" Height="28"
                          ItemsSource="{Binding}" DisplayMemberPath="Name"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                <TextBlock Text="配方 B：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ComboB" Width="200" Height="28"
                          ItemsSource="{Binding}" DisplayMemberPath="Name"/>
            </StackPanel>
            <Button Grid.Column="2" Content="对比"
                    Click="Compare_Click"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                    Padding="14,5" Width="80" Height="28"/>
        </Grid>
        <DataGrid Grid.Row="2" x:Name="DiffGrid"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                  BorderBrush="#CBD5E1" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="参数名" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="A 值" Binding="{Binding ValueA}" Width="*"/>
                <DataGridTextColumn Header="B 值" Binding="{Binding ValueB}" Width="*"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="80"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="关闭" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
