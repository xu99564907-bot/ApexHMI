<Window x:Class="ApexHMI.Views.Dialogs.RecipeDeleteReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="删除配方" Height="240" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="#0F172A" Margin="0,0,0,8">
            <Run Text="确认删除配方："/>
            <Run Text="{Binding Name}" FontWeight="Bold" Foreground="#B91C1C"/>
        </TextBlock>
        <TextBlock Grid.Row="1" FontSize="12" Foreground="#64748B" Margin="0,0,0,8"
                   Text="请填写删除原因（写入审计日志，便于事后追溯）："/>
        <TextBox Grid.Row="2" x:Name="ReasonBox" AcceptsReturn="True" TextWrapping="Wrap"
                 BorderBrush="#CBD5E1" BorderThickness="1" Padding="8" FontSize="13"
                 VerticalScrollBarVisibility="Auto"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="确认删除" Click="Confirm_Click"
                    Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                    Width="100" Height="32" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
