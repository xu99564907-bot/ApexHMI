<Window x:Class="ApexHMI.Views.Dialogs.TextResourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="多语言文本资源" Height="560" Width="880"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"
                       Text="多语言文本资源"/>
            <TextBlock FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Text="控件文本字段写 {text:keyName} 即可引用此处文本，切换当前语言时所有引用处自动刷新。"/>
        </StackPanel>

        <!-- 支持语言行 -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="支持语言（逗号分隔）" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="默认语言：" VerticalAlignment="Center" Margin="10,0,4,0"/>
            <ComboBox x:Name="DefaultLangCombo" Width="100" VerticalAlignment="Center"
                      DockPanel.Dock="Right" Margin="0,0,0,0"/>
            <TextBox x:Name="SupportedLangsText" VerticalAlignment="Center"
                     LostFocus="OnSupportedLangsChanged"/>
        </DockPanel>

        <DataGrid x:Name="EntriesGrid" Grid.Row="2"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                  BorderBrush="#CBD5E1" BorderThickness="1"/>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="新增条目" Padding="10,4" Click="OnAddEntry"/>
                <Button Content="删除选中" Padding="10,4" Margin="6,0,0,0" Click="OnRemoveEntry"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="确定" Padding="20,6" Click="OnOk" IsDefault="True"
                        Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
                <Button Content="取消" Padding="20,6" Margin="8,0,0,0" Click="OnCancel" IsCancel="True"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
