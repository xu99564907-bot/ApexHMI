<Window x:Class="ApexHMI.Views.Dialogs.SwitchUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="切换用户" Height="280" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                   Text="{Binding Title}"/>
        <TextBlock Grid.Row="1" Text="角色：" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="2" x:Name="RoleCombo" Height="30" FontSize="14" Margin="0,0,0,12">
            <ComboBoxItem Content="Operator"/>
            <ComboBoxItem Content="Engineer"/>
            <ComboBoxItem Content="Administrator" IsSelected="True"/>
        </ComboBox>
        <TextBlock Grid.Row="3" Text="密码：" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="4" x:Name="PwdBox" Height="30" FontSize="14"/>
        <TextBlock Grid.Row="5" FontSize="11" Foreground="{DynamicResource Brush.TextPlaceholder}" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="{Binding Hint}"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="确认" Click="Confirm_Click" Width="80" Height="32" Margin="0,0,8,0"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
            <Button Content="取消" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
