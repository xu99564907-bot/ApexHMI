<Window x:Class="ApexHMI.Views.Dialogs.OpcUaWriteTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPC UA 写入测试" Height="280" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="目标节点：" Foreground="{DynamicResource Brush.TextSecondary}"/>
        <TextBlock Grid.Row="1" x:Name="TargetText" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="0,4,0,12"
                   TextTrimming="CharacterEllipsis"/>
        <TextBlock Grid.Row="2" Text="写入值：" Foreground="{DynamicResource Brush.TextSecondary}"/>
        <TextBox Grid.Row="3" x:Name="ValueBox" Margin="0,4,0,8" Height="30"/>
        <TextBlock Grid.Row="4" FontSize="11" Foreground="{DynamicResource Brush.TextPlaceholder}" TextWrapping="Wrap"
                   Text="提示：写入后会自动回读验证一次，并写入审计日志。仅当设备非自动模式 + 工程师权限可用。"/>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="写入并回读" Click="Confirm_Click" Width="110" Height="32" Margin="0,0,8,0"
                    Background="#0F766E" Foreground="White" BorderBrush="#0F766E"/>
            <Button Content="取消" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
