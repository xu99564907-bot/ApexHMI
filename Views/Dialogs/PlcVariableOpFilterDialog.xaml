<Window x:Class="ApexHMI.Views.Dialogs.PlcVariableOpFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择要导入的工位"
        Width="380" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="勾选要导入的工位 OP 号" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="0" x:Name="SummaryText" HorizontalAlignment="Right" Foreground="#64748B" FontSize="11" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="全选" Click="SelectAll_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="全不选" Click="SelectNone_Click" Padding="8,3" Margin="0,0,6,0"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="OpListItems" Padding="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Content="{Binding DisplayText}"
                                      Margin="0,3"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" IsCancel="True" Padding="14,4" Margin="0,0,6,0"/>
            <Button Content="确定 导入" IsDefault="True" Click="Ok_Click"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB" Padding="14,4"/>
        </StackPanel>
    </Grid>
</Window>
