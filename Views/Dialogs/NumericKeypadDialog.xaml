<Window x:Class="ApexHMI.Views.Dialogs.NumericKeypadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数字键盘" Height="380" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#F8FAFC">
    <Window.Resources>
        <Style TargetType="Button" x:Key="KeyBtn">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" x:Name="PreviewBox"
                 Height="44" FontSize="22" Padding="8,6"
                 HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                 Background="#FFFFFF" BorderBrush="#CBD5E1"/>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Row="0" Grid.Column="0" Content="7" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="0" Grid.Column="3" Content="←" Style="{StaticResource KeyBtn}" Click="OnBackspace"/>

            <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="1" Grid.Column="3" Content="Clr" Style="{StaticResource KeyBtn}" Click="OnClear"/>

            <Button Grid.Row="2" Grid.Column="0" Content="1" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="2" Grid.Column="3" Content="±" Style="{StaticResource KeyBtn}" Click="OnSign"/>

            <Button Grid.Row="3" Grid.Column="0" Content="0" Style="{StaticResource KeyBtn}" Click="OnDigit"/>
            <Button Grid.Row="3" Grid.Column="1" Content="." Style="{StaticResource KeyBtn}" Click="OnDot"/>
            <Button Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Content="Enter"
                    Background="#2563EB" Foreground="White" Style="{StaticResource KeyBtn}" Click="OnEnter"/>
        </Grid>

        <Button Grid.Row="2" Content="Esc 取消" Margin="0,6,0,0" Padding="8,6"
                HorizontalAlignment="Right" MinWidth="100" Click="OnCancel"
                Background="#FEE2E2" BorderBrush="#FCA5A5"/>
    </Grid>
</Window>
