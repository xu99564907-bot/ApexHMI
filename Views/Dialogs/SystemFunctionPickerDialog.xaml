<Window x:Class="ApexHMI.Views.Dialogs.SystemFunctionPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择系统函数" Width="520" Height="540"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="按分类选择动作类型；双击或确定即可加入。"
                   Foreground="#64748B" FontSize="12" Margin="0,0,0,8"/>
        <TreeView Grid.Row="1" x:Name="FunctionTree"
                  BorderBrush="#CBD5E1"
                  MouseDoubleClick="OnDoubleClick"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" IsCancel="True" Padding="14,4" Margin="0,0,8,0"/>
            <Button Content="确定" IsDefault="True" Click="OnOk"
                    Padding="14,4"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"/>
        </StackPanel>
    </Grid>
</Window>
