<Window x:Class="ApexHMI.Views.Dialogs.ParameterDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="本次参数修改" Height="480" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="#475569" Margin="0,0,0,8"
                   Text="下表列出当前会话内已修改但与基线不同的参数。基线在「加载参数」/「保存参数」时刷新。"
                   TextWrapping="Wrap"/>
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  RowBackground="White" AlternatingRowBackground="#F1F5F9"
                  BorderBrush="#CBD5E1" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="分组" Binding="{Binding Category}" Width="*"/>
                <DataGridTextColumn Header="HMI变量" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="原值" Binding="{Binding OriginalValue}" Width="*"/>
                <DataGridTextColumn Header="新值" Binding="{Binding Value}" Width="*"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="关闭" IsCancel="True" Width="90" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
