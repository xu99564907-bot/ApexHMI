<Window x:Class="ApexHMI.Views.Dialogs.PasswordPolicyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码策略配置" Height="460" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,12" FontSize="12" Foreground="#475569"
                   TextWrapping="Wrap"
                   Text="修改后立即保存到 config/password-policy.json，下次校验密码时生效。仅管理员可访问。"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="最小长度 (MinLength)" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtMinLength" VerticalAlignment="Center" Padding="4,2"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="必须包含数字 (RequireDigits)" VerticalAlignment="Center"/>
            <CheckBox  Grid.Row="1" Grid.Column="1" x:Name="ChkRequireDigits" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="必须包含字母 (RequireLetters)" VerticalAlignment="Center"/>
            <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="ChkRequireLetters" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="必须包含特殊字符 (RequireSpecial)" VerticalAlignment="Center"/>
            <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="ChkRequireSpecial" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="历史不重复条数 (HistoryCount)" VerticalAlignment="Center"
                       ToolTip="0 = 关闭历史检查"/>
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtHistoryCount" VerticalAlignment="Center" Padding="4,2"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="最长有效期 / 天 (MaxAgeDays)" VerticalAlignment="Center"
                       ToolTip="0 = 永不过期"/>
            <TextBox   Grid.Row="5" Grid.Column="1" x:Name="TxtMaxAgeDays" VerticalAlignment="Center" Padding="4,2"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="过期前提醒 / 天 (WarnDaysBeforeExpire)" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="6" Grid.Column="1" x:Name="TxtWarnDaysBeforeExpire" VerticalAlignment="Center" Padding="4,2"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="保存" Width="80" Height="30" Margin="0,0,8,0"
                    Background="#16A34A" Foreground="White" BorderBrush="#16A34A"
                    Click="Save_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Height="30"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
