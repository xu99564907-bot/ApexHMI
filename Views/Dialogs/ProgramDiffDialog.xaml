<Window x:Class="ApexHMI.Views.Dialogs.ProgramDiffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="程序差异预览" Height="600" Width="1100"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource Brush.SurfaceAlt}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                   Text="左：Git 仓库中当前版本，右：本次生成内容。先目视比对再决定是否 commit。"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,4,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#E2E8F0" Padding="8,4">
                        <TextBlock Text="Git 当前版本" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}"/>
                    </Border>
                    <TextBlock DockPanel.Dock="Bottom" Margin="8,4" FontSize="11" Foreground="{DynamicResource Brush.TextPlaceholder}"
                               Text="{Binding LeftPath}" TextTrimming="CharacterEllipsis"/>
                    <TextBox Text="{Binding LeftContent, Mode=OneWay}"
                             IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{x:Null}"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
            <Border Grid.Column="1" BorderBrush="#CBD5E1" BorderThickness="1" Margin="4,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#DBEAFE" Padding="8,4">
                        <TextBlock Text="本次生成" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                    </Border>
                    <TextBlock DockPanel.Dock="Bottom" Margin="8,4" FontSize="11" Foreground="{DynamicResource Brush.TextPlaceholder}"
                               Text="{Binding RightPath}" TextTrimming="CharacterEllipsis"/>
                    <TextBox Text="{Binding RightContent, Mode=OneWay}"
                             IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="#FFFFFF" Foreground="{DynamicResource Brush.Text}" BorderBrush="{x:Null}"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button Content="关闭" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
