<Window x:Class="ApexHMI.Views.Dialogs.ParameterBatchEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量编辑参数" Height="380" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" FontSize="14" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,8"
                   Text="即将批量修改以下参数（仅可编辑权限内的项）："/>
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding}"
                 BorderBrush="#CBD5E1" BorderThickness="1" Background="White">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Width="160"/>
                        <TextBlock Text="当前=" Foreground="{DynamicResource Brush.TextMuted}"/>
                        <TextBlock Text="{Binding Value}" Foreground="{DynamicResource Brush.Text}" Margin="2,0,8,0"/>
                        <TextBlock Text="{Binding Unit}" Foreground="{DynamicResource Brush.TextPlaceholder}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,4">
            <TextBlock Text="新值：" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ValueBox" Width="280" Height="30" FontSize="14"
                     VerticalContentAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="应用" Width="80" Height="32" Margin="0,0,8,0"
                    Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                    Click="Apply_Click"/>
            <Button Content="取消" IsCancel="True" Width="80" Height="32"
                    Background="#64748B" Foreground="White" BorderBrush="#64748B"/>
        </StackPanel>
    </Grid>
</Window>
