<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.BarWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Border Background="{Binding BackgroundColor, Converter={StaticResource StringToBrushConverter}}"
                BorderBrush="#94A3B8" BorderThickness="1"/>
        <Grid x:Name="FillContainer">
            <!-- 垂直棒图：底部对齐，高度按比例 -->
            <Rectangle x:Name="VerticalFill"
                       Fill="{Binding CurrentFillColor, Converter={StaticResource StringToBrushConverter}}"
                       VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                       Visibility="{Binding IsVertical, Converter={StaticResource BoolToVis}}"/>
            <!-- 水平棒图：左对齐，宽度按比例 -->
            <Rectangle x:Name="HorizontalFill"
                       Fill="{Binding CurrentFillColor, Converter={StaticResource StringToBrushConverter}}"
                       HorizontalAlignment="Left" VerticalAlignment="Stretch">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsVertical}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>
        </Grid>
        <!-- 数值标签居中 -->
        <TextBlock Text="{Binding DisplayText}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#0F172A" FontWeight="SemiBold" FontSize="12"
                   Visibility="{Binding ShowLabel, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>
