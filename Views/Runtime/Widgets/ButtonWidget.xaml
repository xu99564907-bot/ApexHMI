<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ButtonWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Button Command="{Binding ClickCommand}"
            Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}"
            Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
            BorderBrush="{Binding Background, Converter={StaticResource StringToBrushConverter}}"
            BorderThickness="1" Padding="8,4"
            FontSize="13" Cursor="Hand">
        <TextBlock Text="{Binding Text}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Button>
</UserControl>
