<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.CameraViewWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Border BorderBrush="#94A3B8" BorderThickness="1"
            Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}">
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding DesignPlaceholderVisibility}">
                <TextBlock Text="[摄像头预览]" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Url}" Foreground="#64748B" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
            <vlc:VideoView x:Name="Video" Visibility="{Binding RuntimeViewVisibility}"/>
        </Grid>
    </Border>
</UserControl>
