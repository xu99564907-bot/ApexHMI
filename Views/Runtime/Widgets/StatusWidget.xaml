<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.StatusWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1"
            CornerRadius="6" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{Binding Label}" Foreground="#64748B" FontSize="11"
                       Margin="0,0,0,2"/>

            <Ellipse Grid.Row="1" Grid.Column="0"
                     Width="12" Height="12"
                     Fill="{Binding CurrentColor, Converter={StaticResource StringToBrushConverter}}"
                     VerticalAlignment="Center" Margin="0,0,6,0"/>

            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding StatusText}" Foreground="#0F172A"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
