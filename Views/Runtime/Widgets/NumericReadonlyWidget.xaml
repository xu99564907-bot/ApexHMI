<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.NumericReadonlyWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1"
            CornerRadius="6" Padding="8">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding Label}" Foreground="#64748B" FontSize="11"/>
            <TextBlock Text="{Binding DisplayValue}" Foreground="#0F172A"
                       FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                       Margin="0,2,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
