<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.IoSymbolicWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Grid Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}">
        <TextBlock Text="{Binding DisplayText}"
                   Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Padding="4,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInput}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <ComboBox ItemsSource="{Binding Entries}"
                  SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                  DisplayMemberPath="Text"
                  VerticalContentAlignment="Center"
                  SelectionChanged="ComboBox_SelectionChanged">
            <ComboBox.Style>
                <Style TargetType="ComboBox">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInput}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ComboBox.Style>
        </ComboBox>
    </Grid>
</UserControl>
