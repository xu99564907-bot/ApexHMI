<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.BoolLampWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <Ellipse Width="16" Height="16"
                 Fill="{Binding CurrentColor, Converter={StaticResource StringToBrushConverter}}"
                 Margin="0,0,6,0" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                   Foreground="#1F2937" FontSize="13"/>
    </StackPanel>
</UserControl>
