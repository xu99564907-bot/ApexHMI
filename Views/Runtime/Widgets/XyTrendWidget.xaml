<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.XyTrendWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Border BorderBrush="#94A3B8" BorderThickness="1" Background="#FFFFFF">
        <oxy:PlotView Model="{Binding PlotModel}"/>
    </Border>
</UserControl>
