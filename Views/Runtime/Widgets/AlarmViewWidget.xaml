<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.AlarmViewWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <Style x:Key="LevelCellStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Level}" Value="Alarm">
                    <Setter Property="Background" Value="#DC2626"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Error">
                    <Setter Property="Background" Value="#DC2626"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Warning">
                    <Setter Property="Background" Value="#FBBF24"/>
                    <Setter Property="Foreground" Value="#78350F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="Info">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#1E293B"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="#94A3B8" BorderThickness="1" Background="#FFFFFF">
        <DockPanel>
            <!-- 工具栏 -->
            <Border DockPanel.Dock="Top" Background="#F1F5F9" Padding="4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="确认所选" Command="{Binding AckSelectedCommand}" Margin="2" Padding="6,2" FontSize="12"/>
                    <Button Content="确认全部" Command="{Binding AckAllCommand}" Margin="2" Padding="6,2" FontSize="12"/>
                    <Button Content="导出 CSV" Command="{Binding ExportCsvCommand}" Margin="2" Padding="6,2" FontSize="12"/>
                    <Button Content="{Binding Paused, FallbackValue=暂停}" Command="{Binding TogglePauseCommand}" Margin="2" Padding="6,2" FontSize="12" ToolTip="暂停/继续刷新">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="暂停"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Paused}" Value="True">
                                        <Setter Property="Content" Value="继续"/>
                                        <Setter Property="Background" Value="#FBBF24"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="刷新" Command="{Binding RefreshCommand}" Margin="2" Padding="6,2" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- 报警表 -->
            <DataGrid ItemsSource="{Binding VisibleAlarms}"
                      SelectedItem="{Binding SelectedAlarm, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      RowHeight="22"
                      FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间"   Binding="{Binding Time, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="140"/>
                    <DataGridTemplateColumn Header="级别" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Level}" Style="{StaticResource LevelCellStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="来源"   Binding="{Binding Source}"  Width="120"/>
                    <DataGridTextColumn Header="内容"   Binding="{Binding Message}" Width="*"/>
                    <DataGridTextColumn Header="状态"   Binding="{Binding State}"   Width="80"/>
                    <DataGridTextColumn Header="次数"   Binding="{Binding Count}"   Width="50"/>
                    <DataGridTextColumn Header="确认人" Binding="{Binding AcknowledgedBy}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
