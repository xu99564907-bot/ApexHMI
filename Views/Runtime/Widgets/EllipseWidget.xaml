<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.EllipseWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             Opacity="{Binding Opacity}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Ellipse Fill="{Binding Fill, Converter={StaticResource StringToBrushConverter}}"
             Stroke="{Binding Stroke, Converter={StaticResource StringToBrushConverter}}"
             StrokeThickness="{Binding StrokeThickness}"/>
</UserControl>
