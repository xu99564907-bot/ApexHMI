<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.AlarmListWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Border Background="#FFFFFF" CornerRadius="8" BorderBrush="#D7DFEA" BorderThickness="1">
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="#FEE2E2" CornerRadius="8,8,0,0" Padding="10,6">
                <DockPanel>
                    <TextBlock Text="🚨 当前报警" FontWeight="Bold" Foreground="#991B1B" FontSize="13"/>
                    <TextBlock DockPanel.Dock="Right" Foreground="#991B1B" FontSize="11"
                               VerticalAlignment="Center">
                        <Run Text="共 "/><Run Text="{Binding Alarms.Count, Mode=OneWay}"/><Run Text=" 条"/>
                    </TextBlock>
                </DockPanel>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Alarms}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Time, StringFormat=HH:mm:ss}"
                                               FontFamily="Consolas" FontSize="11" Foreground="#64748B"
                                               Margin="0,0,8,0"/>
                                    <Border Grid.Column="1" Padding="4,1" CornerRadius="3" Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E2E8F0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                                        <Setter Property="Background" Value="#FCA5A5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Critical">
                                                        <Setter Property="Background" Value="#EF4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                        <Setter Property="Background" Value="#FCD34D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="Bold"
                                                   Foreground="#0F172A"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="11"
                                               Foreground="#0F172A" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="11"
                                               Foreground="#334155" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
