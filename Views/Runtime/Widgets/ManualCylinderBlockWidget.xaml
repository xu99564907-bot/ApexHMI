<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ManualCylinderBlockWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <Style x:Key="CylBtnBaseStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- 未绑定到具体气缸时显示占位 -->
        <Border BorderBrush="#FBBF24" BorderThickness="1" Background="#FEF3C7" CornerRadius="6"
                Padding="12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBlock}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="⚠ 气缸块" FontSize="13" FontWeight="Bold" Foreground="#92400E"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding PlaceholderText}" FontSize="11" Foreground="#92400E"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="请在右栏属性面板设置 deviceName" FontSize="10"
                           Foreground="#A16207" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 已绑定：显示完整气缸卡片 -->
        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#D7DFEA" BorderThickness="1"
                Padding="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBlock}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid DataContext="{Binding Block}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: 标题 -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#2563EB" FontSize="12"
                               FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Row 1: Work/Home 指令按钮 -->
                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,6">
                    <Button Command="{Binding DataContext.WorkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Padding="8,6" Margin="0,0,5,0" Focusable="False">
                        <Button.Content>
                            <StackPanel>
                                <TextBlock Text="{Binding WorkCommandLabel}" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding WorkCommandAddress}" HorizontalAlignment="Center"
                                           Foreground="#64748B" FontSize="9" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CylBtnBaseStyle}">
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WorkCommandActive}" Value="True">
                                        <Setter Property="Background" Value="#FFF0BF"/>
                                        <Setter Property="BorderBrush" Value="#D6A12E"/>
                                        <Setter Property="Foreground" Value="#5C3B00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding DataContext.HomeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Padding="8,6" Margin="5,0,0,0" Focusable="False">
                        <Button.Content>
                            <StackPanel>
                                <TextBlock Text="{Binding HomeCommandLabel}" HorizontalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding HomeCommandAddress}" HorizontalAlignment="Center"
                                           Foreground="#64748B" FontSize="9" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CylBtnBaseStyle}">
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HomeCommandActive}" Value="True">
                                        <Setter Property="Background" Value="#D9F4E1"/>
                                        <Setter Property="BorderBrush" Value="#63A77A"/>
                                        <Setter Property="Foreground" Value="#0B3B1F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </UniformGrid>

                <!-- Row 2: 位置传感器 -->
                <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,4">
                    <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1"
                            CornerRadius="6" Padding="6" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock Text="{Binding WorkPositionLabel}" Foreground="#64748B" FontSize="10"/>
                            <TextBlock Text="{Binding WorkSensorAddress}" Foreground="#94A3B8" FontSize="9" Margin="0,1,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Ellipse Width="9" Height="9" Margin="0,2,5,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkActive}" Value="True">
                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding WorkActive}" Foreground="#0F172A" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1"
                            CornerRadius="6" Padding="6" Margin="5,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding HomePositionLabel}" Foreground="#64748B" FontSize="10"/>
                            <TextBlock Text="{Binding HomeSensorAddress}" Foreground="#94A3B8" FontSize="9" Margin="0,1,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Ellipse Width="9" Height="9" Margin="0,2,5,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#CBD5E1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HomeActive}" Value="True">
                                                    <Setter Property="Fill" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding HomeActive}" Foreground="#0F172A" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Row 3: 状态提示 -->
                <Border Grid.Row="3" Background="#EFF6FF" BorderBrush="#BFDBFE"
                        BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentStateText}" Foreground="#1D4ED8"
                                   FontWeight="SemiBold" FontSize="10" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding InterlockHint}" Foreground="#1D4ED8"
                                   FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
