<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ClockWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Border Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}">
        <TextBlock Text="{Binding DisplayText}"
                   Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                   FontSize="{Binding FontSizeRaw}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   FontFamily="Consolas"/>
    </Border>
</UserControl>
