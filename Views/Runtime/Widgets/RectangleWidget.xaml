<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.RectangleWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             Opacity="{Binding Opacity}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Border Background="{Binding Fill, Converter={StaticResource StringToBrushConverter}}"
            BorderBrush="{Binding Stroke, Converter={StaticResource StringToBrushConverter}}"
            BorderThickness="{Binding StrokeThickness}"
            CornerRadius="{Binding CornerRadius}"/>
</UserControl>
