<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.AlarmIndicatorWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             Cursor="Hand">
    <UserControl.InputBindings>
        <MouseBinding MouseAction="LeftClick" Command="{Binding ClickCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Ellipse x:Name="Dot" Fill="{Binding IndicatorColor}">
            <Ellipse.Style>
                <Style TargetType="Ellipse">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAlarms}" Value="True">
                            <Setter Property="Opacity" Value="1.0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsNewAlarm}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1.0" To="0.3" Duration="0:0:0.25"
                                                         AutoReverse="True" RepeatBehavior="3x"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Ellipse.Style>
        </Ellipse>
        <TextBlock Text="{Binding ActiveCount}"
                   Foreground="{Binding Foreground}"
                   FontWeight="Bold"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>
