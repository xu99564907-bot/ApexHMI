<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.LineWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <conv:StringToDoubleCollectionConverter x:Key="StringToDoubleCollectionConverter"/>
    </UserControl.Resources>
    <Line X1="{Binding X1Px}" Y1="{Binding Y1Px}"
          X2="{Binding X2Px}" Y2="{Binding Y2Px}"
          Stroke="{Binding Stroke, Converter={StaticResource StringToBrushConverter}}"
          StrokeThickness="{Binding StrokeThickness}"
          StrokeDashArray="{Binding StrokeDashArray, Converter={StaticResource StringToDoubleCollectionConverter}}"
          SnapsToDevicePixels="True"/>
</UserControl>
