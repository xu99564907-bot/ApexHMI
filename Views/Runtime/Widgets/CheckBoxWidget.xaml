<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.CheckBoxWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <CheckBox Content="{Binding Text}"
              IsChecked="{Binding IsChecked, Mode=TwoWay}"
              Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
              VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0"/>
</UserControl>
