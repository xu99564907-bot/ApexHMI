<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.DateTimeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             IsEnabled="{Binding IsEnabledByOperator}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <conv:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>
        <conv:BoolToFontStyleConverter x:Key="BoolToFontStyle"/>
        <conv:BoolToTextDecorationsConverter x:Key="BoolToTextDecorations"/>
        <conv:BorderStyleVisibilityConverter x:Key="BorderStyleBrush"/>
    </UserControl.Resources>
    <Border Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}"
            BorderThickness="{Binding BorderWidthValue}"
            Padding="{Binding PaddingThickness}">
        <Border.BorderBrush>
            <MultiBinding Converter="{StaticResource BorderStyleBrush}">
                <Binding Path="BorderColor"/>
                <Binding Path="BorderStyleName"/>
            </MultiBinding>
        </Border.BorderBrush>
        <Grid>
            <TextBlock Text="{Binding DisplayText}"
                       Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                       FontFamily="{Binding FontFamilyName}"
                       FontWeight="{Binding FontBold, Converter={StaticResource BoolToFontWeight}}"
                       FontStyle="{Binding FontItalic, Converter={StaticResource BoolToFontStyle}}"
                       TextDecorations="{Binding FontUnderline, Converter={StaticResource BoolToTextDecorations}}"
                       VerticalAlignment="Center" TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInput}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <DockPanel>
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInput}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <DatePicker x:Name="EditDatePicker"
                            SelectedDate="{Binding EditDate, Mode=TwoWay}"
                            VerticalAlignment="Center" Width="120"
                            SelectedDateChanged="EditDatePicker_SelectedDateChanged"/>
                <TextBox Text="{Binding EditTime, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{Binding FontFamilyName}"
                         VerticalContentAlignment="Center" Margin="4,0,0,0"
                         KeyDown="EditTime_KeyDown" LostFocus="EditTime_LostFocus"
                         ToolTip="HH:mm:ss"/>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
