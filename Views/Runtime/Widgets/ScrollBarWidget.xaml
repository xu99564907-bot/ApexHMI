<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ScrollBarWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding DisplayText}"
                   VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" MinWidth="32"
                   Visibility="{Binding ShowValue, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <ScrollBar x:Name="ValueScrollBar"
                   Minimum="{Binding MinValue}"
                   Maximum="{Binding MaxValue}"
                   SmallChange="{Binding Step}"
                   LargeChange="{Binding Step}"
                   Orientation="{Binding Orientation}"
                   Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Thumb.DragCompleted="ValueScrollBar_DragCompleted"
                   VerticalAlignment="Center"/>
    </DockPanel>
</UserControl>
