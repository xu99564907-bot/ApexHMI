<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.IoNumericWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}">
        <!-- Output 模式（含 InputOutput 时也用 Output 视觉，但叠加 TextBox 在 Input 模式下） -->
        <TextBlock Text="{Binding DisplayText}"
                   Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                   TextAlignment="{Binding TextAlignment}"
                   VerticalAlignment="Center" HorizontalAlignment="Stretch"
                   Padding="4,0"
                   Visibility="{Binding IsInput, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInput}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                 Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                 TextAlignment="{Binding TextAlignment}"
                 VerticalContentAlignment="Center"
                 BorderThickness="1" BorderBrush="#CBD5E1"
                 KeyDown="EditBox_KeyDown" LostFocus="EditBox_LostFocus">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsInput}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>
    </Grid>
</UserControl>
