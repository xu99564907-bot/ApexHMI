<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.IoNumericWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             IsEnabled="{Binding IsEnabledByOperator}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <conv:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>
        <conv:BoolToFontStyleConverter x:Key="BoolToFontStyle"/>
        <conv:BoolToTextDecorationsConverter x:Key="BoolToTextDecorations"/>
        <conv:BorderStyleVisibilityConverter x:Key="BorderStyleBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
    <Border Background="{Binding EffectiveBackground, Converter={StaticResource StringToBrushConverter}}"
            BorderThickness="{Binding BorderWidthValue}"
            Padding="{Binding PaddingThickness}">
        <Border.BorderBrush>
            <MultiBinding Converter="{StaticResource BorderStyleBrush}">
                <Binding Path="EffectiveBorderColor"/>
                <Binding Path="BorderStyleName"/>
            </MultiBinding>
        </Border.BorderBrush>
        <Grid>
            <TextBlock Text="{Binding DisplayText}"
                       ToolTip="{Binding TooltipText}"
                       Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                       FontSize="{Binding FontSizeRaw}"
                       FontFamily="{Binding FontFamilyName}"
                       FontWeight="{Binding FontBold, Converter={StaticResource BoolToFontWeight}}"
                       FontStyle="{Binding FontItalic, Converter={StaticResource BoolToFontStyle}}"
                       TextDecorations="{Binding FontUnderline, Converter={StaticResource BoolToTextDecorations}}"
                       TextAlignment="{Binding TextAlignment}"
                       VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInput}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                     Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                     FontSize="{Binding FontSizeRaw}"
                     FontFamily="{Binding FontFamilyName}"
                     FontWeight="{Binding FontBold, Converter={StaticResource BoolToFontWeight}}"
                     FontStyle="{Binding FontItalic, Converter={StaticResource BoolToFontStyle}}"
                     TextAlignment="{Binding TextAlignment}"
                     VerticalContentAlignment="Center"
                     BorderThickness="0" Background="Transparent"
                     ToolTip="{Binding TooltipText}"
                     KeyDown="EditBox_KeyDown" LostFocus="EditBox_LostFocus"
                     GotFocus="EditBox_GotFocus" TextChanged="EditBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInput}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>
    </Border>
        <!-- B3.4: Dashed/Dotted/Double 边框覆盖 -->
        <Rectangle Stroke="{Binding BorderColor, Converter={StaticResource StringToBrushConverter}}"
                   StrokeThickness="{Binding BorderWidthDouble}"
                   StrokeDashArray="{Binding BorderDashArrayCollection}"
                   IsHitTestVisible="False"
                   Visibility="{Binding IsBorderDashStyle, Converter={StaticResource BoolToVis}}"/>
        <Rectangle Stroke="{Binding BorderColor, Converter={StaticResource StringToBrushConverter}}"
                   StrokeThickness="{Binding BorderWidthDouble}"
                   Margin="3"
                   IsHitTestVisible="False"
                   Visibility="{Binding IsBorderDouble, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>
