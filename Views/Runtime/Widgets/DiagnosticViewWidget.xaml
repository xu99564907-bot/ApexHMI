<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.DiagnosticViewWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{Binding Background}" BorderBrush="#94A3B8" BorderThickness="1">
        <UniformGrid Rows="1" Columns="3">
            <!-- 通讯状态 -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding ShowCommSection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="OPC UA 通讯" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text="{Binding OpcStatus}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="状态" Style="{StaticResource LabelStyle}"/>
                    <Separator Margin="0,6"/>
                    <TextBlock Text="{Binding SubscribedTagCount}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="订阅 Tag 数" Style="{StaticResource LabelStyle}"/>
                </StackPanel>
            </Border>

            <!-- PLC 状态 -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding ShowPlcSection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="PLC 状态" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text="{Binding PlcState}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="运行状态" Style="{StaticResource LabelStyle}"/>
                    <Separator Margin="0,6"/>
                    <TextBlock Text="{Binding PlcErrorCode}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="错误码" Style="{StaticResource LabelStyle}"/>
                </StackPanel>
            </Border>

            <!-- HMI 资源 -->
            <Border Style="{StaticResource CardStyle}"
                    Visibility="{Binding ShowHmiSection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="HMI 资源" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:0.0} %}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="进程 CPU" Style="{StaticResource LabelStyle}"/>
                    <Separator Margin="0,6"/>
                    <TextBlock Text="{Binding MemoryMb, StringFormat={}{0:0} MB}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="内存占用" Style="{StaticResource LabelStyle}"/>
                    <Separator Margin="0,6"/>
                    <TextBlock Text="{Binding DiskFreeGb, StringFormat={}{0:0.0} GB}" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Text="磁盘可用" Style="{StaticResource LabelStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Border>
</UserControl>
