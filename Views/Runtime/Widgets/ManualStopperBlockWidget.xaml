<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ManualStopperBlockWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#D7DFEA" BorderThickness="1"
            Padding="10">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Bold"
                       Foreground="#0F172A" HorizontalAlignment="Center"/>
            <TextBlock FontSize="10" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,2,0,0">
                <Run Text="Tag："/><Run Text="{Binding TagName}"/>
            </TextBlock>
            <Border Background="#F1F5F9" CornerRadius="4" Padding="6,2" Margin="0,4,0,8"
                    HorizontalAlignment="Center">
                <TextBlock Text="{Binding CurrentValueText}" FontSize="14" FontWeight="Bold"
                           Foreground="#1D4ED8"/>
            </Border>
            <Button Content="切换挡停"
                    Command="{Binding ToggleCommand}"
                    CommandParameter="{Binding TagName}"
                    Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                    Padding="14,6" FontWeight="SemiBold"/>
        </StackPanel>
    </Border>
</UserControl>
