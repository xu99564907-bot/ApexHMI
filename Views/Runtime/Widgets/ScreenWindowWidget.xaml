<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ScreenWindowWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Border BorderBrush="#94A3B8" BorderThickness="1" CornerRadius="2" Background="#F8FAFC">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#E2E8F0" Padding="6,2"
                    Visibility="{Binding TitleBarVisibility}">
                <TextBlock Text="{Binding DisplayTitle}" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>
            </Border>

            <!-- 嵌入式：递归渲染子 widgets -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding EmbeddedWidgets}"
                          Visibility="{Binding EmbeddedVisibility}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style>
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentPresenter Content="{Binding View}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 模态 / 占位 -->
            <Border Grid.Row="1" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1"
                    Visibility="{Binding PlaceholderVisibility}">
                <TextBlock Text="{Binding PlaceholderText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#92400E" FontWeight="SemiBold"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
