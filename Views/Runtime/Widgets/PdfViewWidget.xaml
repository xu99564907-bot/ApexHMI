<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.PdfViewWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Border BorderBrush="#94A3B8" BorderThickness="1"
            Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}">
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding DesignPlaceholderVisibility}">
                <TextBlock Text="[PDF 视图]" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding FilePath}" Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
            <wv2:WebView2 x:Name="Web" Visibility="{Binding RuntimeViewVisibility}"/>
        </Grid>
    </Border>
</UserControl>
