<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.IoGraphicWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             IsEnabled="{Binding IsEnabledByOperator}">
    <UserControl.Resources>
        <conv:BorderStyleVisibilityConverter x:Key="BorderStyleBrush"/>
    </UserControl.Resources>
    <Border BorderThickness="{Binding BorderWidthValue}"
            Padding="{Binding PaddingThickness}">
        <Border.BorderBrush>
            <MultiBinding Converter="{StaticResource BorderStyleBrush}">
                <Binding Path="BorderColor"/>
                <Binding Path="BorderStyleName"/>
            </MultiBinding>
        </Border.BorderBrush>
        <Image Source="{Binding CurrentImage}"
               Stretch="{Binding Stretch}"/>
    </Border>
</UserControl>
