<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ManualAxisBlockWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Grid>
        <!-- 占位（未绑定轴） -->
        <Border BorderBrush="#FBBF24" BorderThickness="1" Background="#FEF3C7" CornerRadius="6"
                Padding="12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBlock}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="⚠ 轴块" FontSize="13" FontWeight="Bold" Foreground="#92400E"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding PlaceholderText}" FontSize="11" Foreground="#92400E"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="请在右栏属性面板设置 deviceName" FontSize="10"
                           Foreground="#A16207" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 完整卡片 -->
        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#D7DFEA" BorderThickness="1"
                Padding="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasBlock}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid DataContext="{Binding Block}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                        <TextBlock Text="{Binding StateCodeText}" Foreground="#2563EB"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="#FEE2E2" Padding="6,2" CornerRadius="4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AlarmActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="报警" Foreground="#B91C1C" FontWeight="Bold" FontSize="11"/>
                    </Border>
                </DockPanel>

                <!-- 实时数据 -->
                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,6">
                    <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1"
                            CornerRadius="6" Padding="6" Margin="0,0,5,0">
                        <StackPanel>
                            <TextBlock Text="实际位置" Foreground="#64748B" FontSize="10"/>
                            <TextBlock Text="{Binding ActualPositionDisplay}" Foreground="#0F172A"
                                       FontWeight="Bold" FontSize="13" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F8FAFC" BorderBrush="#D7DFEA" BorderThickness="1"
                            CornerRadius="6" Padding="6" Margin="5,0,0,0">
                        <StackPanel>
                            <TextBlock Text="实际速度" Foreground="#64748B" FontSize="10"/>
                            <TextBlock Text="{Binding ActualVelocityDisplay}" Foreground="#0F172A"
                                       FontWeight="Bold" FontSize="13" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- 主要操作按钮：使能 / 停止 / 回原点 -->
                <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,4">
                    <Button Content="使能"
                            Command="{Binding DataContext.ToggleEnableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Background="#2563EB" Foreground="White" BorderBrush="#2563EB"
                            FontSize="11" Padding="6,4" Margin="0,0,3,0"/>
                    <Button Content="停止"
                            Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Background="#B91C1C" Foreground="White" BorderBrush="#B91C1C"
                            FontSize="11" Padding="6,4" Margin="3,0,3,0"/>
                    <Button Content="回原点"
                            Command="{Binding DataContext.MoveToHomeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Background="#0F766E" Foreground="White" BorderBrush="#0F766E"
                            FontSize="11" Padding="6,4" Margin="3,0,0,0"/>
                </UniformGrid>

                <!-- Jog 按钮 -->
                <UniformGrid Grid.Row="3" Columns="2" Margin="0,0,0,4">
                    <Button Content="◄ Jog-"
                            Command="{Binding DataContext.JogBackwardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Background="#64748B" Foreground="White" BorderBrush="#64748B"
                            FontSize="11" Padding="6,4" Margin="0,0,3,0"/>
                    <Button Content="Jog+ ►"
                            Command="{Binding DataContext.JogForwardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Background="#374151" Foreground="White" BorderBrush="#374151"
                            FontSize="11" Padding="6,4" Margin="3,0,0,0"/>
                </UniformGrid>

                <!-- 状态提示 -->
                <Border Grid.Row="4" Background="#EFF6FF" BorderBrush="#BFDBFE"
                        BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,2,0,0">
                    <TextBlock Text="{Binding CurrentStateText}" Foreground="#1D4ED8"
                               FontSize="10" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
