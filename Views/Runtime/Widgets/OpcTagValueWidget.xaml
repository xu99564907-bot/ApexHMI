<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.OpcTagValueWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Border Background="#FFFFFF" CornerRadius="6" BorderBrush="#D7DFEA" BorderThickness="1"
            Padding="10">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding Label}" Foreground="#64748B" FontSize="11"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding DisplayValue}" Foreground="#0F172A"
                           FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="{Binding Unit}" Foreground="#64748B"
                           FontSize="13" VerticalAlignment="Bottom" Margin="6,0,0,3"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
