<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.TextWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             IsEnabled="{Binding IsEnabledByOperator}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <conv:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>
        <conv:BoolToFontStyleConverter x:Key="BoolToFontStyle"/>
        <conv:BoolToTextDecorationsConverter x:Key="BoolToTextDecorations"/>
        <conv:BorderStyleVisibilityConverter x:Key="BorderStyleBrush"/>
    </UserControl.Resources>
    <Border Background="{Binding Background, Converter={StaticResource StringToBrushConverter}}"
            BorderThickness="{Binding BorderWidthValue}"
            CornerRadius="4"
            Padding="{Binding PaddingThickness}">
        <Border.BorderBrush>
            <MultiBinding Converter="{StaticResource BorderStyleBrush}">
                <Binding Path="BorderColor"/>
                <Binding Path="BorderStyleName"/>
            </MultiBinding>
        </Border.BorderBrush>
        <TextBlock Text="{Binding Text}"
                   FontSize="{Binding FontSize}"
                   FontWeight="{Binding FontWeight}"
                   FontFamily="{Binding FontFamilyName}"
                   FontStyle="{Binding FontItalic, Converter={StaticResource BoolToFontStyle}}"
                   TextDecorations="{Binding FontUnderline, Converter={StaticResource BoolToTextDecorations}}"
                   Foreground="{Binding Foreground, Converter={StaticResource StringToBrushConverter}}"
                   TextAlignment="{Binding TextAlignment}"
                   VerticalAlignment="{Binding VerticalAlignment}"
                   TextWrapping="Wrap"/>
    </Border>
</UserControl>
