<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.GraphicViewWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:ApexHMI.ViewModels.Runtime"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}"
             Opacity="{Binding Opacity}">
    <Grid>
        <!-- P3 原 Image 路径渲染（仅当未设置 IconKind 时） -->
        <Image Source="{Binding Source}"
               Stretch="{Binding Stretch}"
               Visibility="{Binding ShowImage, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <!-- P6D: 工业符号渲染（IconKind 非空时显示，覆盖 Image） -->
        <materialDesign:PackIcon Kind="{Binding IconKind, TargetNullValue=Cog, FallbackValue=Cog}"
                                 Width="{Binding Model.Width}" Height="{Binding Model.Height}"
                                 Foreground="{Binding IconColor}"
                                 Visibility="{Binding ShowIcon, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>
