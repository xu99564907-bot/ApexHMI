<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.ManualRobotBlockWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ApexHMI.Views.Controls"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <Grid>
        <!-- 占位 -->
        <Border BorderBrush="#FBBF24" BorderThickness="1" Background="#FEF3C7" CornerRadius="6"
                Padding="12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasRobot}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="⚠ 机械手块" FontSize="13" FontWeight="Bold" Foreground="#92400E"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="未连接到机械手控制器" FontSize="11" Foreground="#92400E"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- 机械手控件 -->
        <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#D7DFEA" BorderThickness="1"
                Padding="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasRobot}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <controls:RobotControl DataContext="{Binding RobotVm}"/>
        </Border>
    </Grid>
</UserControl>
