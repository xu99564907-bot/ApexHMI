<UserControl x:Class="ApexHMI.Views.Runtime.Widgets.GaugeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ApexHMI.Converters"
             Width="{Binding Model.Width}" Height="{Binding Model.Height}">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
    </UserControl.Resources>
    <Grid>
        <!-- 背景圆弧 + 进度圆弧由 code-behind 在 SizeChanged / Value 变化时重绘 -->
        <Canvas x:Name="ArcCanvas"/>
        <TextBlock Text="{Binding DisplayText}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{Binding CurrentColor, Converter={StaticResource StringToBrushConverter}}"
                   FontWeight="Bold" FontSize="14"/>
    </Grid>
</UserControl>
