<UserControl x:Class="ApexHMI.Views.Runtime.DynamicPageHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ApexHMI.ViewModels.Runtime"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280">
    <DockPanel>
        <!-- 多页导航条：>=2 个页面时显示 -->
        <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="#D7DFEA" BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="{Binding ShowPageTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding AvailablePages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Title}"
                                Command="{Binding DataContext.NavigateTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Padding="12,4" Margin="0,0,4,0"
                                Background="#F1F5F9" Foreground="#0F172A" BorderBrush="#D7DFEA"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Border Width="{Binding CurrentPage.CanvasWidth, FallbackValue=1280}"
                Height="{Binding CurrentPage.CanvasHeight, FallbackValue=720}"
                Background="#E2E8F0"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="8">
            <Canvas ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding WidgetElements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PositionedWidget}">
                            <ContentPresenter Content="{Binding View}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Border>
    </ScrollViewer>
    </DockPanel>
</UserControl>
