<Window x:Class="ApexHMI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ApexHMI.ViewModels"
        xmlns:model="clr-namespace:ApexHMI.Models"
        xmlns:conv="clr-namespace:ApexHMI.Converters"
        xmlns:controls="clr-namespace:ApexHMI.Views.Controls"
        xmlns:pages="clr-namespace:ApexHMI.Views.Pages"
        xmlns:runtime="clr-namespace:ApexHMI.Views.Runtime"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:l="clr-namespace:ApexHMI.Converters"
        mc:Ignorable="d"
        Title="PLC OPC UA HMI Designer" Height="1080" Width="1880" WindowStartupLocation="CenterScreen" Background="#F3F6FB" WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        PreviewMouseWheel="MainWindow_PreviewMouseWheel">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.InputBindings>
        <!-- G1 全局快捷键：Ctrl+1~8 顶部导航；F5 刷新 -->
        <KeyBinding Modifiers="Ctrl" Key="D1" Command="{Binding NavigateCommand}" CommandParameter="主界面"/>
        <KeyBinding Modifiers="Ctrl" Key="D2" Command="{Binding NavigateCommand}" CommandParameter="监控"/>
        <KeyBinding Modifiers="Ctrl" Key="D3" Command="{Binding NavigateCommand}" CommandParameter="手动操作"/>
        <KeyBinding Modifiers="Ctrl" Key="D4" Command="{Binding NavigateCommand}" CommandParameter="参数设定"/>
        <KeyBinding Modifiers="Ctrl" Key="D5" Command="{Binding NavigateCommand}" CommandParameter="配方管理"/>
        <KeyBinding Modifiers="Ctrl" Key="D6" Command="{Binding NavigateCommand}" CommandParameter="报警画面"/>
        <KeyBinding Modifiers="Ctrl" Key="D7" Command="{Binding NavigateCommand}" CommandParameter="登录"/>
        <KeyBinding Modifiers="Ctrl" Key="D8" Command="{Binding NavigateCommand}" CommandParameter="设计器"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad1" Command="{Binding NavigateCommand}" CommandParameter="主界面"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad2" Command="{Binding NavigateCommand}" CommandParameter="监控"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad3" Command="{Binding NavigateCommand}" CommandParameter="手动操作"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad4" Command="{Binding NavigateCommand}" CommandParameter="参数设定"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad5" Command="{Binding NavigateCommand}" CommandParameter="配方管理"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad6" Command="{Binding NavigateCommand}" CommandParameter="报警画面"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad7" Command="{Binding NavigateCommand}" CommandParameter="登录"/>
        <KeyBinding Modifiers="Ctrl" Key="NumPad8" Command="{Binding NavigateCommand}" CommandParameter="设计器"/>
        <KeyBinding Key="F5" Command="{Binding RefreshTagsCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <conv:ViewportToCylinderItemWidthConverter x:Key="ViewportToCylinderItemWidthConverter"/>
        <conv:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <conv:ElementTypeToVisibilityConverter x:Key="ElementTypeToVisibilityConverter"/>
        <conv:NavigationIconConverter x:Key="NavigationIconConverter"/>
        <conv:NavigationSelectionBrushConverter x:Key="NavigationSelectionBrushConverter"/>
        <conv:NavigationGroupVisibilityConverter x:Key="NavigationGroupVisibilityConverter"/>
        <conv:CurrentSectionToNavigationWidthConverter x:Key="CurrentSectionToNavigationWidthConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:DurationToWidthConverter x:Key="DurationToWidthConverter"/>
        <Style x:Key="SparklinePathStyle" TargetType="Path">
            <Setter Property="StrokeThickness" Value="2.5"/>
            <Setter Property="Stretch" Value="Fill"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="ModeToggleButtonStyle">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="BorderBrush" Value="#60A5FA"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="EmergencyStopButtonStyle">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="DataGridRow" x:Key="ParameterRowStyle">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#64748B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReadOnly}" Value="False">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow" x:Key="HighlightRowStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EFF3F8"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="TextBlock.Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DataGridEditTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#60A5FA"/>
            <Setter Property="CaretBrush" Value="#0F172A"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style x:Key="TopNavigationIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="tt" Y="0"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="bd" Property="Background" Value="#EEF4FF"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CylinderActionButtonBaseStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="VsMenuBarBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="VsMenuTextBrush" Color="#334155"/>
        <SolidColorBrush x:Key="VsMenuHoverBrush" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="VsMenuPopupBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="VsMenuBorderBrush" Color="#D7DFEA"/>
        <SolidColorBrush x:Key="VsMenuSeparatorBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="VsMenuGestureBrush" Color="#64748B"/>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource VsMenuBarBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource VsMenuTextBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Margin="8,6" Background="{StaticResource VsMenuSeparatorBrush}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource VsMenuTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="TopLevelBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="{TemplateBinding Margin}">
                                <DockPanel>
                                    <TextBlock Text="{TemplateBinding Header}" VerticalAlignment="Center"/>
                                    <Path x:Name="TopLevelArrow"
                                          DockPanel.Dock="Right"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          Fill="{StaticResource VsMenuTextBrush}"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Visibility="Collapsed"/>
                                </DockPanel>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="SubmenuBorder"
                                        Background="{StaticResource VsMenuPopupBrush}"
                                        BorderBrush="{StaticResource VsMenuBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="Popup" Property="Placement" Value="Bottom"/>
                                <Setter TargetName="TopLevelArrow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="TopLevelBorder" Property="CornerRadius" Value="0"/>
                                <Setter TargetName="TopLevelBorder" Property="Margin" Value="0"/>
                                <Setter TargetName="TopLevelBorder" Property="Padding" Value="8,4"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="Popup" Property="Placement" Value="Bottom"/>
                                <Setter TargetName="TopLevelBorder" Property="CornerRadius" Value="0"/>
                                <Setter TargetName="TopLevelBorder" Property="Margin" Value="0"/>
                                <Setter TargetName="TopLevelBorder" Property="Padding" Value="8,4"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Popup" Property="Placement" Value="Right"/>
                                <Setter TargetName="TopLevelBorder" Property="CornerRadius" Value="6"/>
                                <Setter TargetName="TopLevelArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="TopLevelArrow" Property="Data" Value="M 0 0 L 0 8 L 4 4 Z"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="Popup" Property="Placement" Value="Right"/>
                                <Setter TargetName="TopLevelBorder" Property="CornerRadius" Value="6"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="{StaticResource VsMenuHoverBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="{StaticResource VsMenuHoverBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F6F6F"/>
                                <Setter TargetName="TopLevelArrow" Property="Fill" Value="#6F6F6F"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Role" Value="TopLevelHeader"/>
                                    <Condition Property="IsHighlighted" Value="False"/>
                                    <Condition Property="IsSubmenuOpen" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="Transparent"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Role" Value="TopLevelItem"/>
                                    <Condition Property="IsHighlighted" Value="False"/>
                                    <Condition Property="IsSubmenuOpen" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TopLevelBorder" Property="Background" Value="Transparent"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1"
            Background="#F3F6FB"
            BorderBrush="#E7ECF3"
            BorderThickness="0.5"
            CornerRadius="4"
            SnapsToDevicePixels="True">
        <Grid Background="#F3F6FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding CurrentSection, Converter={StaticResource CurrentSectionToNavigationWidthConverter}}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="0,0,0,1">
                <Grid Height="40" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,14,0">
                        <Border Width="18" Height="18" CornerRadius="4" Background="#007ACC" Margin="0,0,8,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid>
                                <Rectangle Width="9" Height="9" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="PLC OPC UA HMI Designer" Foreground="#334155" VerticalAlignment="Center" FontSize="13" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                    <Menu Grid.Column="1" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <MenuItem Header="{l:Loc Menu_File}">
                            <MenuItem Header="{l:Loc Menu_ImportXmlTag}" Command="{Binding ImportXmlTagsCommand}"/>
                            <MenuItem Header="{l:Loc Menu_ImportCsvTag}" Command="{Binding ImportTagsCommand}"/>
                            <MenuItem Header="{l:Loc Menu_ImportIoTable}" Command="{Binding ImportIoTableCommand}"/>
                        <MenuItem Header="{l:Loc Menu_GenerateManualProgram}" Command="{Binding GenerateIoProgramsCommand}"/>
                            <MenuItem Header="{l:Loc Menu_ImportFlowCsv}" Command="{Binding ImportFlowCsvCommand}"/>
                            <Separator/>
                            <MenuItem Header="{l:Loc Menu_OpenIoGenDir}" Command="{Binding OpenGeneratedIoFolderCommand}"/>
                            <Separator/>
                            <MenuItem Header="{l:Loc Menu_Exit}" Click="ExitMenuItem_Click"/>
                        </MenuItem>
                        <MenuItem Header="{l:Loc Menu_Edit}">
                            <MenuItem Header="{l:Loc Menu_ExportReport}" Command="{Binding ExportProductionReportCommand}"/>
                            <Separator/>
                            <MenuItem Header="语言 / Language">
                                <MenuItem Header="中文 (zh-CN)" Command="{Binding SwitchLanguageCommand}" CommandParameter="zh-CN"/>
                                <MenuItem Header="English (en-US)" Command="{Binding SwitchLanguageCommand}" CommandParameter="en-US"/>
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Header="{l:Loc Menu_Window}">
                            <MenuItem Header="{l:Loc Menu_ToggleRuntime}" Command="{Binding ToggleRuntimeModeCommand}"/>
                            <Separator/>
                            <MenuItem Header="{l:Loc Menu_Maximize}" Click="MaximizeWindowMenuItem_Click"/>
                            <MenuItem Header="{l:Loc Menu_Restore}" Click="RestoreWindowMenuItem_Click"/>
                            <MenuItem Header="{l:Loc Menu_Topmost}" IsCheckable="True" Click="ToggleTopmostMenuItem_Click"/>
                        </MenuItem>
                        <MenuItem Header="{l:Loc Menu_Help}">
                            <MenuItem Header="{l:Loc Menu_UsageHelp}" Click="ShowUsageHelpMenuItem_Click"/>
                            <MenuItem Header="{l:Loc Menu_OpenReadme}" Click="OpenReadmeMenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="{l:Loc Menu_About}" Click="ShowAboutMenuItem_Click"/>
                        </MenuItem>
                    </Menu>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowControlButtonStyle}" Click="MinimizeWindowButton_Click">
                            <Grid Width="12" Height="12">
                                <Rectangle Height="1" Width="10" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Grid>
                        </Button>
                        <Button x:Name="MaxRestoreButton" Style="{StaticResource WindowControlButtonStyle}" Click="MaxRestoreWindowButton_Click">
                            <Grid Width="12" Height="12">
                                <Rectangle x:Name="MaximizeIcon" Width="9" Height="9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Grid x:Name="RestoreIcon" Visibility="Collapsed">
                                    <Rectangle Width="7" Height="7" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                                    <Rectangle Width="7" Height="7" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                </Grid>
                            </Grid>
                        </Button>
                        <Button Click="CloseWindowButton_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource WindowControlButtonStyle}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C42B1C"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Grid Width="12" Height="12">
                                <Path Data="M 1,1 L 11,11 M 11,1 L 1,11"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.2"
                                      StrokeStartLineCap="Square"
                                      StrokeEndLineCap="Square"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
                </Border>
                <Grid Margin="20,6,20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="2" Background="Transparent"/>
                    </Grid>
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="主界面" ToolTip="主界面">
                            <Button.Background>
                                <MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}">
                                    <Binding Path="CurrentSection"/>
                                    <Binding Source="主界面"/>
                                </MultiBinding>
                            </Button.Background>
                            <materialDesign:PackIcon Kind="HomeOutline" Width="70" Height="70">
                                <materialDesign:PackIcon.Foreground>
                                    <MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground">
                                        <Binding Path="CurrentSection"/>
                                        <Binding Source="主界面"/>
                                    </MultiBinding>
                                </materialDesign:PackIcon.Foreground>
                            </materialDesign:PackIcon>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="监控" ToolTip="监控">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="监控"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="FileTableBoxOutline" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="监控"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="手动操作" ToolTip="手动操作">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="手动操作"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="WrenchOutline" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="手动操作"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="参数设定" ToolTip="参数设定">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="参数设定"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="Cog" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="参数设定"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                        <Border Grid.Column="4" Margin="12,8" CornerRadius="14" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{l:Loc Nav_CurrentSection}" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentSection}" Foreground="{DynamicResource Brush.Text}" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button Grid.Column="5" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="配方管理" ToolTip="配方管理">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="配方管理"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="CrosshairsGps" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="配方管理"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                        <Button Grid.Column="6" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="报警画面" ToolTip="报警画面">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="报警画面"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="ChartBellCurveCumulative" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="报警画面"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                        <Button Grid.Column="7" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="登录" ToolTip="登录">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="登录"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="AccountMultipleOutline" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="登录"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                        <!-- 用户挂载到主导航的页面（ShowInTopNav=True 的设计页） -->
                        <ItemsControl Grid.Column="8" ItemsSource="{Binding TopNavUserPages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource TopNavigationIconButtonStyle}"
                                            Command="{Binding DataContext.NavigateToUserPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding RouteKey}"
                                            ToolTip="{Binding Title}">
                                        <StackPanel Orientation="Vertical">
                                            <materialDesign:PackIcon Kind="{Binding NavIcon, FallbackValue=ViewDashboard, TargetNullValue=ViewDashboard}"
                                                                     Width="48" Height="48"
                                                                     Foreground="#334155"
                                                                     HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}" FontSize="11"
                                                       Foreground="#334155" HorizontalAlignment="Center"
                                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="80"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Grid.Column="9" Style="{StaticResource TopNavigationIconButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="设计器" ToolTip="设计器" Visibility="{Binding IsDesignMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button.Background><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}"><Binding Path="CurrentSection"/><Binding Source="设计器"/></MultiBinding></Button.Background>
                            <materialDesign:PackIcon Kind="PencilRuler" Width="70" Height="70"><materialDesign:PackIcon.Foreground><MultiBinding Converter="{StaticResource NavigationSelectionBrushConverter}" ConverterParameter="Foreground"><Binding Path="CurrentSection"/><Binding Source="设计器"/></MultiBinding></materialDesign:PackIcon.Foreground></materialDesign:PackIcon>
                        </Button>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="12" Padding="12">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentSection}" Value="主界面">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsRuntimeFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{l:Loc Nav_SubNav}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}" Margin="4,0,0,12"/>
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="Visible">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource NavigationGroupVisibilityConverter}">
                                                            <Binding Path="DataContext.CurrentNavigationGroup" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            <Binding Path="Title"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Brush.TextMuted}" FontWeight="SemiBold" Margin="4,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Children}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Title}" Command="{Binding DataContext.NavigateNavItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Padding="8" Margin="20,0,0,4" Background="#F8FAFC" Foreground="#334155" BorderBrush="{DynamicResource Brush.Border}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Margin="0,12,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TabControl Grid.Row="0" Background="#FFFFFF" BorderThickness="0" Foreground="{DynamicResource Brush.Text}" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
                <TabControl.Template>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </TabControl.Template>
                <TabItem Header="{l:Loc Tab_Home}">
                    <pages:HomeView DataContext="{Binding Home}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Monitor}">
                    <pages:MonitorView DataContext="{Binding Monitor}"/>
                </TabItem>
                <TabItem Header="{l:Loc Tab_Recipe}">
                    <pages:RecipeView DataContext="{Binding Recipe}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Manual}">
                    <pages:ManualView DataContext="{Binding Manual}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Parameter}">
                    <pages:ParameterView DataContext="{Binding ParametersModule}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Alarm}">
                    <pages:AlarmView DataContext="{Binding Alarm}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Login}">
                    <pages:LoginView DataContext="{Binding Login}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Audit}">
                    <pages:AuditView DataContext="{Binding Audit}"/>
                </TabItem>

                <TabItem Header="程序生成">
                    <pages:DesignerView DataContext="{Binding Designer}"/>
                </TabItem>

                <TabItem Header="画布设计">
                    <pages:DesignerEditorView DataContext="{Binding DesignerEditor}"/>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Runtime}">
                    <runtime:DynamicPageHost DataContext="{Binding RuntimePage}"/>
                </TabItem>

                <TabItem Header="生产计数">
                    <pages:CountView DataContext="{Binding Count}"/>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,1,0,0" Padding="12,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRuntimeFullScreen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <WrapPanel>
                    <Border Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                            <TextBlock Text="{Binding DesignerModeText}" Foreground="#4338CA" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                            <TextBlock Text="{Binding CurrentRoleText}" Foreground="#047857" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Border Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{l:Loc StatusBar_PlcPrefix}" Foreground="#1D4ED8" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CommunicationStatus}" Foreground="#1D4ED8" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F3E8FF" BorderBrush="#DDD6FE" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,10,0"
                            ToolTip="当前自动流程主步号；点击跳到 主界面">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="流程：" Foreground="#7C3AED" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentFlowStepText}" Foreground="#7C3AED" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,10,0"
                            ToolTip="实时节拍 / 每小时产量">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="节拍 " Foreground="#047857" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CycleTimeSeconds, StringFormat={}{0:F1}s}" Foreground="#047857" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " Foreground="#047857" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding HourlyThroughput, StringFormat={}{0} UPH}" Foreground="#047857" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding SystemMessage}" Foreground="{DynamicResource Brush.Text}" VerticalAlignment="Center"/>
                </WrapPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{l:Loc StatusBar_AppTagline}" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        </Grid>
    </Border>
</Window>





