<UserControl x:Class="ApexHMI.Views.Controls.KpiCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Self">
    <Border Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Card}"
            Padding="14,12"
            MinWidth="160">
        <StackPanel>
            <DockPanel LastChildFill="False">
                <Border DockPanel.Dock="Left"
                        Background="{Binding ElementName=Self, Path=AccentBrush}"
                        CornerRadius="3" Padding="6,2" Margin="0,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ElementName=Self, Path=Tag}"
                               Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                </Border>
            </DockPanel>
            <TextBlock Text="{Binding ElementName=Self, Path=Label}"
                       Foreground="{StaticResource Brush.TextMuted}"
                       FontSize="12" Margin="0,8,0,2"/>
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding ElementName=Self, Path=Value}"
                           Foreground="{StaticResource Brush.Text}"
                           FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="{Binding ElementName=Self, Path=Unit}"
                           Foreground="{StaticResource Brush.TextMuted}"
                           FontSize="11" VerticalAlignment="Bottom" Margin="6,0,0,4"/>
            </DockPanel>
            <TextBlock Text="{Binding ElementName=Self, Path=Hint}"
                       Foreground="{StaticResource Brush.TextPlaceholder}"
                       FontSize="11" Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
