<ResourceDictionary
    x:Class="ApexHMI.Views.Controls.PropertyEditors.PropertyEditorTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="clr-namespace:ApexHMI.Behaviors"
    xmlns:vm="clr-namespace:ApexHMI.ViewModels.Modules"
    xmlns:converters="clr-namespace:ApexHMI.Converters">

    <!-- 本字典内部使用的 converter（App.xaml 父级也有同名，但 MergedDictionary 子作用域看不到，
         故本地再声明一份）-->
    <converters:StringToBrushConverter x:Key="StringToBrushConverter"/>

    <!-- P7.5: 9 类属性编辑器 DataTemplate 集合。
         约定：DataContext = PropertyEditorVM，外层 ItemsControl 已渲染 DisplayName 列；
         模板只负责右侧编辑控件本身。 -->

    <!-- ===== String ===== -->
    <DataTemplate x:Key="PropEditor.String">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 ToolTip="{Binding Description}"/>
    </DataTemplate>

    <!-- ===== MultilineString ===== -->
    <DataTemplate x:Key="PropEditor.MultilineString">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="60" MaxHeight="120"
                 VerticalScrollBarVisibility="Auto"
                 ToolTip="{Binding Description}"/>
    </DataTemplate>

    <!-- ===== Number ===== -->
    <DataTemplate x:Key="PropEditor.Number">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 ToolTip="{Binding Description}"/>
    </DataTemplate>

    <!-- ===== Integer ===== -->
    <DataTemplate x:Key="PropEditor.Integer">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 ToolTip="{Binding Description}"/>
    </DataTemplate>

    <!-- ===== Boolean ===== -->
    <DataTemplate x:Key="PropEditor.Boolean">
        <CheckBox IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}"
                  VerticalAlignment="Center"
                  ToolTip="{Binding Description}"/>
    </DataTemplate>

    <!-- ===== TagAddress ===== -->
    <DataTemplate x:Key="PropEditor.TagAddress">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 b:TagAutoComplete.IsEnabled="True"
                 VerticalAlignment="Center"
                 ToolTip="OPC UA Tag 地址（输入时下方列出候选；Tab/Enter 补全）"/>
    </DataTemplate>

    <!-- ===== Enum ===== -->
    <DataTemplate x:Key="PropEditor.Enum">
        <ComboBox ItemsSource="{Binding EnumOptionItems}"
                  SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"
                  VerticalAlignment="Center"
                  ToolTip="{Binding Description}"/>
    </DataTemplate>

    <!-- ===== Color ===== -->
    <DataTemplate x:Key="PropEditor.Color">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- 色块预览 -->
            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="3"
                    BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,4,0"
                    Background="{Binding Value, Converter={StaticResource StringToBrushConverter}}"/>
            <!-- hex / 引用串输入 -->
            <TextBox Grid.Column="1"
                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas" FontSize="11"
                     VerticalAlignment="Center"
                     ToolTip="支持 #RRGGBB / 命名色 / {style:colors/primary} 引用"/>
            <!-- Popup 取色器 -->
            <ToggleButton Grid.Column="2" x:Name="PickerToggle"
                          Content="▾" Padding="6,0" Margin="4,0,0,0"
                          MinWidth="22" Height="22"
                          ToolTip="打开取色面板"/>
            <Popup IsOpen="{Binding IsChecked, ElementName=PickerToggle}"
                   StaysOpen="False" Placement="Bottom" AllowsTransparency="True">
                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                        CornerRadius="4" Padding="8" SnapsToDevicePixels="True">
                    <StackPanel MinWidth="220">
                        <TextBlock Text="常用工业色" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                        <WrapPanel>
                            <Border Tag="#EF4444" Width="22" Height="22" Margin="2" Background="#EF4444"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="红 #EF4444"/>
                            <Border Tag="#10B981" Width="22" Height="22" Margin="2" Background="#10B981"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="绿 #10B981"/>
                            <Border Tag="#F59E0B" Width="22" Height="22" Margin="2" Background="#F59E0B"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="黄 #F59E0B"/>
                            <Border Tag="#3B82F6" Width="22" Height="22" Margin="2" Background="#3B82F6"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="蓝 #3B82F6"/>
                            <Border Tag="#F97316" Width="22" Height="22" Margin="2" Background="#F97316"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="橙 #F97316"/>
                            <Border Tag="#64748B" Width="22" Height="22" Margin="2" Background="#64748B"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="灰 #64748B"/>
                            <Border Tag="#0F172A" Width="22" Height="22" Margin="2" Background="#0F172A"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="黑 #0F172A"/>
                            <Border Tag="#FFFFFF" Width="22" Height="22" Margin="2" Background="#FFFFFF"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ColorSwatch_Click" ToolTip="白 #FFFFFF"/>
                        </WrapPanel>
                        <TextBlock Text="样式引用" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                        <WrapPanel>
                            <Button Content="{}{style:colors/primary}" Tag="{}{style:colors/primary}"
                                    Click="ColorStyleRef_Click" Margin="2" Padding="6,2" FontSize="11"/>
                            <Button Content="{}{style:colors/accent}" Tag="{}{style:colors/accent}"
                                    Click="ColorStyleRef_Click" Margin="2" Padding="6,2" FontSize="11"/>
                            <Button Content="{}{style:colors/warn}" Tag="{}{style:colors/warn}"
                                    Click="ColorStyleRef_Click" Margin="2" Padding="6,2" FontSize="11"/>
                            <Button Content="{}{style:colors/error}" Tag="{}{style:colors/error}"
                                    Click="ColorStyleRef_Click" Margin="2" Padding="6,2" FontSize="11"/>
                            <Button Content="{}{style:colors/text}" Tag="{}{style:colors/text}"
                                    Click="ColorStyleRef_Click" Margin="2" Padding="6,2" FontSize="11"/>
                            <Button Content="{}{style:colors/border}" Tag="{}{style:colors/border}"
                                    Click="ColorStyleRef_Click" Margin="2" Padding="6,2" FontSize="11"/>
                        </WrapPanel>
                        <TextBlock Text="自定义 (#RRGGBB)" FontSize="11" Foreground="#64748B" Margin="0,8,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="应用" Padding="8,2" Margin="4,0,0,0"
                                    Click="ColorCustomApply_Click"/>
                            <TextBox x:Name="CustomColorBox" Text="{Binding Value, Mode=OneWay}"
                                     FontFamily="Consolas" FontSize="11"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </DataTemplate>

    <!-- ===== PageRoute ===== -->
    <DataTemplate x:Key="PropEditor.PageRoute">
        <ComboBox ItemsSource="{Binding DataContext.NavigateTargets, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedValuePath="RouteKey"
                  SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                  VerticalAlignment="Center"
                  ToolTip="选择跳转目标 RouteKey">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Group, StringFormat=[{0}]}"
                                   Foreground="#2563EB" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayName}"/>
                        <TextBlock Text="{Binding RouteKey, StringFormat=  ({0})}"
                                   Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
    </DataTemplate>

    <!-- ===== Json ===== -->
    <DataTemplate x:Key="PropEditor.Json">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="NoWrap"
                 MinHeight="80" MaxHeight="200"
                 FontFamily="Consolas" FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 ToolTip="JSON 文本（v2.0 升级语法高亮）"/>
    </DataTemplate>

    <!-- ===== TextListRef / GraphicListRef / Font：先回退到普通 String ===== -->
    <DataTemplate x:Key="PropEditor.TextListRef">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 ToolTip="文本列表引用 ID（v2.0 下拉选择器）"/>
    </DataTemplate>
    <DataTemplate x:Key="PropEditor.GraphicListRef">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 ToolTip="图形列表引用 ID（v2.0 下拉选择器）"/>
    </DataTemplate>
    <DataTemplate x:Key="PropEditor.Font">
        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Center"
                 ToolTip="字体描述（v2.0 字体选择器）"/>
    </DataTemplate>
</ResourceDictionary>
