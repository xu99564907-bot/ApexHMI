<UserControl x:Class="ApexHMI.Views.Controls.RobotControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ApexHMI.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="580" d:DesignWidth="720">

    <UserControl.DataContext>
        <vm:RobotControlViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="HeaderBackground" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentRed" Color="#DC2626"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#F59E0B"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F97316"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8B5CF6"/>

        <!-- 状态颜色 -->
        <SolidColorBrush x:Key="StateReady" Color="#10B981"/>
        <SolidColorBrush x:Key="StateRunning" Color="#2563EB"/>
        <SolidColorBrush x:Key="StatePaused" Color="#F59E0B"/>
        <SolidColorBrush x:Key="StateError" Color="#DC2626"/>
        <SolidColorBrush x:Key="StateOffline" Color="#6B7280"/>

        <!-- 指示灯颜色 -->
        <SolidColorBrush x:Key="IndicatorOn" Color="#10B981"/>
        <SolidColorBrush x:Key="IndicatorOff" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="IndicatorWarning" Color="#F59E0B"/>
        <SolidColorBrush x:Key="IndicatorError" Color="#DC2626"/>
        <SolidColorBrush x:Key="IndicatorBlue" Color="#3B82F6"/>

        <!-- 按钮样式 - 主要 -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E40AF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#93C5FD"/>
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮样式 - 成功 -->
        <Style x:Key="BtnSuccess" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#047857"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮样式 - 危险 -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#991B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮样式 - 警告 -->
        <Style x:Key="BtnWarning" TargetType="Button">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#F59E0B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D97706"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B45309"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 按钮样式 - 默认 -->
        <Style x:Key="BtnDefault" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 轴点动按钮 - 前进 -->
        <Style x:Key="BtnAxisForward" TargetType="Button">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="Foreground" Value="#059669"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1FAE5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A7F3D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 轴点动按钮 - 后退 -->
        <Style x:Key="BtnAxisBackward" TargetType="Button">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FECACA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 状态指示器样式 -->
        <Style x:Key="StatusIndicator" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Consolas, monospace"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 下拉框样式 -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 区域标题样式 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- 状态标签样式 -->
        <Style x:Key="StateBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}" 
            BorderBrush="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorBorderConverter}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 图标和标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="36" Height="36" 
                            Background="{Binding Robot.StateColor, Converter={StaticResource StringToBrushConverter}}"
                            CornerRadius="8" Margin="0,0,10,0">
                        <TextBlock Text="R" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding Robot.RobotName}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{Binding Robot.Status.Error, Converter={StaticResource ErrorToTextColorConverter}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 状态徽章 -->
                <Border Grid.Column="2" Style="{StaticResource StateBadge}"
                        Background="{Binding Robot.StateColor, Converter={StaticResource StringToBrushConverter}, ConverterParameter=Light}">
                    <TextBlock Text="{Binding Robot.StateText}" 
                               FontSize="12" 
                               FontWeight="Bold"
                               Foreground="{Binding Robot.StateColor, Converter={StaticResource StringToBrushConverter}}"/>
                </Border>
            </Grid>

            <!-- 分隔线 -->
            <Border Grid.Row="1" Height="1" Background="#E5E7EB" Margin="0,0,0,12"/>

            <!-- 状态指示器 -->
            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.Ready, Converter={StaticResource BoolToIndicatorBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.Ready, Converter={StaticResource BoolToIndicatorBorderConverter}}">
                    <TextBlock Text="就绪" FontSize="10" FontWeight="SemiBold" 
                               Foreground="{Binding Robot.Status.Ready, Converter={StaticResource BoolToIndicatorTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.Running, Converter={StaticResource BoolToBlueBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.Running, Converter={StaticResource BoolToBlueBorderConverter}}">
                    <TextBlock Text="运行" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.Running, Converter={StaticResource BoolToBlueTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.Paused, Converter={StaticResource BoolToYellowBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.Paused, Converter={StaticResource BoolToYellowBorderConverter}}">
                    <TextBlock Text="暂停" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.Paused, Converter={StaticResource BoolToYellowTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorBorderConverter}}">
                    <TextBlock Text="错误" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.EStopOn, Converter={StaticResource BoolToErrorBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.EStopOn, Converter={StaticResource BoolToErrorBorderConverter}}">
                    <TextBlock Text="急停" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.EStopOn, Converter={StaticResource BoolToErrorTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="5" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.MotorsOn, Converter={StaticResource BoolToIndicatorBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.MotorsOn, Converter={StaticResource BoolToIndicatorBorderConverter}}">
                    <TextBlock Text="电机ON" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.MotorsOn, Converter={StaticResource BoolToIndicatorTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Status.PowerHigh, Converter={StaticResource BoolToIndicatorBrushConverter}}"
                        BorderBrush="{Binding Robot.Status.PowerHigh, Converter={StaticResource BoolToIndicatorBorderConverter}}">
                    <TextBlock Text="高功率" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.PowerHigh, Converter={StaticResource BoolToIndicatorTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Grid.Column="7" Style="{StaticResource StatusIndicator}"
                        Background="{Binding Robot.Command.TeachMode, Converter={StaticResource BoolToBlueBrushConverter}}"
                        BorderBrush="{Binding Robot.Command.TeachMode, Converter={StaticResource BoolToBlueBorderConverter}}">
                    <TextBlock Text="示教" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Command.TeachMode, Converter={StaticResource BoolToBlueTextConverter}}"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- 主控制区 -->
            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：主要操作 -->
                <Border Grid.Column="0" Background="#F9FAFB" BorderBrush="#E5E7EB" 
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,7,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="主操作" Style="{StaticResource SectionTitle}"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="电机 ON" Style="{StaticResource BtnSuccess}" 
                                    Width="90" Height="40" Margin="0,0,8,0"
                                    Command="{Binding MotorOnCommand}"/>
                            <Button Content="电机 OFF" Style="{StaticResource BtnDefault}" 
                                    Width="90" Height="40"
                                    Command="{Binding MotorOffCommand}"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,8">
                            <Button Content="启动" Style="{StaticResource BtnPrimary}" 
                                    Margin="0,0,4,0" Height="36"
                                    Command="{Binding StartCommand}"/>
                            <Button Content="暂停" Style="{StaticResource BtnWarning}" 
                                    Margin="0,0,4,0" Height="36"
                                    Command="{Binding PauseCommand}"/>
                            <Button Content="停止" Style="{StaticResource BtnDanger}" 
                                    Height="36"
                                    Command="{Binding StopCommand}"/>
                        </UniformGrid>

                        <UniformGrid Grid.Row="3" Columns="3">
                            <Button Content="继续" Style="{StaticResource BtnDefault}" 
                                    Margin="0,0,4,0" Height="36"
                                    Command="{Binding ContinueCommand}"/>
                            <Button Content="复位" Style="{StaticResource BtnDefault}" 
                                    Margin="0,0,4,0" Height="36"
                                    Command="{Binding ResetCommand}"/>
                            <Button Content="回原点" Style="{StaticResource BtnDefault}" 
                                    Height="36"
                                    Command="{Binding GoHomeCommand}"/>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- 右侧：状态显示 -->
                <Border Grid.Column="1" Background="#F9FAFB" BorderBrush="#E5E7EB" 
                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="7,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="运行状态" Style="{StaticResource SectionTitle}"/>

                        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                            <Border Background="White" BorderBrush="#E5E7EB" 
                                    BorderThickness="1" CornerRadius="6" 
                                    Padding="10" Margin="0,0,6,6">
                                <StackPanel>
                                    <TextBlock Text="运行速度" FontSize="10" 
                                               Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="18" FontWeight="Bold" 
                                               Foreground="#111827" FontFamily="Consolas">
                                        <Run Text="{Binding Robot.Command.Speed}"/>
                                        <Run Text="%" FontSize="12" Foreground="#9CA3AF"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E5E7EB" 
                                    BorderThickness="1" CornerRadius="6" 
                                    Padding="10" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="当前点位" FontSize="10" 
                                               Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="18" FontWeight="Bold" 
                                               Foreground="#111827" FontFamily="Consolas">
                                        <Run Text="P"/>
                                        <Run Text="{Binding Robot.Command.PointNum}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E5E7EB" 
                                    BorderThickness="1" CornerRadius="6" 
                                    Padding="10" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="错误代码" FontSize="10" 
                                               Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Robot.Status.ErrorCode}" 
                                               FontSize="18" FontWeight="Bold" 
                                               Foreground="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorValueConverter}}"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <Border Background="White" BorderBrush="#E5E7EB" 
                                    BorderThickness="1" CornerRadius="6" 
                                    Padding="10">
                                <StackPanel>
                                    <TextBlock Text="产品类型" FontSize="10" 
                                               Foreground="#6B7280" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Robot.Command.ProductType}" 
                                               FontSize="18" FontWeight="Bold" 
                                               Foreground="#111827" FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 轴控制区 -->
            <Border Grid.Row="4" Background="#F9FAFB" BorderBrush="#E5E7EB" 
                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="轴点动控制" Style="{StaticResource SectionTitle}"/>

                    <UniformGrid Grid.Row="1" Columns="6">
                        <!-- X轴 -->
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="X 轴" FontSize="14" FontWeight="Bold" 
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Button Content="前进 +" Style="{StaticResource BtnAxisForward}" 
                                        Margin="0,0,0,4"
                                        Command="{Binding JogXForwardCommand}"/>
                                <Button Content="后退 -" Style="{StaticResource BtnAxisBackward}"
                                        Command="{Binding JogXBackwardCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- Y轴 -->
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Y 轴" FontSize="14" FontWeight="Bold" 
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Button Content="前进 +" Style="{StaticResource BtnAxisForward}" 
                                        Margin="0,0,0,4"
                                        Command="{Binding JogYForwardCommand}"/>
                                <Button Content="后退 -" Style="{StaticResource BtnAxisBackward}"
                                        Command="{Binding JogYBackwardCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- Z轴 -->
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Z 轴" FontSize="14" FontWeight="Bold" 
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Button Content="前进 +" Style="{StaticResource BtnAxisForward}" 
                                        Margin="0,0,0,4"
                                        Command="{Binding JogZForwardCommand}"/>
                                <Button Content="后退 -" Style="{StaticResource BtnAxisBackward}"
                                        Command="{Binding JogZBackwardCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- U轴 -->
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="U 轴" FontSize="14" FontWeight="Bold" 
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Button Content="前进 +" Style="{StaticResource BtnAxisForward}" 
                                        Margin="0,0,0,4"
                                        Command="{Binding JogUForwardCommand}"/>
                                <Button Content="后退 -" Style="{StaticResource BtnAxisBackward}"
                                        Command="{Binding JogUBackwardCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- V轴 -->
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="V 轴" FontSize="14" FontWeight="Bold" 
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Button Content="前进 +" Style="{StaticResource BtnAxisForward}" 
                                        Margin="0,0,0,4"
                                        Command="{Binding JogVForwardCommand}"/>
                                <Button Content="后退 -" Style="{StaticResource BtnAxisBackward}"
                                        Command="{Binding JogVBackwardCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- W轴 -->
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8">
                            <StackPanel>
                                <TextBlock Text="W 轴" FontSize="14" FontWeight="Bold" 
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <Button Content="前进 +" Style="{StaticResource BtnAxisForward}" 
                                        Margin="0,0,0,4"
                                        Command="{Binding JogWForwardCommand}"/>
                                <Button Content="后退 -" Style="{StaticResource BtnAxisBackward}"
                                        Command="{Binding JogWBackwardCommand}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- 参数设置区 -->
            <Border Grid.Row="5" Background="#F9FAFB" BorderBrush="#E5E7EB" 
                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="参数设置" Style="{StaticResource SectionTitle}"/>

                    <UniformGrid Grid.Row="1" Columns="3">
                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="运行速度" FontSize="11" 
                                           Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding Robot.Command.Speed}" 
                                         Style="{StaticResource InputBox}" 
                                         Width="80"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="目标点位" FontSize="11" 
                                           Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding Robot.Command.PointNum}" 
                                         Style="{StaticResource InputBox}" 
                                         Width="80"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E5E7EB" 
                                BorderThickness="1" CornerRadius="6" 
                                Padding="8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="产品类型" FontSize="11" 
                                           Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding Robot.Command.ProductType}" 
                                         Style="{StaticResource InputBox}" 
                                         Width="80"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- 点位操作区 -->
            <Border Grid.Row="6" Background="#F9FAFB" BorderBrush="#E5E7EB" 
                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="点位操作" Style="{StaticResource SectionTitle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock Text="点位号:" FontSize="12" 
                                   Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="70" Margin="0,0,10,0"
                                  SelectedIndex="{Binding Robot.Command.PointNum}"
                                  Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem>P0</ComboBoxItem>
                            <ComboBoxItem>P1</ComboBoxItem>
                            <ComboBoxItem>P2</ComboBoxItem>
                            <ComboBoxItem>P3</ComboBoxItem>
                            <ComboBoxItem>P4</ComboBoxItem>
                            <ComboBoxItem>P5</ComboBoxItem>
                            <ComboBoxItem>P6</ComboBoxItem>
                            <ComboBoxItem>P7</ComboBoxItem>
                            <ComboBoxItem>P8</ComboBoxItem>
                            <ComboBoxItem>P9</ComboBoxItem>
                        </ComboBox>

                        <Button Content="保存点位" Style="{StaticResource BtnPrimary}" 
                                Margin="0,0,8,0" Padding="12,6"
                                Command="{Binding SavePointCommand}"/>
                        <Button Content="跳转点位" Style="{StaticResource BtnDefault}" 
                                Margin="0,0,20,0" Padding="12,6"
                                Command="{Binding JumpToPointCommand}"/>

                        <TextBlock Text="当前位置:" FontSize="12" 
                                   Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock FontSize="14" FontWeight="Bold" 
                                   Foreground="#2563EB" FontFamily="Consolas"
                                   VerticalAlignment="Center">
                            <Run Text="X:"/><Run Text="{Binding Robot.CurrentX, StringFormat=F2}"/>
                            <Run Text=" Y:"/><Run Text="{Binding Robot.CurrentY, StringFormat=F2}"/>
                            <Run Text=" Z:"/><Run Text="{Binding Robot.CurrentZ, StringFormat=F2}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 分隔线 -->
            <Border Grid.Row="7" Height="1" Background="#E5E7EB" Margin="0,0,0,12"/>

            <!-- 状态信息区 -->
            <Border Grid.Row="8" 
                    Background="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorBackgroundConverter}}"
                    BorderBrush="{Binding Robot.Status.Error, Converter={StaticResource BoolToErrorBorderConverter}}"
                    BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="{Binding Robot.Status.Error, Converter={StaticResource BoolToStatusTitleConverter}}" 
                               FontSize="11" 
                               Foreground="{Binding Robot.Status.Error, Converter={StaticResource BoolToStatusTitleColorConverter}}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Robot.Status.Error, Converter={StaticResource BoolToStatusMessageConverter}}" 
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{Binding Robot.Status.Error, Converter={StaticResource BoolToStatusMessageColorConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
